def acquire_lock(lock_path: Path):
    """Single-instance guard. Returns the lock fd; callers should keep it.

    Best-effort `mkdir` of the parent so manual / non-systemd invocations
    work, but under the systemd unit the parent is supposed to be
    created via `RuntimeDirectory=wireguardrtc`.  If the parent doesn't
    exist AND we can't create it, surface a clear error rather than a
    Python traceback — almost always the cause is that systemd's view
    of the unit is stale (forgot to `systemctl daemon-reload` after
    upgrading), or the dependency chain that pulls in the helpers
    didn't fire (forgot to `systemctl enable` them).
    """
    try:
        lock_path.parent.mkdir(parents=True, exist_ok=True)
    except PermissionError:
        if not lock_path.parent.exists():
            sys.stderr.write(
                f"[FATAL] lock-file directory {lock_path.parent} does "
                f"not exist and this process cannot create it "
                f"(EACCES on mkdir).\n"
                f"\n"
                f"Under systemd, the directory is normally created via "
                f"RuntimeDirectory=wireguardrtc.  After a package upgrade "
                f"that adds new helper units, you typically need:\n"
                f"\n"
                f"  sudo systemctl daemon-reload\n"
                f"  sudo systemctl enable --now \\\n"
                f"      wireguardrtc-key-oracle.service \\\n"
                f"      wireguardrtc-raw-helper.service \\\n"
                f"      wireguardrtc-provision-broker.socket\n"
                f"  sudo systemctl restart wireguardrtc.service\n"
                f"\n"
                f"For non-systemd invocations, override --lock-file to a "
                f"path under a directory you can write.\n")
            sys.exit(2)
        # Race: the dir exists now even though we got EACCES on mkdir;
        # treat that as success and fall through to the open
    fd = os.open(str(lock_path), os.O_CREAT | os.O_RDWR, 0o600)
    try:
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        sys.stderr.write(
            f"[FATAL] another wireguardrtc daemon already holds {lock_path}\n"
        )
        sys.exit(2)
    return fd


def probe_capabilities():
    """Daemon has no Linux capabilities after the privsep refactors —
    raw inject lives in wireguardrtc-raw-helper, key derivation lives
    in wireguardrtc-key-oracle, peer mutation lives in either of
    those depending on the operation.  All this needs to do is verify
    that the WireGuard kernel module is reachable for `wg show`."""
    out = wg_show("interfaces")
    if not out:
        sys.stderr.write("[FATAL] `wg show interfaces` returned nothing — "
                         "wireguard-tools missing or no interfaces?\n")
        sys.exit(2)


def _fmt_handshake_age(ts_str: str) -> str:
    """Convert a wg latest-handshakes timestamp string to a human-readable age."""
    try:
        ts = int(ts_str.strip())
    except (ValueError, AttributeError):
        return "never"
    if ts == 0:
        return "never"
    age = int(time.time()) - ts
    if age < 0:
        return "just now"
    if age < 120:
        return f"{age}s ago"
    if age < 7200:
        return f"{age // 60}m ago"
    return f"{age // 3600}h ago"


def cmd_show_config(args):
    """Print identity and suggested peer config; no lock or raw-socket needed."""
    gcfg = load_global_config(args.config)
    peer_cfgs = load_peer_configs(args.peers_dir)

    salt_fp = hashlib.sha256(gcfg.salt).hexdigest()[:16]

    iface_filter = getattr(args, "iface", None)

    # Gather kernel state for all (or one) WG interfaces.
    all_ifaces = list_interfaces()
    if iface_filter:
        if iface_filter not in all_ifaces:
            print(f"ERROR: interface '{iface_filter}' not found by `wg show interfaces`")
            print(f"Available interfaces: {' '.join(all_ifaces) or '(none)'}")
            return
        all_ifaces = [iface_filter]

    iface_info = {}   # iface -> (pub, port_str)
    iface_peers = {}  # iface -> set of peer pubkeys
    iface_endpoints = {}    # iface -> {peer_pk: endpoint_str}
    iface_handshakes = {}   # iface -> {peer_pk: ts_str}
    iface_allowedips = {}   # iface -> {peer_pk: allowed_ips_str}
    iface_keepalive = {}    # iface -> {peer_pk: keepalive_str}
    for iface in all_ifaces:
        pub = get_iface_field(iface, "public-key")
        port_s = get_iface_field(iface, "listen-port")
        if not pub:
            continue
        iface_info[iface] = (pub, port_s)
        aips = get_iface_table(iface, "allowed-ips")
        iface_allowedips[iface] = aips
        iface_peers[iface] = set(aips.keys())
        iface_endpoints[iface] = get_iface_table(iface, "endpoints")
        iface_handshakes[iface] = get_iface_table(iface, "latest-handshakes")
        iface_keepalive[iface] = get_iface_table(iface, "persistent-keepalive")

    # ------------------------------------------------------------------ #
    # Section 1 — THIS PEER: kernel WG state cross-referenced with peers.d
    # ------------------------------------------------------------------ #
    print("=" * 72)
    print("THIS PEER  (kernel WireGuard state)")
    print("=" * 72)
    print(f"  salt-fingerprint : {salt_fp}"
          "  (SHA-256 of Salt; must match on every peer)")
    if not iface_info:
        print("  WARNING: no WireGuard interfaces found")
    for iface, (pub, port) in iface_info.items():
        our_id = routing_id(pub, gcfg.salt)
        print()
        print(f"  INTERFACE  {iface}")
        print(f"    public-key   {pub}")
        print(f"    listen-port  {port or '(not set)'}")
        print(f"    broker-id    {our_id}")
        peers_here = iface_peers.get(iface, set())
        if not peers_here:
            print(f"    (no WireGuard peers configured on {iface})")
            continue
        print(f"    WireGuard peers ({len(peers_here)}):")
        for peer_pk in sorted(peers_here):
            pid = routing_id(peer_pk, gcfg.salt)
            ep = iface_endpoints.get(iface, {}).get(peer_pk, "(none)").strip()
            hs = _fmt_handshake_age(iface_handshakes.get(iface, {}).get(peer_pk, "0"))
            aip = iface_allowedips.get(iface, {}).get(peer_pk, "").strip()
            ka = iface_keepalive.get(iface, {}).get(peer_pk, "off").strip()
            if peer_pk in peer_cfgs:
                cfg_label = peer_cfgs[peer_pk].label
                cfg_mode = peer_cfgs[peer_pk].mode.value
                cfg_tag = f"peers.d: [{cfg_label}]  mode={cfg_mode}"
            else:
                cfg_tag = "peers.d: (no entry — daemon ignores this peer)"
            print(f"      peer {peer_pk}")
            print(f"        broker-id        {pid}")
            print(f"        allowed-ips      {aip or '(none)'}")
            print(f"        endpoint         {ep}")
            print(f"        last-handshake   {hs}")
            print(f"        keepalive        {ka}")
            print(f"        {cfg_tag}")
    print()

    # ------------------------------------------------------------------ #
    # Section 2 — PEERS.D entries: cross-reference with kernel state
    # ------------------------------------------------------------------ #
    print("=" * 72)
    print(f"PEERS.D  ({args.peers_dir})")
    print("=" * 72)
    if not peer_cfgs:
        print(f"  (no peer drop-ins found under {args.peers_dir})")
    for pk, cfg in peer_cfgs.items():
        found_on = sorted(i for i, ps in iface_peers.items() if pk in ps)
        if iface_filter and iface_filter not in found_on:
            # In filtered mode only show peers relevant to that interface,
            # but still show entries that claim this interface but aren't found.
            pass  # included below via the warning block
        wg_status = f"on {', '.join(found_on)}" if found_on else "NOT FOUND IN KERNEL WG PEERS"

        print()
        print(f"  PEER [{cfg.label}]  mode={cfg.mode.value}  kernel-status={wg_status}")
        print(f"    public-key  {pk}")

        if cfg.mode == Mode.IGNORE:
            print("    (mode=ignore — daemon takes no action for this peer)")
        elif cfg.mode == Mode.DNS_ROAM:
            print(f"    dns-host    {cfg.dns_host}")
            print("    (mode=dns-roam — endpoint updated from DNS, no PeerJS)")
        else:  # ACTIVE or PASSIVE
            peer_broker_id = routing_id(pk, gcfg.salt)
            print(f"    broker-id   {peer_broker_id}")
            if not found_on:
                print()
                print("    !!! PUBLIC KEY NOT FOUND AS A WG PEER ON THIS MACHINE.")
                print("    !!! peers.d PublicKey must match a key in `wg show` output")
                print("    !!! on THIS host — i.e. the REMOTE host's interface public key")
                print("    !!! as seen by this machine, not the remote's peers.d key.")
                all_peers = {p for ps in iface_peers.values() for p in ps}
                if all_peers:
                    print()
                    print("    All WireGuard peers on this machine:")
                    for candidate in sorted(all_peers):
                        on = [i for i, ps in iface_peers.items() if candidate in ps]
                        clabel = peer_cfgs[candidate].label if candidate in peer_cfgs else ""
                        csuffix = f"  [{clabel}]" if clabel else ""
                        cid = routing_id(candidate, gcfg.salt)
                        print(f"      {candidate}  (on {', '.join(on)}){csuffix}")
                        print(f"        broker-id {cid}")
            else:
                suggested_mode = "passive" if cfg.mode == Mode.ACTIVE else "active"
                for iface in found_on:
                    pub_us, port_us = iface_info[iface]
                    our_broker_id = routing_id(pub_us, gcfg.salt)
                    print()
                    print(f"    Suggested peers.d drop-in on the remote host [{cfg.label}]"
                          f" for its side of {iface}:")
                    print(f"      [Peer]")
                    print(f"      PublicKey = {pub_us}  # this host's {iface} public-key")
                    print(f"      Mode = {suggested_mode}")
                    print(f"      # broker-id this host will use on {iface}: {our_broker_id}")
        print()


def _b64url_nopad(data: bytes) -> str:
    return base64.urlsafe_b64encode(data).rstrip(b"=").decode("ascii")


def cmd_enroll_token(args):
    """Mint a single-use enrollment token, persist it, print the
    `wgrtc-enroll://v1?...` URI to stdout (and a terminal QR if isatty
    and qrencode is available)."""
    gcfg = load_global_config(args.config)
    if not gcfg.enrollment_enabled:
        sys.stderr.write(
            f"[FATAL] {args.config}: [Enrollment] Enabled = no.\n"
            "Set Enabled = yes and ProvisionScript = ... to use enrollment.\n")
        sys.exit(2)

    # Pick the WG interface whose pubkey we'll embed in the URI.
    all_ifaces = list_interfaces()
    iface = args.iface
    if iface is None:
        if not all_ifaces:
            sys.stderr.write(
                "[FATAL] no WireGuard interfaces found; cannot mint enrollment "
                "token without a server pubkey to embed in the URI.\n")
            sys.exit(2)
        if len(all_ifaces) == 1:
            iface = all_ifaces[0]
        else:
            sys.stderr.write(
                f"[FATAL] multiple WireGuard interfaces present "
                f"({', '.join(all_ifaces)}); pick one with --iface.\n")
            sys.exit(2)
    elif iface not in all_ifaces:
        sys.stderr.write(
            f"[FATAL] interface {iface!r} not found "
            f"(have: {', '.join(all_ifaces) or 'none'}).\n")
        sys.exit(2)

    server_pub = get_iface_field(iface, "public-key")
    if not server_pub:
        sys.stderr.write(
            f"[FATAL] could not read public key of {iface}; daemon needs "
            "CAP_NET_ADMIN (or root) for `wg show <iface> public-key`.\n")
        sys.exit(2)

    # Validate name hint.
    name_hint = (args.enroll_token or "").strip()
    if not name_hint:
        sys.stderr.write("[FATAL] empty NAME for --enroll-token.\n")
        sys.exit(2)
    if len(name_hint) > 64:
        sys.stderr.write(
            f"[FATAL] NAME too long ({len(name_hint)} chars; max 64).\n")
        sys.exit(2)
    if any(c in name_hint for c in "\x00\n\r"):
        sys.stderr.write(
            "[FATAL] NAME may not contain NUL or newlines.\n")
        sys.exit(2)

    expires_in = float(args.expires) if args.expires else TOKEN_DEFAULT_EXPIRY
    if expires_in < 60 or expires_in > 7 * 86400:
        sys.stderr.write(
            f"[FATAL] --expires {expires_in:.0f}s out of range (60..604800).\n")
        sys.exit(2)

    store = PendingTokensStore(gcfg.state_dir)
    try:
        token, superseded = store.mint(
            name_hint, expires_in=expires_in,
            iface=iface,
            max_pending=gcfg.max_pending_tokens)
    except RuntimeError as e:
        sys.stderr.write(f"[FATAL] {e}\n")
        sys.exit(2)
    if superseded is not None:
        # Same-name re-mint: previous unexpired token was just removed
        # in favour of the one we're about to print.  Warn the admin —
        # the supported scenarios are "QR was lost" or "token close to
        # expiry, refresh now"; either way they should know that any
        # outstanding URL is now invalid.
        prev_iso = time.strftime("%Y-%m-%dT%H:%M:%SZ",
                                 time.gmtime(superseded.get("created_at", 0)))
        prev_exp = time.strftime("%Y-%m-%dT%H:%M:%SZ",
                                 time.gmtime(superseded.get("expires_at", 0)))
        sys.stderr.write(
            f"note: replaced previous unexpired token for "
            f"\"{name_hint}\" (issued {prev_iso}, was valid until "
            f"{prev_exp}); the previously-printed URL is now invalid.\n")
        # Best-effort: also remove the broker permit for the superseded
        # token so a stale URL can't sneak through if the admin shipped
        # it before the supersede.
        try:
            prev_token = base64.b64decode(superseded.get("token_b64", ""))
            if prev_token:
                remove_provision_permit(prev_token)
        except Exception:
            pass

    # Decode server pubkey to raw bytes for compact URL-safe encoding.
    try:
        server_pub_raw = base64.b64decode(server_pub)
    except Exception:
        sys.stderr.write(
            f"[FATAL] {iface} public key is not valid base64: {server_pub!r}\n")
        sys.exit(2)

    salt_b64url = _b64url_nopad(gcfg.salt)
    pk_b64url = _b64url_nopad(server_pub_raw)
    token_b64url = _b64url_nopad(token)
    expires_at = int(time.time() + expires_in)

    # Drop a single-use permit file in the broker's trust directory
    # (mode 0700, root-only).  When the broker later receives a
    # provisioning request from the daemon, it looks for this permit;
    # without it the request is refused.  Effect: a daemon RCE cannot
    # provision arbitrary peers outside the window between mint and
    # legitimate consumption.  See SECURITY/Auto-enrollment privilege
    # separation in wireguardrtc(8).
    #
    # CR-D1: PermissionError is handled inside write_provision_permit
    # itself (mint stays valid, broker just won't auto-provision —
    # admin re-runs under sudo).  Any other OSError (ENOSPC, EIO,
    # etc.) leaves the just-minted token orphaned in pending-tokens.json
    # — the daemon would accept the ENROLL but the broker would
    # refuse for lack of permit.  Roll back by calling unmint
    try:
        write_provision_permit(token, name_hint, expires_at)
    except Exception as e:
        try:
            store.unmint(token)
        except Exception as rollback_err:
            sys.stderr.write(
                f"[FATAL] permit write failed AND rollback failed: "
                f"{type(e).__name__}: {e}; rollback: "
                f"{type(rollback_err).__name__}: {rollback_err}.  "
                f"Manually edit pending-tokens.json to remove the "
                f"orphaned token if necessary.\n")
            sys.exit(2)
        sys.stderr.write(
            f"[FATAL] could not write provisioning permit "
            f"({type(e).__name__}: {e}).  Mint rolled back; no token "
            f"was committed.  Resolve the underlying I/O issue and "
            f"retry the mint command.\n")
        sys.exit(2)

    # Build URI.  urlencode does the right thing with reserved chars.
    params = [
        ("pk",        pk_b64url),
        ("salt",      salt_b64url),
        ("broker",    gcfg.peerjs_server),
        ("brokerkey", gcfg.peerjs_key),
        ("token",     token_b64url),
        ("expires",   str(expires_at)),
        ("server",    name_hint),  # hint for the phone's UI
    ]
    import urllib.parse as _up
    qs = _up.urlencode(params, safe="-_.~")
    uri = f"wgrtc-enroll://v1?{qs}"

    print(uri)

    # Render QR code if stdout is a TTY and qrencode is available.
    if sys.stdout.isatty():
        try:
            res = subprocess.run(
                ["qrencode", "-t", "ansiutf8", "-o", "-", uri],
                capture_output=True, text=True, timeout=5)
            if res.returncode == 0:
                print()
                sys.stdout.write(res.stdout)
                print()
        except (FileNotFoundError, subprocess.TimeoutExpired):
            pass

    # Diagnostics on stderr (no secrets, just a confirmation).
    sys.stderr.write(
        f"\nMinted enrollment token for '{name_hint}':\n"
        f"  expires: {expires_in:.0f}s from now ({expires_at} unix)\n"
        f"  iface:   {iface}\n"
        f"  state:   {store.path}\n"
    )


def _reverse_dns(ip, timeout=2.0):
    """Best-effort PTR lookup with a wall-clock timeout.  Returns the
    hostname on success, None on failure or timeout.  Runs in a
    daemon thread so the main thread can move on if the resolver is
    slow or unreachable."""
    import threading
    result = [None]

    def worker():
        try:
            host, _, _ = socket.gethostbyaddr(ip)
            result[0] = host
        except Exception:
            pass

    t = threading.Thread(target=worker, daemon=True)
    t.start()
    t.join(timeout)
    return result[0]


def _ip_equal(a, b):
    """Compare two address strings for representational equality.
    Canonicalises via inet_pton/inet_ntop so e.g. '::1' == '0:0:0:0:0:0:0:1'."""
    if a is None or b is None:
        return False
    for fam in (socket.AF_INET, socket.AF_INET6):
        try:
            return socket.inet_pton(fam, a) == socket.inet_pton(fam, b)
        except OSError:
            continue
    return a == b


def _discover_local_ip(family):
    """Ask the kernel which local address it would route outbound traffic
    over for the given family.  Returns the address as a string, or None
    if the family isn't reachable at all (no v4 stack, no v6 stack)."""
    # Use a public anycast address — no traffic is actually sent for
    # a connect() on an unbound UDP socket; the kernel only performs
    # a route lookup.
    sample = ("8.8.8.8", 80) if family == socket.AF_INET \
             else ("2001:4860:4860::8888", 80)
    try:
        s = socket.socket(family, socket.SOCK_DGRAM)
        try:
            s.connect(sample)
            ip = s.getsockname()[0]
            return ip
        finally:
            s.close()
    except OSError:
        return None


def _check_nat_family(family, servers, src_ports):
    """Probe every (server, src_port) combo over the given family.
    Returns (probes, failures, label) suitable for classify_nat_result()
    and pretty printing."""
    family_label = "IPv4" if family == socket.AF_INET else "IPv6"
    bind_addr = "0.0.0.0" if family == socket.AF_INET else "::"
    probes = []
    failures = []
    magic = 0x2112A442
    for server in servers:
        host, port_str = server.rsplit(":", 1)
        port = int(port_str)
        try:
            infos = socket.getaddrinfo(
                host, port, family=family, type=socket.SOCK_DGRAM)
        except socket.gaierror as e:
            for src_port in src_ports:
                failures.append((server, src_port, f"DNS: {e}"))
                print(f"  {server:32s}  src={src_port:>5d}  "
                      f"->  FAILED: DNS ({family_label})")
            continue
        if not infos:
            for src_port in src_ports:
                failures.append((server, src_port, "no address records"))
                print(f"  {server:32s}  src={src_port:>5d}  "
                      f"->  FAILED: no {family_label} record")
            continue
        server_ip = infos[0][4][0]
        for src_port in src_ports:
            sock = socket.socket(family, socket.SOCK_DGRAM)
            if family == socket.AF_INET6:
                try:
                    sock.setsockopt(socket.IPPROTO_IPV6,
                                    socket.IPV6_V6ONLY, 1)
                except OSError:
                    pass
            try:
                sock.bind((bind_addr, src_port))
                local_port = sock.getsockname()[1]
                txid = os.urandom(12)
                request = struct.pack("!HHL12s", 0x0001, 0, magic, txid)
                sock.settimeout(2.0)
                sock.sendto(request, (server_ip, port))
                deadline = time.time() + 2.0
                parsed = None
                while time.time() < deadline:
                    data, _ = sock.recvfrom(2048)
                    parsed = _parse_stun_xor_mapped(data, txid)
                    if parsed is not None:
                        break
                if parsed is None:
                    raise RuntimeError("XOR-MAPPED-ADDRESS not in response")
                ext_ip, ext_port = parsed
                probes.append((server, local_port, ext_ip, ext_port))
                tag = "preserved" if ext_port == local_port else "remapped"
                print(f"  {server:32s}  src={local_port:>5d}  "
                      f"->  {ext_ip}:{ext_port}  ({tag})")
            except Exception as e:
                failures.append((server, src_port, str(e)))
                print(f"  {server:32s}  src={src_port:>5d}  ->  FAILED: {e}")
            finally:
                sock.close()
    return probes, failures, family_label


def _format_with_rdns(ip):
    """Return 'IP' or 'IP (rdns)' if reverse lookup succeeds within the
    short timeout.  Used for one-line address display."""
    host = _reverse_dns(ip, timeout=2.0) if ip else None
    return f"{ip} ({host})" if host else (ip or "(none)")


def _print_family_verdict(family, servers, src_ports):
    """Run a single-family probe and print its section.  Returns True if
    the family is viable for wgrtc (port-preserving cone or single
    no-NAT path), False otherwise."""
    family_label = "IPv4" if family == socket.AF_INET else "IPv6"
    local_ip = _discover_local_ip(family)
    print(f"━━ {family_label} ━━")
    print(f"Local address: {_format_with_rdns(local_ip)}")
    if local_ip is None:
        print(f"No {family_label} route on this host — skipping STUN probe.")
        print()
        return None
    print(f"Source ports:  {src_ports}")
    print()
    probes, failures, _ = _check_nat_family(family, servers, src_ports)
    verdict = classify_nat_result(probes)
    print()
    if verdict.external_ips:
        for ip in verdict.external_ips:
            print(f"External {family_label}: {_format_with_rdns(ip)}")
    else:
        print(f"External {family_label}: (none)")
    # NAT presence is orthogonal to port-preservation: a network can
    # legitimately have no NAT (IPv6 direct), or NAT (RFC1918 v4, or
    # NAT66/NPT on v6 with a different external prefix), and either
    # case may be port-preserving from STUN's perspective.  Compute
    # this independently of the port classifier.
    if verdict.external_ips:
        nat_detected = not any(_ip_equal(local_ip, ext)
                                for ext in verdict.external_ips)
        if nat_detected:
            print(f"NAT presence:  detected "
                  f"(external address differs from local)")
        else:
            print(f"NAT presence:  none — direct end-to-end")
    print(f"Verdict:       {verdict.kind}")
    print(f"  cone:             {verdict.cone}")
    print(f"  port-preserving:  {verdict.port_preserving}")
    print()
    print(verdict.summary)
    if family == socket.AF_INET6 and not probes and not failures:
        print("(No IPv6 STUN servers responded — likely v6-disabled "
              "upstream or v6-only-locally.)")
    elif failures:
        print(f"({len(failures)} probe(s) failed; verdict based on the rest)")
    print()
    return verdict.wgrtc_viable


def cmd_check_nat(args):
    """Run STUN probes from 3 source ports across the chosen address
    families, classify each family independently, print verdicts, and
    exit 0 only if at least one family is viable.

    IPv4 and IPv6 are routed independently — even if your v4 path is
    behind symmetric NAT, your v6 path may be NAT-free.  The two
    verdicts together describe the network honestly."""
    servers = args.stun_servers or DEFAULT_STUN_SERVERS

    family = (args.family or "auto").lower()
    families = []
    if family in ("auto", "4", "ipv4", "v4"):
        families.append(socket.AF_INET)
    if family in ("auto", "6", "ipv6", "v6"):
        families.append(socket.AF_INET6)
    if not families:
        sys.stderr.write(f"Unrecognised --family value: {args.family!r}\n")
        sys.exit(2)

    # Pick three distinct ephemeral source ports up front — these are
    # reused across families.  Ports are family-agnostic; the same port
    # number is fine on both stacks.
    src_ports = []
    for _ in range(3):
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.bind(("0.0.0.0", 0))
        src_ports.append(s.getsockname()[1])
        s.close()
        time.sleep(0.05)

    print(f"STUN servers:  {', '.join(servers)}")
    print()

    viable = []
    for fam in families:
        v = _print_family_verdict(fam, servers, src_ports)
        viable.append(v)

    any_viable = any(v is True for v in viable)
    sys.exit(0 if any_viable else 1)


def _read_broker_config(global_config_path):
    """Read [Signaling] Server / Key from the global config file.
    Falls back to defaults if the file doesn't exist or doesn't
    specify these values.  Used by the wormhole CLI subcommands."""
    cp = configparser.ConfigParser()
    cp.optionxform = str
    try:
        cp.read(global_config_path)
    except Exception:
        pass
    server = cp.get("Signaling", "Server",
                     fallback=DEFAULT_PEERJS_SERVER)
    key = cp.get("Signaling", "Key", fallback=DEFAULT_PEERJS_KEY)
    return server, key


class WormholeBrokerTransport:
    """Minimal async WSS transport for wormhole-pairing CLI subcommands.

    Connects to the broker, subscribes under [routing_id], runs a
    HEARTBEAT loop while open, exposes async send / recv / close
    matching WormholeFlow's transport contract.  Separate from the
    daemon's long-lived PeerJSClient because the wormhole flow is
    one-shot (no reconnect needed) and the daemon may not even be
    running on the joiner side.
    """

    def __init__(self, server, key, our_routing_id):
        self._server = server
        self._key = key
        self._our_id = our_routing_id
        self._ws = None
        self._inbound = asyncio.Queue()
        self._stop = asyncio.Event()
        self._tasks = []

    async def open(self, open_timeout=15.0):
        sep = "&" if "?" in self._server else "?"
        token = secrets.token_hex(8)
        uri = (f"{self._server}{sep}key={self._key}&id={self._our_id}"
               f"&token={token}&version=1.5.2")
        self._ws = await websockets.connect(uri)
        # Wait for the broker's OPEN frame before allowing send().
        raw = await asyncio.wait_for(self._ws.recv(),
                                      timeout=open_timeout)
        msg = json.loads(raw)
        if msg.get("type") != "OPEN":
            raise WormholeFailed(
                f"broker did not OPEN (got {msg!r})")
        # Inbound + heartbeat loops live for the session lifetime.
        self._tasks.append(asyncio.create_task(self._recv_loop()))
        self._tasks.append(asyncio.create_task(self._heartbeat_loop()))

    async def _recv_loop(self):
        try:
            while not self._stop.is_set():
                raw = await self._ws.recv()
                try:
                    msg = json.loads(raw)
                except json.JSONDecodeError:
                    continue
                await self._inbound.put(msg)
        except Exception:
            # Connection closed or torn down — signal recv() callers
            # by leaving the queue empty.  The wait_for at the call
            # site bounds blocking.
            return

    async def _heartbeat_loop(self):
        while not self._stop.is_set():
            try:
                await asyncio.wait_for(self._stop.wait(),
                                        timeout=PEERJS_HEARTBEAT)
                return
            except asyncio.TimeoutError:
                pass
            try:
                await self._ws.send('{"type":"HEARTBEAT"}')
            except Exception:
                return

    async def send(self, envelope):
        if self._ws is None or self._stop.is_set():
            return False
        try:
            await self._ws.send(json.dumps(envelope))
            return True
        except Exception:
            return False

    async def recv(self):
        return await self._inbound.get()

    async def close(self):
        self._stop.set()
        if self._ws is not None:
            try:
                await self._ws.close()
            except Exception:
                pass
        for t in self._tasks:
            t.cancel()
        for t in self._tasks:
            try:
                await t
            except (asyncio.CancelledError, Exception):
                pass


def _confirm_sas_interactive(phrase):
    """Default SAS-confirm callback: print + read y/n from stdin.

    Returns True iff the user typed 'y' (case-insensitive).  Anything
    else, including EOF, treats as a NO — better fail-closed than
    silently accept on a hung prompt.
    """
    sys.stdout.write(f"\nSAS phrase: {phrase}\n")
    sys.stdout.write("Confirm match on the other device.\n")
    sys.stdout.write("Match? [y/N]: ")
    sys.stdout.flush()
    try:
        ans = sys.stdin.readline().strip().lower()
    except EOFError:
        return False
    return ans == "y"


def cmd_use_wormhole(args):
    """Joiner side: type a wormhole code, exchange enrollment info,
    print a wg-quick config the user can persist."""
    code = wormhole_normalize(args.use_wormhole)
    if not wormhole_is_valid(code):
        sys.stderr.write(
            f"Invalid wormhole code: {args.use_wormhole!r} "
            f"(after normalization: {code!r}, "
            f"expected {WORMHOLE_DEFAULT_LENGTH} letters from {WORMHOLE_ALPHABET})\n")
        sys.exit(2)
    code_bytes = wormhole_to_bytes(code)
    broker_server, broker_key = _read_broker_config(args.config)

    # Generate a fresh joiner WG keypair so the user can copy the
    # private key into wg-quick.  We don't write it to disk — the
    # user pastes both halves themselves.
    import subprocess
    try:
        priv = subprocess.check_output(["wg", "genkey"]).strip()
        pub = subprocess.check_output(["wg", "pubkey"], input=priv).strip()
    except (OSError, subprocess.CalledProcessError) as e:
        sys.stderr.write(f"failed to generate WG keypair via wg(8): {e}\n"
                          "Install wireguard-tools or pass --my-pubkey.\n")
        sys.exit(2)
    joiner_pub_b64 = pub.decode("ascii")
    joiner_priv_b64 = priv.decode("ascii")
    device_name = args.device_name

    async def _run():
        transport = WormholeBrokerTransport(
            broker_server, broker_key,
            sas_routing_id_initiator(code_bytes))
        await transport.open()
        try:
            flow = WormholeFlow(role="initiator",
                                 code_bytes=code_bytes,
                                 transport=transport)
            try:
                sas, host_info = await flow.run_joiner(
                    joiner_pubkey_b64=joiner_pub_b64,
                    device_name=device_name,
                    confirm_sas=_confirm_sas_interactive,
                )
            except SasAborted:
                sys.stderr.write("\nAborted: SAS did not match.\n")
                sys.exit(3)
            return sas, host_info
        finally:
            await transport.close()

    sys.stdout.write(f"Connecting to broker {broker_server} ...\n")
    sys.stdout.write(f"Typed code: {code}\n")
    sys.stdout.write("Waiting for the host to mint this code...\n")
    sys.stdout.flush()
    try:
        sas, host_info = asyncio.run(_run())
    except WormholeFailed as e:
        sys.stderr.write(f"\nWormhole pairing failed: {e}\n")
        sys.exit(4)
    except KeyboardInterrupt:
        sys.stderr.write("\nInterrupted.\n")
        sys.exit(130)

    sys.stdout.write("\nEnrollment received.  Suggested wg-quick config:\n")
    sys.stdout.write("=" * 60 + "\n")
    sys.stdout.write(f"[Interface]\nPrivateKey = {joiner_priv_b64}\n")
    sys.stdout.write(f"Address = {host_info['assigned_address']}\n")
    if host_info.get("dns"):
        sys.stdout.write(f"DNS = {host_info['dns']}\n")
        if host_info.get("mtu"):
            sys.stdout.write(f"MTU = {host_info['mtu']}\n")
    sys.stdout.write(f"\n[Peer]\nPublicKey = {host_info['wg_pubkey']}\n")
    sys.stdout.write(f"Endpoint = {host_info['wg_endpoint']}\n")
    sys.stdout.write(f"AllowedIPs = {host_info['allowed_ips']}\n")
    if host_info.get("keepalive"):
        sys.stdout.write(f"PersistentKeepalive = {host_info['keepalive']}\n")
    sys.stdout.write("=" * 60 + "\n")
    if host_info.get("host_name"):
        sys.stdout.write(f"\nPaired with: {host_info['host_name']}\n")


def cmd_mint_wormhole(args):
    """Host side: generate a wormhole code, advertise it, await a
    joiner, and on success print the peer drop-in for the daemon."""
    code = wormhole_generate(length=WORMHOLE_DEFAULT_LENGTH)
    code_bytes = wormhole_to_bytes(code)
    broker_server, broker_key = _read_broker_config(args.config)

    iface = args.iface
    if iface is None:
        sys.stderr.write(
            "--mint-wormhole requires --iface <wg-interface> so we know "
            "which WG identity to advertise to the joiner.\n")
        sys.exit(2)

    # Read host's WG pubkey + listen-port via wg(8).  Requires
    # CAP_NET_ADMIN (root or the wireguardrtc group).
    try:
        host_pub = wg_show(iface, "public-key")
        listen_port = wg_show(iface, "listen-port")
    except Exception as e:
        sys.stderr.write(f"failed to read WG state for {iface!r}: {e}\n")
        sys.exit(2)
    host_pub = (host_pub or "").strip()
    listen_port = (listen_port or "").strip()
    if not host_pub or not listen_port:
        sys.stderr.write(
            f"interface {iface!r} did not return pubkey/port "
            "(missing, no permission, or not a WG interface).\n")
        sys.exit(2)

    wg_endpoint = args.endpoint or f"0.0.0.0:{listen_port}"
    assigned_address = args.assigned_address
    allowed_ips = args.allowed_ips or assigned_address

    async def _run():
        transport = WormholeBrokerTransport(
            broker_server, broker_key,
            sas_routing_id_responder(code_bytes))
        await transport.open()
        try:
            flow = WormholeFlow(role="responder",
                                 code_bytes=code_bytes,
                                 transport=transport)
            try:
                sas, joiner_info = await flow.run_host(
                    host_info=dict(
                        wg_pubkey_b64=host_pub,
                        wg_endpoint=wg_endpoint,
                        assigned_address=assigned_address,
                        allowed_ips=allowed_ips,
                        host_name=args.host_name or socket.gethostname(),
                        keepalive=args.keepalive,
                    ),
                    confirm_sas=_confirm_sas_interactive,
                )
            except SasAborted:
                sys.stderr.write("\nAborted: SAS did not match.\n")
                sys.exit(3)
            return sas, joiner_info
        finally:
            await transport.close()

    sys.stdout.write(f"Wormhole code: {code}\n")
    sys.stdout.write(f"Broker: {broker_server}\n")
    sys.stdout.write("Tell the joiner: run\n")
    sys.stdout.write(f"  sudo wireguardrtc --use-wormhole {code}\n")
    sys.stdout.write("Waiting for joiner to connect...\n")
    sys.stdout.flush()
    try:
        sas, joiner_info = asyncio.run(_run())
    except WormholeFailed as e:
        sys.stderr.write(f"\nWormhole pairing failed: {e}\n")
        sys.exit(4)
    except KeyboardInterrupt:
        sys.stderr.write("\nInterrupted.\n")
        sys.exit(130)

    label = args.label or (joiner_info.get("device_name") or "wormhole-peer")
    sys.stdout.write("\nEnrollment received.  Add this peer to the daemon:\n")
    sys.stdout.write("=" * 60 + "\n")
    sys.stdout.write(f"# /etc/wireguardrtc/peers.d/{label}.conf\n")
    sys.stdout.write("[Peer]\n")
    sys.stdout.write(f"PublicKey = {joiner_info['wg_pubkey']}\n")
    sys.stdout.write("Mode = active\n")
    sys.stdout.write("=" * 60 + "\n")


def main():
    ap = argparse.ArgumentParser(description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("--config", type=Path, default=GLOBAL_CONFIG)
    ap.add_argument("--peers-dir", type=Path, default=PEERS_DIR)
    ap.add_argument("--lock-file", type=Path, default=LOCK_FILE,
                    help=f"path to single-instance lock file "
                         f"(default: {LOCK_FILE}; also via "
                         f"WIREGUARDRTC_LOCK_FILE env)")
    ap.add_argument("--log-level", default=os.environ.get("LOG_LEVEL", "INFO"),
                    choices=["DEBUG", "INFO", "WARNING", "ERROR"])
    ap.add_argument("--show-config", action="store_true",
                    help="print identity, broker IDs, and suggested peer config; then exit")
    ap.add_argument("--iface", metavar="IFACE", default=None,
                    help="with --show-config or --enroll-token: WireGuard interface to use")
    ap.add_argument("--enroll-token", metavar="NAME", default=None,
                    help="mint a single-use enrollment token for NAME and "
                         "print the wgrtc-enroll:// URI; then exit")
    ap.add_argument("--expires", metavar="SECONDS", type=int, default=None,
                    help=f"with --enroll-token: token validity window "
                         f"(default {int(TOKEN_DEFAULT_EXPIRY)}s, range 60..604800)")
    ap.add_argument("--check-nat", action="store_true",
                    help="probe STUN servers and classify this network's NAT "
                         "for each address family available; exit 0 if at "
                         "least one family is viable")
    ap.add_argument("--family", choices=("auto", "4", "6"), default="auto",
                    help="with --check-nat: restrict probing to a single "
                         "address family (default: auto = both v4 and v6 "
                         "where available)")
    ap.add_argument("--stun-servers", metavar="HOST:PORT", nargs="+",
                    default=None,
                    help="with --check-nat: STUN servers to probe "
                         "(default: stun.l.google.com, stun.cloudflare.com, "
                         "stun.nextcloud.com)")
    ap.add_argument("--mint-wormhole", action="store_true",
                    help="mint a wormhole code (host side), wait for "
                         "a joiner to type it, run SPAKE2+SAS, and "
                         "print the peer drop-in needed to authorize "
                         "them.  Requires --iface.")
    ap.add_argument("--use-wormhole", metavar="CODE", default=None,
                    help="join a tunnel using a wormhole code (joiner "
                         "side).  Runs SPAKE2+SAS against the host who "
                         "minted the same code, then prints a wg-quick "
                         "config the user can save.")
    ap.add_argument("--label", default=None,
                    help="with --mint-wormhole: label for the peer "
                         "drop-in file.  Defaults to the joiner's "
                         "device name (or 'wormhole-peer').")
    ap.add_argument("--endpoint", default=None,
                    help="with --mint-wormhole: host's external "
                         "endpoint (ip:port) to advertise to the "
                         "joiner.  Defaults to 0.0.0.0:<listen-port>.")
    ap.add_argument("--assigned-address", default="10.99.0.2/32",
                    help="with --mint-wormhole: address to advertise "
                         "to the joiner for [Interface] Address.")
    ap.add_argument("--allowed-ips", default=None,
                    help="with --mint-wormhole: AllowedIPs to advertise "
                         "to the joiner.  Defaults to the assigned "
                         "address as a /32.")
    ap.add_argument("--host-name", default=None,
                    help="with --mint-wormhole: friendly host name "
                         "shown to the joiner.  Defaults to hostname.")
    ap.add_argument("--keepalive", type=int, default=25,
                    help="with --mint-wormhole: PersistentKeepalive "
                         "(seconds) to advertise to the joiner.  "
                         "0 disables.  Default: 25.")
    ap.add_argument("--device-name", default=None,
                    help="with --use-wormhole: friendly name for "
                         "this device sent to the host.  Defaults to "
                         "this machine's hostname.")
    args = ap.parse_args()

    if args.show_config:
        cmd_show_config(args)
        return
    if args.enroll_token:
        cmd_enroll_token(args)
        return
    if args.check_nat:
        cmd_check_nat(args)
        return
    if args.mint_wormhole:
        cmd_mint_wormhole(args)
        return
    if args.use_wormhole:
        cmd_use_wormhole(args)
        return

    logging.basicConfig(
        level=args.log_level,
        format="%(asctime)s %(levelname)s %(message)s",
        datefmt="%Y-%m-%dT%H:%M:%S",
    )

    # Validate config up-front, BEFORE the lock and the capability probe.
    # This way a config-error message is the first thing the user sees,
    # not "cannot create raw socket" — far better UX for misconfigurations.
    load_global_config(args.config)
    load_peer_configs(args.peers_dir)

    lock_fd = acquire_lock(args.lock_file)  # noqa: F841 — keep it open
    probe_capabilities()

    daemon = Daemon(args)

    loop = asyncio.new_event_loop()
    asyncio.set_event_loop(loop)

    def _shutdown(*_):
        logging.info("shutdown signalled")
        loop.call_soon_threadsafe(daemon.shutdown_event.set)

    for sig in (signal.SIGTERM, signal.SIGINT):
        loop.add_signal_handler(sig, _shutdown)

    try:
        loop.run_until_complete(daemon.run())
    finally:
        loop.close()


if __name__ == "__main__":
    main()
