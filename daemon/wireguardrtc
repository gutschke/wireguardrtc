def derive_sas(shared_key, word_count=4):
    """Derive a SAS phrase from a SPAKE2 shared key.

    Parameters mirror Android's deriveSas: a 32-byte shared key (we
    accept ≥16 for symmetry with the JVM tests), and a word_count
    in [0, 32].  Each byte of the BLAKE2b-derived digest indexes a
    word in SAS_WORDLIST.
    """
    if len(shared_key) < 16:
        raise ValueError(
            f"sharedKey too short for SAS derivation "
            f"(got {len(shared_key)} bytes, need >= 16)")
    if not (0 <= word_count <= 32):
        raise ValueError(
            f"wordCount out of range (got {word_count}; allowed 0..32)")
    if word_count == 0:
        return ""
    digest = hashlib.blake2b(shared_key, digest_size=word_count,
                             key=SPAKE2_LABEL_SAS).digest()
    return " ".join(SAS_WORDLIST[b] for b in digest)


# ─── Wormhole code (the SPAKE2 password) ────────────────────────────
#
# Format: 6 uppercase letters from a 24-letter alphabet (A-Z minus
# 'I' and 'O', which look like 1 and 0).  Search space ~191 M; combined
# with one-attempt-per-mint-cycle (user aborts on bad SAS), this is a
# one-shot brute force not an offline one.  Format mirrors Android's
# WormholeCode.kt — both sides MUST canonicalise to the same byte
# string or SPAKE2 fails with a SAS mismatch.

WORMHOLE_ALPHABET = "ABCDEFGHJKLMNPQRSTUVWXYZ"
WORMHOLE_DEFAULT_LENGTH = 6


def wormhole_generate(length=WORMHOLE_DEFAULT_LENGTH):
    """Uniformly-random code from WORMHOLE_ALPHABET."""
    if not (1 <= length <= 32):
        raise ValueError(
            f"length out of range (got {length}, allowed 1..32)")
    return "".join(
        secrets.choice(WORMHOLE_ALPHABET) for _ in range(length))


def wormhole_normalize(raw):
    """Canonicalise user input: uppercase, drop any char not in the
    alphabet.  Whitespace, dashes, digits, punctuation, the letters
    I and O — all stripped."""
    upper = raw.upper()
    return "".join(c for c in upper if c in WORMHOLE_ALPHABET)


def wormhole_is_valid(code, length=WORMHOLE_DEFAULT_LENGTH):
    """True iff [code] normalises to exactly [length] letters."""
    return len(wormhole_normalize(code)) == length


def wormhole_to_bytes(code):
    """SPAKE2-input bytes: UTF-8 of the canonical form."""
    return wormhole_normalize(code).encode("utf-8")


# ─── SAS wire format (envelopes, routing-id, MAC) ─────────────────────
#
# Mirrors signalling/SasWireFormat.kt.  Three message kinds, all
# wrapped in the OFFER envelope shape so they survive the public
# PeerJS broker's payload-shape filter.  Wire-format constants are
# protocol commitments — bumping any of them is wire-incompatible.

import base64 as _base64
import hmac as _hmac

SAS_STEP_1 = "sas_step_1"
SAS_STEP_2 = "sas_step_2"
SAS_CONFIRM = "sas_confirm"

SAS_LABEL_ROUTING_INIT = b"wgrtc/sas/routing-init-2026"
SAS_LABEL_ROUTING_RESP = b"wgrtc/sas/routing-resp-2026"
SAS_LABEL_CONFIRM_INIT = b"wgrtc/sas/confirm-init-2026"
SAS_LABEL_CONFIRM_RESP = b"wgrtc/sas/confirm-resp-2026"

SAS_PAKE_MSG_LEN = 32
SAS_CONFIRM_MAC_LEN = 16


def _b64url_nopad(b):
    return _base64.urlsafe_b64encode(b).rstrip(b"=").decode("ascii")


def sas_routing_id_initiator(code_bytes):
    """Broker subscription id for the initiator's inbox.  Derived from
    the wormhole-code bytes via keyed BLAKE2b under a role label, so
    initiator and responder subscribe to disjoint ids."""
    digest = hashlib.blake2b(code_bytes, digest_size=32,
                              key=SAS_LABEL_ROUTING_INIT).digest()
    return _b64url_nopad(digest)


def sas_routing_id_responder(code_bytes):
    digest = hashlib.blake2b(code_bytes, digest_size=32,
                              key=SAS_LABEL_ROUTING_RESP).digest()
    return _b64url_nopad(digest)


def _build_sas_envelope(dst_routing_id, kind, metadata_extras):
    """Common OFFER-wrapped envelope shape, fed by per-kind metadata
    additions in `metadata_extras` (a dict)."""
    conn_id = "dc_" + secrets.token_hex(6)
    md = {"v": PROTOCOL_VERSION, "kind": kind}
    md.update(metadata_extras)
    return {
        "type": "OFFER",
        "dst": dst_routing_id,
        "payload": {
            "sdp": {"sdp": build_peerjs_sdp(), "type": "offer"},
            "type": "data",
            "connectionId": conn_id,
            "label": conn_id,
            "reliable": False,
            "serialization": "binary",
            "metadata": md,
        },
    }


def build_sas_step1_envelope(dst_routing_id, pake_msg):
    if len(pake_msg) != SAS_PAKE_MSG_LEN:
        raise ValueError(
            f"pake_msg must be {SAS_PAKE_MSG_LEN} bytes "
            f"(got {len(pake_msg)})")
    return _build_sas_envelope(
        dst_routing_id, SAS_STEP_1,
        {"pake_msg": _base64.b64encode(pake_msg).decode("ascii")})


def build_sas_step2_envelope(dst_routing_id, pake_msg):
    if len(pake_msg) != SAS_PAKE_MSG_LEN:
        raise ValueError(
            f"pake_msg must be {SAS_PAKE_MSG_LEN} bytes "
            f"(got {len(pake_msg)})")
    return _build_sas_envelope(
        dst_routing_id, SAS_STEP_2,
        {"pake_msg": _base64.b64encode(pake_msg).decode("ascii")})


def build_sas_confirm_envelope(dst_routing_id, confirm_mac,
                                encrypted_info=None):
    if len(confirm_mac) != SAS_CONFIRM_MAC_LEN:
        raise ValueError(
            f"confirm_mac must be {SAS_CONFIRM_MAC_LEN} bytes "
            f"(got {len(confirm_mac)})")
    extras = {"mac": _base64.b64encode(confirm_mac).decode("ascii")}
    if encrypted_info is not None:
        extras["info"] = _base64.b64encode(encrypted_info).decode("ascii")
    return _build_sas_envelope(dst_routing_id, SAS_CONFIRM, extras)


def _extract_sas_metadata(message, expected_kind):
    """Validate the envelope and return (src, metadata-dict) or None."""
    if not isinstance(message, dict):
        return None
    if message.get("type") != "OFFER":
        return None
    src = message.get("src")
    if not isinstance(src, str):
        return None
    pl = message.get("payload")
    if not isinstance(pl, dict):
        return None
    md = pl.get("metadata")
    if not isinstance(md, dict):
        return None
    # Daemon serializes `v` as int; Android does too.  Accept either
    # string or int (some brokers stringify numbers in transit).
    v = md.get("v")
    if v != PROTOCOL_VERSION and v != str(PROTOCOL_VERSION):
        return None
    if md.get("kind") != expected_kind:
        return None
    return src, md


def _decode_b64_field(md, field, expected_len=None):
    val = md.get(field)
    if not isinstance(val, str):
        return None
    try:
        out = _base64.b64decode(val, validate=True)
    except Exception:
        return None
    if expected_len is not None and len(out) != expected_len:
        return None
    return out


def extract_sas_step1(message):
    """Return (src, pake_msg) for a valid SAS_STEP_1, or None."""
    meta = _extract_sas_metadata(message, SAS_STEP_1)
    if meta is None:
        return None
    src, md = meta
    pake = _decode_b64_field(md, "pake_msg", SAS_PAKE_MSG_LEN)
    if pake is None:
        return None
    return src, pake


def extract_sas_step2(message):
    meta = _extract_sas_metadata(message, SAS_STEP_2)
    if meta is None:
        return None
    src, md = meta
    pake = _decode_b64_field(md, "pake_msg", SAS_PAKE_MSG_LEN)
    if pake is None:
        return None
    return src, pake


def extract_sas_confirm(message):
    """Return (src, mac, encrypted_info_or_None) for a valid SAS_CONFIRM."""
    meta = _extract_sas_metadata(message, SAS_CONFIRM)
    if meta is None:
        return None
    src, md = meta
    mac = _decode_b64_field(md, "mac", SAS_CONFIRM_MAC_LEN)
    if mac is None:
        return None
    info = None
    if "info" in md:
        info = _decode_b64_field(md, "info")
        if info is None:
            return None
    return src, mac, info


def build_sas_confirm_mac(role, sas_key):
    """16-byte MAC = first 16 bytes of BLAKE2b-32(role_label, key=sas_key).

    This intentionally mirrors Android's sequence (compute 32-byte
    digest, truncate to 16) byte-for-byte — BLAKE2b output is NOT
    a prefix of larger output, so the truncate-from-32 step is wire-
    format-significant.
    """
    if len(sas_key) < 16:
        raise ValueError(
            f"sasKey too short (got {len(sas_key)}, need >= 16)")
    if role == "initiator":
        label = SAS_LABEL_CONFIRM_INIT
    elif role == "responder":
        label = SAS_LABEL_CONFIRM_RESP
    else:
        raise ValueError(f"role must be 'initiator' or 'responder' "
                         f"(got {role!r})")
    full = hashlib.blake2b(label, digest_size=32,
                           key=sas_key[:32]).digest()
    return full[:SAS_CONFIRM_MAC_LEN]


def verify_sas_confirm_mac(peer_role, sas_key, received_mac):
    """Constant-time compare via hmac.compare_digest."""
    if not isinstance(received_mac, (bytes, bytearray)) or \
            len(received_mac) != SAS_CONFIRM_MAC_LEN:
        return False
    expected = build_sas_confirm_mac(peer_role, sas_key)
    return _hmac.compare_digest(expected, bytes(received_mac))


# ─── SAS enrolment info (encrypted inside sas_confirm `info`) ─────────
#
# Mirrors SasEnrollInfo.kt.  After SAS-confirm both sides hold the same
# SPAKE2 key K; we use K[:32] as a secretbox key to wrap a JSON blob
# carrying tunnel-config bytes:
#
#  - JoinerEnrollInfo (joiner → host): joiner's WG pubkey + optional
#    device label, so the host can add them as a peer.
#  - HostEnrollInfo (host → joiner): host's WG pubkey, endpoint,
#    joiner's pre-allocated address, AllowedIPs, optional broker WSS
#    + DNS + MTU + keepalive + host name.
#
# Both carry `v` (protocol version) and `ts` (UTC seconds) for replay
# resistance, matching the existing ENROLL plaintext convention.
# Decoder rejects malformed JSON, wrong version, stale timestamp,
# wg_pubkey not exactly 32 bytes after base64-decode.  All failures
# return None silently — error shapes shouldn't be observable.

def _is_valid_wg_pubkey_b64(s):
    if not isinstance(s, str):
        return False
    try:
        return len(base64.b64decode(s, validate=True)) == 32
    except Exception:
        return False


def _secretbox_encrypt_json(payload, sas_key32):
    plain = json.dumps(payload, separators=(",", ":")).encode("utf-8")
    return SecretBox(sas_key32).encrypt(plain)


def _secretbox_decrypt_json(blob, sas_key32):
    try:
        plain = SecretBox(sas_key32).decrypt(bytes(blob))
        return json.loads(plain.decode("utf-8"))
    except Exception:
        return None


def encode_joiner_enroll_info(
        sas_key, wg_pubkey_b64, device_name=None, timestamp=None):
    """Build the encrypted joiner→host blob.

    `sas_key` must be ≥ 32 bytes; we use the first 32.
    """
    if len(sas_key) < 32:
        raise ValueError("sas_key must be ≥ 32 bytes")
    payload = {
        "v": PROTOCOL_VERSION,
        "ts": int(timestamp if timestamp is not None else time.time()),
        "wg_pubkey": wg_pubkey_b64,
    }
    if device_name is not None:
        payload["device_name"] = device_name
    else:
        # Match Android's `encodeDefaults = true` — serialise the
        # null so both sides hash identical bytes on round-trip
        # property tests.  Decoder treats absent and null
        # identically.
        payload["device_name"] = None
    return bytes(_secretbox_encrypt_json(payload, bytes(sas_key[:32])))


def decode_joiner_enroll_info(blob, sas_key, now=None,
                               freshness_window=PROTOCOL_FRESHNESS_WINDOW):
    if len(sas_key) < 32:
        return None
    msg = _secretbox_decrypt_json(blob, bytes(sas_key[:32]))
    if not isinstance(msg, dict):
        return None
    if msg.get("v") != PROTOCOL_VERSION:
        return None
    ts = msg.get("ts")
    if not isinstance(ts, int):
        return None
    now = now if now is not None else time.time()
    if abs(now - ts) > freshness_window:
        return None
    if not _is_valid_wg_pubkey_b64(msg.get("wg_pubkey")):
        return None
    return msg


def encode_host_enroll_info(
        sas_key, wg_pubkey_b64, wg_endpoint, assigned_address,
        allowed_ips, broker_wss=None, broker_key=None, salt_b64=None,
        dns=None, mtu=None, keepalive=None, host_name=None,
        timestamp=None):
    if len(sas_key) < 32:
        raise ValueError("sas_key must be ≥ 32 bytes")
    payload = {
        "v": PROTOCOL_VERSION,
        "ts": int(timestamp if timestamp is not None else time.time()),
        "wg_pubkey": wg_pubkey_b64,
        "wg_endpoint": wg_endpoint,
        "assigned_address": assigned_address,
        "allowed_ips": allowed_ips,
        "broker_wss": broker_wss,
        "broker_key": broker_key,
        "salt": salt_b64,
        "dns": dns,
        "mtu": mtu,
        "keepalive": keepalive,
        "host_name": host_name,
    }
    return bytes(_secretbox_encrypt_json(payload, bytes(sas_key[:32])))


def decode_host_enroll_info(blob, sas_key, now=None,
                             freshness_window=PROTOCOL_FRESHNESS_WINDOW):
    if len(sas_key) < 32:
        return None
    msg = _secretbox_decrypt_json(blob, bytes(sas_key[:32]))
    if not isinstance(msg, dict):
        return None
    if msg.get("v") != PROTOCOL_VERSION:
        return None
    ts = msg.get("ts")
    if not isinstance(ts, int):
        return None
    now = now if now is not None else time.time()
    if abs(now - ts) > freshness_window:
        return None
    if not _is_valid_wg_pubkey_b64(msg.get("wg_pubkey")):
        return None
    return msg


# ─── Wormhole flow controller ──────────────────────────────────────────
#
# Orchestrates SPAKE2 + SAS + enrollment over a transport object.  The
# transport contract is narrow:
#   await transport.send(envelope_dict)
#   envelope = await transport.recv()    # awaitable; returns next inbound
#   await transport.close()
#
# Production uses PeerJSClient under the hood (or a thin adapter that
# turns its callback API into a queue); tests substitute an in-memory
# queue pair.  Keeping the transport behind an interface lets the
# protocol logic be exercised without touching the network.

class SasAborted(Exception):
    """The local user pressed "no" on the SAS comparison.  Distinct
    from WormholeFailed so the caller can show a "you aborted"
    message instead of a generic failure."""


class WormholeFailed(Exception):
    """Wormhole pairing failed for a non-user reason: malformed
    inbound envelope, MAC mismatch (different code), broker error,
    bad enroll-info payload.  Message gives the specific reason."""


class WormholeFlow:
    """One-side wormhole-pairing state machine.

    Args:
        role: "initiator" (joiner; sends sas_step_1) or
              "responder" (host; sends sas_step_2 in reply).
        code_bytes: UTF-8 of the canonical (uppercase, alphabet-only)
                    wormhole code.
        transport: object with async send(envelope), async recv()
                   returning envelope dict, async close().
    """

    def __init__(self, role, code_bytes, transport):
        if role not in ("initiator", "responder"):
            raise ValueError(
                f"role must be 'initiator' or 'responder' (got {role!r})")
        self._role = role
        self._code_bytes = bytes(code_bytes)
        self._transport = transport
        if role == "initiator":
            self._our_id = sas_routing_id_initiator(self._code_bytes)
            self._peer_id = sas_routing_id_responder(self._code_bytes)
        else:
            self._our_id = sas_routing_id_responder(self._code_bytes)
            self._peer_id = sas_routing_id_initiator(self._code_bytes)
        # SPAKE2 role mapping: initiator=alice, responder=bob.
        self._spake = Spake2(role=("alice" if role == "initiator" else "bob"),
                              password=self._code_bytes)

    @property
    def our_routing_id(self):
        return self._our_id

    @property
    def peer_routing_id(self):
        return self._peer_id

    async def _recv_kind(self, *extractors):
        """Wait for an inbound that matches at least one extractor.
        Each extractor takes the envelope and returns a parsed tuple
        or None.  Returns (extractor_index, parsed_value)."""
        while True:
            env = await self._transport.recv()
            for i, ex in enumerate(extractors):
                parsed = ex(env)
                if parsed is not None:
                    return i, parsed

    async def run_joiner(self, joiner_pubkey_b64, device_name=None,
                          confirm_sas=None):
        """Initiator (joiner) side.  Sends sas_step_1, awaits sas_step_2,
        derives + displays SAS, awaits user confirmation, sends
        sas_confirm with encrypted JoinerEnrollInfo, awaits responder's
        sas_confirm, decrypts HostEnrollInfo, returns (sas_phrase,
        host_info_dict).

        confirm_sas: callable taking the SAS phrase and returning True
                     iff the user accepted.  Raises SasAborted if False.
        """
        if confirm_sas is None:
            confirm_sas = lambda phrase: True
        # Step 1: send our PAKE message.
        my_msg = self._spake.start()
        await self._transport.send(
            build_sas_step1_envelope(self._peer_id, my_msg))
        # Step 2: await peer's PAKE message.
        _, (_src, peer_msg) = await self._recv_kind(extract_sas_step2)
        sas_key = self._spake.finish(peer_msg)
        # User confirmation.
        sas_phrase = derive_sas(sas_key)
        if not confirm_sas(sas_phrase):
            raise SasAborted(sas_phrase)
        # Pack the joiner's info and send our confirm.
        info_blob = encode_joiner_enroll_info(
            sas_key=sas_key,
            wg_pubkey_b64=joiner_pubkey_b64,
            device_name=device_name,
        )
        my_mac = build_sas_confirm_mac("initiator", sas_key)
        await self._transport.send(build_sas_confirm_envelope(
            self._peer_id, my_mac, encrypted_info=info_blob))
        # Receive peer's confirm + encrypted HostEnrollInfo.
        _, (_src2, peer_mac, peer_info) = await self._recv_kind(
            extract_sas_confirm)
        if not verify_sas_confirm_mac("responder", sas_key, peer_mac):
            raise WormholeFailed(
                "peer sas_confirm MAC did not verify — wrong code "
                "or a relay-MITM that completed PAKE on each side")
        if peer_info is None:
            raise WormholeFailed(
                "peer's sas_confirm did not include enroll-info; "
                "responder may be older than the encrypted-info "
                "extension")
        host_info = decode_host_enroll_info(peer_info, sas_key=sas_key)
        if host_info is None:
            raise WormholeFailed(
                "peer's enroll-info blob did not decrypt / validate")
        return sas_phrase, host_info

    async def run_host(self, host_info, confirm_sas=None):
        """Responder (host) side.  Awaits sas_step_1, sends sas_step_2,
        derives SAS, awaits user confirmation, awaits joiner's
        sas_confirm with JoinerEnrollInfo, sends our sas_confirm with
        HostEnrollInfo, returns (sas_phrase, joiner_info_dict).

        host_info: dict with keys matching encode_host_enroll_info's
                   keyword args.
        confirm_sas: as in run_joiner.
        """
        if confirm_sas is None:
            confirm_sas = lambda phrase: True
        # Step 1: await peer's PAKE message.
        _, (_src, peer_msg) = await self._recv_kind(extract_sas_step1)
        # Step 2: send ours, derive key.
        my_msg = self._spake.start()
        await self._transport.send(
            build_sas_step2_envelope(self._peer_id, my_msg))
        sas_key = self._spake.finish(peer_msg)
        sas_phrase = derive_sas(sas_key)
        if not confirm_sas(sas_phrase):
            raise SasAborted(sas_phrase)
        # Receive peer's confirm + encrypted JoinerEnrollInfo.
        _, (_src2, peer_mac, peer_info) = await self._recv_kind(
            extract_sas_confirm)
        if not verify_sas_confirm_mac("initiator", sas_key, peer_mac):
            raise WormholeFailed(
                "peer sas_confirm MAC did not verify — wrong code "
                "or a relay-MITM that completed PAKE on each side")
        if peer_info is None:
            raise WormholeFailed(
                "peer's sas_confirm did not include enroll-info")
        joiner_info = decode_joiner_enroll_info(peer_info, sas_key=sas_key)
        if joiner_info is None:
            raise WormholeFailed(
                "peer's enroll-info blob did not decrypt / validate")
        # Send our confirm with encrypted HostEnrollInfo back.
        host_blob = encode_host_enroll_info(sas_key=sas_key, **host_info)
        my_mac = build_sas_confirm_mac("responder", sas_key)
        await self._transport.send(build_sas_confirm_envelope(
            self._peer_id, my_mac, encrypted_info=host_blob))
        return sas_phrase, joiner_info


# ─── STUN XOR-MAPPED-ADDRESS parser ────────────────────────────────────
# Pure function — no I/O, no sockets, testable with synthetic vectors.
# Handles both family=0x01 (IPv4) and family=0x02 (IPv6) per RFC 5389
# §15.2.  v6 addresses are XORed with magic_cookie ‖ transaction_id.
# Returns (ext_ip_str, ext_port) on a valid response, or None otherwise.
# Used by `cmd_check_nat`; the live daemon loop still has its own
# inline v4-only parser in `stun_query` (raw-inject hole-punching is
# v4-only so it never needs v6 here).

def _parse_stun_xor_mapped(data, txid):
    if len(data) < 20:
        return None
    msg_type, msg_len, magic, resp_txid = struct.unpack(
        "!HHL12s", data[:20])
    if msg_type != 0x0101:
        return None
    if magic != STUN_MAGIC_COOKIE:
        return None
    if resp_txid != txid:
        return None
    end = 20 + msg_len
    if len(data) < end:
        return None
    offset = 20
    while offset + 4 <= end:
        atype, alen = struct.unpack("!HH", data[offset:offset + 4])
        offset += 4
        if atype == 0x0020 and alen >= 8 and offset + alen <= end:
            family = data[offset + 1]
            xport = struct.unpack("!H", data[offset + 2:offset + 4])[0]
            ext_port = xport ^ (STUN_MAGIC_COOKIE >> 16)
            if family == 0x01:
                xip = struct.unpack(
                    "!L", data[offset + 4:offset + 8])[0]
                ext_ip = socket.inet_ntoa(
                    struct.pack("!L", xip ^ STUN_MAGIC_COOKIE))
                return ext_ip, ext_port
            if family == 0x02 and alen >= 20:
                raw = data[offset + 4:offset + 20]
                mask = struct.pack("!L", STUN_MAGIC_COOKIE) + txid
                ip_bytes = bytes(a ^ b for a, b in zip(raw, mask))
                ext_ip = socket.inet_ntop(socket.AF_INET6, ip_bytes)
                return ext_ip, ext_port
        offset += alen + ((4 - (alen % 4)) % 4)
    return None


# STUN_MAGIC_COOKIE is referenced above; the actual value is defined
# further down with the other wire-format constants.  The parser's
# lookup happens at call time, so the forward reference is fine.


# ─── NAT-type classifier (used by --check-nat + tests/01_stun_nat.py) ────

class NatVerdict:
    """Structured verdict from classify_nat_result.

    Fields:
        kind: one of "no_data", "no_nat_or_cone_port_preserving",
              "cone_not_port_preserving", "symmetric".
        port_preserving: True if every observed src_port mapped to the
                         same number externally; False if any didn't;
                         None when no data observed.
        cone: True if every src_port mapped to the SAME ext port across
              servers; False if at least one src_port showed differing
              ext ports across destinations; None when no data or only
              one server probed.
        external_ips: sorted list of unique external IPs reported.
        summary: short human-readable verdict, suitable for a CLI
                 one-liner or a UI banner.
        wgrtc_viable: True if direct wgrtc hole-punching is expected
                      to work on this NAT.
    """
    __slots__ = ("kind", "port_preserving", "cone", "external_ips",
                 "summary", "wgrtc_viable")

    def __init__(self, kind, port_preserving, cone, external_ips,
                 summary, wgrtc_viable):
        self.kind = kind
        self.port_preserving = port_preserving
        self.cone = cone
        self.external_ips = external_ips
        self.summary = summary
        self.wgrtc_viable = wgrtc_viable

    def __repr__(self):
        return (f"NatVerdict(kind={self.kind!r}, "
                f"port_preserving={self.port_preserving}, "
                f"cone={self.cone}, external_ips={self.external_ips}, "
                f"wgrtc_viable={self.wgrtc_viable})")


def classify_nat_result(probes):
    """Classify NAT behaviour from a list of STUN probe results.

    Args:
        probes: iterable of (server_label, src_port, ext_ip, ext_port)
                tuples — each tuple is one successful STUN binding
                response.  Failed probes should be excluded by the
                caller.

    Returns:
        a [NatVerdict] describing what was observed and whether the
        daemon's hole-punch is expected to work.
    """
    probes = list(probes)
    if not probes:
        return NatVerdict(
            kind="no_data", port_preserving=None, cone=None,
            external_ips=[],
            summary="No successful STUN probes — cannot classify NAT. "
                    "Check outbound UDP, then retry.",
            wgrtc_viable=False)

    external_ips = sorted({ext_ip for (_s, _p, ext_ip, _e) in probes})

    # Group ext_ports observed per src_port.
    by_src = {}
    for server, src_port, _ext_ip, ext_port in probes:
        by_src.setdefault(src_port, []).append((server, ext_port))

    # Port-preservation: every observed src_port mapped to the same
    # external port number.  If ANY src maps to a different number on
    # ANY server → not preserving.
    preserving = True
    for src_port, observations in by_src.items():
        for _server, ext_port in observations:
            if ext_port != src_port:
                preserving = False
                break
        if not preserving:
            break

    # Cone vs symmetric: for each src, count distinct ext ports across
    # servers.  If any src shows ≥ 2 distinct ext ports → symmetric.
    # If every src that was probed against ≥ 2 servers shows exactly
    # one ext port → cone.  If every src was only probed once we don't
    # have enough data to declare cone-ness.
    cone_known = False
    cone = True
    for src_port, observations in by_src.items():
        distinct_ports = {p for _s, p in observations}
        if len(observations) >= 2:
            cone_known = True
            if len(distinct_ports) > 1:
                cone = False
                break
    if not cone_known:
        cone = None

    if cone is False:
        return NatVerdict(
            kind="symmetric", port_preserving=preserving, cone=False,
            external_ips=external_ips,
            summary="Symmetric NAT detected: external port varies per "
                    "destination, so wgrtc's hole-punch can't predict the "
                    "right port.  Needs a relay or different NAT.",
            wgrtc_viable=False)

    if cone is True and preserving:
        return NatVerdict(
            kind="no_nat_or_cone_port_preserving",
            port_preserving=True, cone=True, external_ips=external_ips,
            summary="Port-preserving — direct hole-punch works.  "
                    "(Whether NAT is actually present is determined "
                    "separately by comparing local vs external address.)",
            wgrtc_viable=True)

    if cone is True and not preserving:
        return NatVerdict(
            kind="cone_not_port_preserving",
            port_preserving=False, cone=True, external_ips=external_ips,
            summary="Cone NAT but NOT port-preserving: external port "
                    "differs from your WireGuard listen port.  wgrtc will "
                    "publish the wrong port; enable NAT-PMP/PCP, set up a "
                    "manual port forward, or use the daemon on a host "
                    "with a public IP.",
            wgrtc_viable=False)

    # cone is None → only single-server data per src; honest about it.
    return NatVerdict(
        kind="cone_not_port_preserving" if not preserving
             else "no_nat_or_cone_port_preserving",
        port_preserving=preserving, cone=None, external_ips=external_ips,
        summary="Only one STUN server responded per source port — "
                "port-preservation determined but cone-vs-symmetric "
                "is undetermined.  Re-run with more STUN servers reachable.",
        wgrtc_viable=preserving)

DEFAULT_PEERJS_SERVER = "wss://0.peerjs.com/peerjs"
DEFAULT_PEERJS_KEY = "peerjs"

STUN_MAGIC_COOKIE = 0x2112A442


# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------


class Mode(enum.Enum):
    ACTIVE = "active"
    PASSIVE = "passive"
    DNS_ROAM = "dns-roam"
    IGNORE = "ignore"


@dataclasses.dataclass
class PeerConfig:
    public_key: str
    mode: Mode
    label: str  # filename stem, for logs
    dns_host: Optional[str] = None  # only meaningful for DNS_ROAM


@dataclasses.dataclass
class GlobalConfig:
    salt: bytes
    peerjs_server: str
    peerjs_key: str
    stun_servers: list
    public_ip: Optional[str] = None  # IPv4 override; bypasses STUN if set
    stun_strict: bool = False  # if true, reject private/non-global STUN responses
    enrollment_enabled: bool = False
    provision_script: Optional[str] = None
    state_dir: Path = Path("/var/lib/wireguardrtc")
    max_pending_tokens: int = 32
    # When the daemon successfully enrolls a peer, write a peers.d-style
    # drop-in to <state_dir>/auto-enrolled.d/ so the daemon pushes
    # signalling OFFERs to it (Mode=active) without requiring the admin
    # to hand-author a peers.d/<label>.conf.  An explicit drop-in in
    # /etc/wireguardrtc/peers.d/ always wins over the auto-enrolled
    # entry.  See [Enrollment] AutoActive in wireguardrtc(5).
    auto_active_enrollment: bool = True
    # Candidate-negotiation v2 knobs (Step B).  Used by the multi-
    # candidate enumeration in Step C to override interface-level
    # defaults: AdvertiseInterfaces explicitly opts in interfaces that
    # would otherwise be soft-skipped (e.g., wg-mesh0 in a corp
    # overlay deployment); SuppressInterfaces drops interfaces that
    # would otherwise be enumerated (e.g., docker0 on a build host).

    # rules".
    advertise_interfaces: list = dataclasses.field(default_factory=list)
    suppress_interfaces: list = dataclasses.field(default_factory=list)


def load_global_config(path: Path) -> GlobalConfig:
    cp = configparser.ConfigParser()
    cp.optionxform = str  # preserve case for base64 values
    if not cp.read(path):
        sys.stderr.write(f"[FATAL] config file not found: {path}\n")
        sys.exit(2)

    salt_str = cp.get("Global", "Salt", fallback="").strip()
    if not salt_str or salt_str == "CHANGE_ME_TO_A_SECURE_RANDOM_STRING":
        sys.stderr.write(
            f"[FATAL] {path}: [Global] Salt must be set to a unique random value.\n"
            "Generate one with: head -c 32 /dev/urandom | base64\n"
        )
        sys.exit(2)
    salt = salt_str.encode("utf-8")

    peerjs_server = cp.get("Global", "PeerJsServer", fallback=DEFAULT_PEERJS_SERVER).strip()
    peerjs_key = cp.get("Global", "PeerJsKey", fallback=DEFAULT_PEERJS_KEY).strip()

    public_ip_str = cp.get("Global", "PublicIp", fallback="").strip()
    public_ip = None
    if public_ip_str:
        try:
            addr = ipaddress.ip_address(public_ip_str)
        except ValueError:
            sys.stderr.write(
                f"[FATAL] {path}: [Global] PublicIp = {public_ip_str!r} "
                "is not a valid IP address.\n"
            )
            sys.exit(2)
        if not isinstance(addr, ipaddress.IPv4Address):
            sys.stderr.write(
                f"[FATAL] {path}: [Global] PublicIp must be IPv4. "
                "IPv6 endpoint publication is not yet implemented; "
                "see wg-holepunch-guide.md §8 (Limitations).\n"
            )
            sys.exit(2)
        if (addr.is_loopback or addr.is_multicast or addr.is_link_local
                or addr.is_unspecified or addr.is_reserved):
            sys.stderr.write(
                f"[FATAL] {path}: [Global] PublicIp = {public_ip_str} "
                "is not routable on the public internet.\n"
            )
            sys.exit(2)
        public_ip = str(addr)

    stun_raw = cp.get("Stun", "Servers", fallback=", ".join(DEFAULT_STUN_SERVERS))
    stun = [s.strip() for s in stun_raw.split(",") if s.strip()]

    # When `Strict = yes`, get_public_ipv4() rejects STUN responses
    # that report a non-globally-routable address (private RFC 1918,
    # CGN, loopback, link-local, multicast, unspecified, reserved).
    # Catches a hijacked or misconfigured STUN server feeding us an
    # internal IP that we'd otherwise advertise as the host's
    # publicly-reachable endpoint.  Default off because LAN-only
    # deployments legitimately need to advertise private addresses.
    stun_strict = cp.getboolean("Stun", "Strict", fallback=False)

    enrollment_enabled = cp.getboolean(
        "Enrollment", "Enabled", fallback=False)
    provision_script = cp.get(
        "Enrollment", "ProvisionScript", fallback="").strip() or None
    state_dir_str = cp.get(
        "Enrollment", "StateDir", fallback="/var/lib/wireguardrtc").strip()
    try:
        max_pending = cp.getint("Enrollment", "MaxPendingTokens", fallback=32)
    except ValueError:
        sys.stderr.write(
            f"[FATAL] {path}: [Enrollment] MaxPendingTokens must be an integer.\n")
        sys.exit(2)
    if max_pending < 1 or max_pending > 1000:
        sys.stderr.write(
            f"[FATAL] {path}: [Enrollment] MaxPendingTokens out of range "
            f"(got {max_pending}, allowed 1..1000).\n")
        sys.exit(2)
    if enrollment_enabled and not provision_script:
        sys.stderr.write(
            f"[FATAL] {path}: [Enrollment] Enabled requires "
            f"ProvisionScript to be set.\n")
        sys.exit(2)
    auto_active = cp.getboolean(
        "Enrollment", "AutoActive", fallback=True)

    advertise_raw = cp.get("Global", "AdvertiseInterfaces", fallback="")
    advertise_interfaces = [
        s.strip() for s in advertise_raw.split(",") if s.strip()
    ]
    suppress_raw = cp.get("Global", "SuppressInterfaces", fallback="")
    suppress_interfaces = [
        s.strip() for s in suppress_raw.split(",") if s.strip()
    ]

    return GlobalConfig(
        salt=salt,
        peerjs_server=peerjs_server,
        peerjs_key=peerjs_key,
        stun_servers=stun,
        public_ip=public_ip,
        stun_strict=stun_strict,
        enrollment_enabled=enrollment_enabled,
        provision_script=provision_script,
        state_dir=Path(state_dir_str),
        max_pending_tokens=max_pending,
        auto_active_enrollment=auto_active,
        advertise_interfaces=advertise_interfaces,
        suppress_interfaces=suppress_interfaces,
    )


AUTO_ACTIVE_SUBDIR = "auto-enrolled.d"


def auto_active_dir(state_dir: Path) -> Path:
    """Path to the runtime drop-in directory the daemon writes to
    when [Enrollment] AutoActive = yes.  Lives under state_dir
    (writable by the daemon), separate from the read-only admin
    dir at /etc/wireguardrtc/peers.d.  Per-pubkey filenames; the
    daemon scans this in addition to the admin dir."""
    return state_dir / AUTO_ACTIVE_SUBDIR


def write_auto_active_peer(state_dir: Path, pubkey_b64: str,
                           label: str, iface: str) -> None:
    """Write a peers.d-style drop-in for a freshly-enrolled peer with
    Mode=active.  Filename is the SHA-256 fingerprint of the pubkey
    (truncated, hex) so admin and auto-enrolled drop-ins can never
    collide on filename, and re-enrollment of the same pubkey
    overwrites idempotently."""
    aa_dir = auto_active_dir(state_dir)
    aa_dir.mkdir(parents=True, exist_ok=True)
    os.chmod(aa_dir, 0o700)
    fp = hashlib.sha256(pubkey_b64.encode("utf-8")).hexdigest()[:16]
    # Sanitise label for use as a filename hint — admin-supplied
    # via the URI's name field, but already validated by
    # cmd_enroll_token to be free of path-injecting characters.
    safe_label = "".join(c for c in label
                         if c.isalnum() or c in "-_.") or "peer"
    path = aa_dir / f"{safe_label}-{fp}.conf"
    body = (f"# auto-generated by wireguardrtc on enrollment.\n"
            f"# An admin-authored entry in /etc/wireguardrtc/peers.d/\n"
            f"# with the same PublicKey overrides this drop-in.\n"
            f"# Manage / delete via the same flow as peers.d: this\n"
            f"# file is a regular wireguardrtc peer drop-in.\n"
            f"[Peer]\n"
            f"PublicKey = {pubkey_b64}\n"
            f"Mode = active\n"
            f"# Iface = {iface}\n")
    tmp = path.with_suffix(".tmp")
    fd = os.open(str(tmp), os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    try:
        with os.fdopen(fd, "w") as f:
            f.write(body)
    except BaseException:
        try: os.unlink(tmp)
        except OSError: pass
        raise
    os.replace(tmp, path)


def load_peer_configs(directory: Path,
                      auto_active_directory: Optional[Path] = None) -> dict:
    """Load every drop-in. Returns {public_key: PeerConfig}.

    Two source directories:
      - `directory` — the admin-authored, read-only
        /etc/wireguardrtc/peers.d.  Authoritative.
      - `auto_active_directory` — the runtime drop-in dir under
        state_dir, populated by write_auto_active_peer when
        [Enrollment] AutoActive = yes.

    Admin entries win on pubkey collision so an explicit override
    never fires.  Pass None for auto_active_directory to skip the
    auto-loaded set entirely (CLI tools that don't care about
    runtime peers, e.g. --show-config).
    """
    out: dict = {}
    # Auto-active first; admin overrides next so admin wins on
    # collision.  Both dirs use the same drop-in format.
    for d in [auto_active_directory, directory]:
        if d is None or not d.is_dir:
            continue
        out = _merge_peer_dir(out, d, override=(d == directory))
    return out


def _merge_peer_dir(into: dict, directory: Path, override: bool) -> dict:
    for path in sorted(directory.glob("*.conf")):
        cp = configparser.ConfigParser()
        cp.optionxform = str
        if not cp.read(path):
            logging.warning("could not read %s", path)
            continue
        if "Peer" not in cp:
            logging.warning("%s: no [Peer] section, skipping", path)
            continue
        sec = cp["Peer"]
        pubkey = sec.get("PublicKey", "").strip()
        if not pubkey:
            logging.warning("%s: no PublicKey in [Peer], skipping", path)
            continue
        mode_str = sec.get("Mode", "passive").strip().lower()
        try:
            mode = Mode(mode_str)
        except ValueError:
            logging.warning("%s: unknown Mode=%r, defaulting to passive",
                            path, mode_str)
            mode = Mode.PASSIVE
        dns_host = sec.get("DnsHost", "").strip() or None
        if mode == Mode.DNS_ROAM and not dns_host:
            logging.warning("%s: dns-roam requires DnsHost, ignoring peer", path)
            continue
        if pubkey in into and not override:
            # Auto-active dir runs first (override=False).  If admin
            # later loads the same pubkey, that's the override path
            # below — no warning.
            logging.debug("%s: duplicate PublicKey already loaded from %s",
                          path, into[pubkey].label)
            continue
        if pubkey in into and override:
            # Admin override — silently replace the auto-active entry.
            pass
        into[pubkey] = PeerConfig(
            public_key=pubkey,
            mode=mode,
            label=path.stem,
            dns_host=dns_host,
        )
    return into


# ---------------------------------------------------------------------------
# Anti-spam logging
# ---------------------------------------------------------------------------


class StateLogger:
    """Emit a line only when the (scope, key) value changes."""
    def __init__(self):
        self._state = {}

    def event(self, scope, key, value, message, level=logging.INFO):
        cell = (scope, key)
        if self._state.get(cell) == value:
            return
        self._state[cell] = value
        logging.log(level, "[%s] %s", scope, message)


LOG = StateLogger()


# ---------------------------------------------------------------------------
# WireGuard kernel state (via `wg`)
# ---------------------------------------------------------------------------


def wg_show(*args) -> str:
    res = subprocess.run(
        ["wg", "show", *args],
        capture_output=True, text=True, timeout=5,
    )
    if res.returncode != 0:
        # caller decides what to do; don't spam
        return ""
    return res.stdout


def wg_set(*args) -> bool:
    res = subprocess.run(
        ["wg", "set", *args],
        capture_output=True, text=True, timeout=5,
    )
    if res.returncode != 0:
        logging.warning("wg set %s failed: %s",
                        " ".join(args), res.stderr.strip())
        return False
    return True


def list_interfaces() -> list:
    return wg_show("interfaces").split()


def get_iface_field(iface, field) -> str:
    return wg_show(iface, field).strip()


def get_iface_table(iface, field) -> dict:
    """For per-peer fields like endpoints/allowed-ips/latest-handshakes:
    returns {pubkey: rest_of_line_with_whitespace_separated_values}."""
    out = {}
    for line in wg_show(iface, field).splitlines():
        parts = line.split(None, 1)
        if len(parts) == 2:
            out[parts[0]] = parts[1]
        elif len(parts) == 1:
            out[parts[0]] = ""
    return out


# ---------------------------------------------------------------------------
# STUN client (async, validates txid)
# ---------------------------------------------------------------------------


async def stun_query(server, timeout=STUN_TIMEOUT) -> Optional[tuple]:
    """Returns (external_ip, external_port) on success, or None."""
    if ":" not in server:
        return None
    host, port_s = server.rsplit(":", 1)
    try:
        port = int(port_s)
    except ValueError:
        return None
    loop = asyncio.get_running_loop()
    try:
        infos = await loop.getaddrinfo(host, None, family=socket.AF_INET,
                                       type=socket.SOCK_DGRAM)
    except socket.gaierror:
        return None
    if not infos:
        return None
    server_ip = infos[0][4][0]

    txid = os.urandom(12)
    request = struct.pack("!HHL12s", 0x0001, 0, STUN_MAGIC_COOKIE, txid)

    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.setblocking(False)
    sock.bind(("0.0.0.0", 0))
    try:
        sock.sendto(request, (server_ip, port))
        deadline = loop.time() + timeout
        while loop.time() < deadline:
            remaining = deadline - loop.time()
            try:
                data = await asyncio.wait_for(loop.sock_recv(sock, 2048),
                                              timeout=remaining)
            except asyncio.TimeoutError:
                return None
            if len(data) < 20:
                continue
            msg_type, msg_len, magic, resp_txid = struct.unpack("!HHL12s",
                                                                data[:20])
            if (msg_type != 0x0101 or magic != STUN_MAGIC_COOKIE
                    or resp_txid != txid):
                continue
            offset = 20
            end = 20 + msg_len
            while offset + 4 <= end:
                atype, alen = struct.unpack("!HH", data[offset:offset + 4])
                offset += 4
                if atype == 0x0020 and alen >= 8:
                    family = data[offset + 1]
                    if family == 0x01:
                        xport = struct.unpack("!H",
                                              data[offset + 2:offset + 4])[0]
                        xip = struct.unpack("!L",
                                            data[offset + 4:offset + 8])[0]
                        ext_port = xport ^ (STUN_MAGIC_COOKIE >> 16)
                        ext_ip = socket.inet_ntoa(
                            struct.pack("!L", xip ^ STUN_MAGIC_COOKIE))
                        return ext_ip, ext_port
                offset += alen + ((4 - (alen % 4)) % 4)
        return None
    finally:
        sock.close()


def _stun_response_passes_strict(server, ext_ip) -> bool:
    """Strict-mode filter: only globally-routable IPs accepted.  Logs
    rejection with the server name so users can debug a hijacked /
    misconfigured STUN server feeding internal addresses."""
    try:
        addr = ipaddress.ip_address(ext_ip)
    except ValueError:
        LOG.event("stun", "rejected", f"{server}:{ext_ip}",
                  f"STUN strict: {server} returned malformed "
                  f"address {ext_ip!r}; rejecting",
                  level=logging.WARNING)
        return False
    if not addr.is_global:
        LOG.event("stun", "rejected", f"{server}:{ext_ip}",
                  f"STUN strict: {server} returned "
                  f"non-routable {ext_ip}; rejecting",
                  level=logging.WARNING)
        return False
    return True


async def get_public_ipv4(stun_servers, state) -> Optional[str]:
    """Return the host's public IPv4 address.

    If the GlobalConfig has a `public_ip` override set, return it immediately
    and skip STUN entirely.  Otherwise query all STUN servers in PARALLEL
    and return the first valid response — the slowest server no longer
    blocks the rest, which matters when the configured list mixes a
    fast nearby server with an unreachable / slow one.

    With `[Stun] Strict = yes`, STUN responses whose XOR-MAPPED-ADDRESS
    is non-globally-routable (RFC 1918 private, CGN, loopback, etc.)
    are skipped — guards against a hijacked or misconfigured STUN
    server feeding us an internal IP.  Default is off because LAN-only
    deployments legitimately advertise private addresses.

    Step H of the candidate-negotiation v2 design (memory:
    project_protocol_signal_wake_candidates.md).  Single-result API
    preserved for back-compat; multi-homed daemons use
    `get_public_ipv4_all` to discover every reflexive address at once.
    """
    if getattr(state, "public_ip", None):
        LOG.event("stun", "public_ip", state.public_ip,
                  f"public IPv4 = {state.public_ip} (configured override; "
                  f"STUN skipped)")
        return state.public_ip
    if not stun_servers:
        LOG.event("stun", "public_ip", None, "STUN: no servers configured")
        return None
    strict = getattr(state, "stun_strict", False)
    # Fire all servers in parallel and process responses in completion
    # order.  First valid response wins; remaining tasks are cancelled
    # so their sockets close promptly.  Each task is the
    # _stun_query_with_server wrapper so the awaited result carries
    # the server name — `asyncio.as_completed` returns opaque future
    # wrappers, not the original tasks, so we can't recover the
    # server name from the future itself.
    tasks = [
        asyncio.create_task(_stun_query_with_server(server))
        for server in stun_servers
    ]
    try:
        for done in asyncio.as_completed(tasks):
            server, result = await done
            if result is None:
                continue
            ext_ip, _ = result
            if strict and not _stun_response_passes_strict(server, ext_ip):
                continue
            LOG.event("stun", "public_ip", ext_ip,
                      f"public IPv4 mapped as {ext_ip} via {server}")
            return ext_ip
    finally:
        for t in tasks:
            if not t.done():
                t.cancel()
        # Drain cancellations — keeps asyncio's "Task was destroyed
        # but it is pending" warnings out of the log.
        await asyncio.gather(*tasks, return_exceptions=True)
    LOG.event("stun", "public_ip", None, "STUN: no server responded")
    return None


async def get_public_ipv4_all(stun_servers, state) -> list:
    """Parallel multi-result variant of `get_public_ipv4`.

    Returns a deduped list of all valid public IPv4 addresses observed,
    in completion order.  A single-homed daemon with three configured
    servers gets back a one-element list (all three see the same NAT
    mapping).  A multi-homed daemon — different upstream paths to
    different STUN servers — gets back the full set of distinct
    reflexive addresses.

    Used by the Step C sender-side multi-candidate enumeration: every
    distinct STUN-discovered IP becomes a `kind=stun` candidate.

    PublicIp override returns `[public_ip]` (single-element list) and
    skips STUN entirely — same semantics as `get_public_ipv4`.

    Returns `[]` if no server responded with a valid (under strict
    mode) IP.  Caller distinguishes `[]` from `None`: empty list
    means "STUN ran, found nothing usable"; never returns None.
    """
    if getattr(state, "public_ip", None):
        LOG.event("stun", "public_ip", state.public_ip,
                  f"public IPv4 = {state.public_ip} (configured override; "
                  f"STUN skipped)")
        return [state.public_ip]
    if not stun_servers:
        return []
    strict = getattr(state, "stun_strict", False)
    tasks = [
        asyncio.create_task(_stun_query_with_server(server))
        for server in stun_servers
    ]
    # CR-10: return_exceptions=True so one misbehaving STUN server
    # (network-down on its iface, hostname resolution exception, etc.)
    # doesn't abort the whole gather and force an empty candidate list.
    # Surviving servers still produce results.
    raw = await asyncio.gather(*tasks, return_exceptions=True)
    seen: set = set()
    out: list = []
    for entry in raw:
        if isinstance(entry, BaseException):
            LOG.event("stun", "task-error", repr(entry),
                      f"STUN task raised {type(entry).__name__}: {entry}; "
                      f"continuing with surviving responses",
                      level=logging.WARNING)
            continue
        server, result = entry
        if result is None:
            continue
        ext_ip, _ = result
        if strict and not _stun_response_passes_strict(server, ext_ip):
            continue
        if ext_ip in seen:
            continue
        seen.add(ext_ip)
        out.append(ext_ip)
        LOG.event("stun", "public_ip", ext_ip,
                  f"public IPv4 mapped as {ext_ip} via {server}")
    if not out:
        LOG.event("stun", "public_ip", None,
                  "STUN: no valid response from any configured server")
    return out


async def _stun_query_with_server(server):
    """Wrapper that pairs the server name with the result so the caller
    can attribute responses for logging / strict-mode reporting."""
    return server, await stun_query(server)


# ---------------------------------------------------------------------------
# Step C: multi-candidate enumeration
# ---------------------------------------------------------------------------
#
#  —
# replaces the single-candidate emission in `signal_peer` with a ranked
# list built from PublicIp + parallel STUN + local interfaces.  The
# `kind` tag is mostly diagnostic; `rank` (lower = better) drives the
# receiver's pick order.

# Tunnel-name patterns: default-skip unless explicitly allowlisted via
# [Global] AdvertiseInterfaces.  See §"Sender rules / SOFT-SKIP".
_TUNNEL_IFACE_RE = re.compile(
    r"^("
    r"tun\d+|"        r"tap\d+|"
    r"ppp\d+|"
    r"tailscale\d+|"
    r"zt[0-9a-f]+|"   # ZeroTier: zt<10-hex-id>
    r"gre\d+|gretap\d+|"
    r"sit\d+|"
    r"ipip\d+|"
    r"ip6tnl\d+|ip6gre\d+|"
    r"erspan\d+|"
    r"ifb\d+|dummy\d+|"
    r"ip_vti\d+|ip6_vti\d+"
    r")$"
)

_BRIDGE_IFACE_RE = re.compile(r"^(br[\w-]*|vmbr\d+|virbr\d+)$")


def _is_tunnel_iface_name(name: str) -> bool:
    return bool(_TUNNEL_IFACE_RE.match(name)) or name.startswith("wg")


def _is_bridge_iface_name(name: str) -> bool:
    return bool(_BRIDGE_IFACE_RE.match(name))


# RFC 7335 v4-only-host stub; never advertise (Pixel CLAT puts
# `192.0.0.4/32` on the cellular CLAT iface — see
# `9_interface_names.md`).
_RFC7335_CLAT = ipaddress.ip_network("192.0.0.0/29")


def _is_candidate_eligible_v4(ip_str: str) -> bool:
    """True if `ip_str` is a v4 IP usable as a candidate.  Drops
    loopback, link-local (169.254/16), multicast, unspecified
    (0.0.0.0), and the RFC 7335 CLAT stub (192.0.0.0/29)."""
    try:
        addr = ipaddress.ip_address(ip_str)
    except (ValueError, TypeError):
        return False
    if not isinstance(addr, ipaddress.IPv4Address):
        return False
    if addr.is_loopback or addr.is_link_local: return False
    if addr.is_multicast or addr.is_unspecified: return False
    if addr.is_reserved: return False
    if addr in _RFC7335_CLAT: return False
    return True


def _is_private_v4(ip_str: str) -> bool:
    """RFC 1918 + CGNAT (100.64.0.0/10) → True; globally-routable → False.
    We treat both classes the same for ranking purposes (rank 50,
    kind=lan).  CGNAT is intentionally NOT dropped — many CGNAT
    deployments hole-punch fine and the daemon's own STUN-discovered
    address may itself be CGNAT."""
    try:
        addr = ipaddress.ip_address(ip_str)
    except (ValueError, TypeError):
        return False
    return not addr.is_global


_IPROUTE2_MISSING_WARNED = False


def _warn_iproute2_missing_once():
    """One-shot WARN at startup-or-first-attempt when `ip` is missing.
    Hardened containers without iproute2 can otherwise silently lose
    the iface enumeration leg of candidate discovery (CR-8) — the
    daemon then advertises only STUN-derived candidates with no log
    explaining why local addresses are missing."""
    global _IPROUTE2_MISSING_WARNED
    if _IPROUTE2_MISSING_WARNED:
        return
    _IPROUTE2_MISSING_WARNED = True
    LOG.event("candidates", "iproute2", "missing",
              "iproute2 (`ip` command) not found in PATH; local "
              "interface enumeration disabled — candidate list will "
              "include STUN/PublicIp only.  Install iproute2 (`apt "
              "install iproute2`) or accept reduced functionality.",
              level=logging.WARNING)


def _enumerate_iface_addrs_v4_ioctl() -> list:
    """Pure-stdlib fallback for iface enumeration: walk
    `socket.if_nameindex` and SIOCGIFADDR each name.  Works without
    iproute2 (or any subprocess) — needed inside the daemon's strict
    systemd sandbox where `ip` sometimes returns empty output for
    reasons we can't otherwise pin down.

    Misses secondary IPv4 aliases (SIOCGIFADDR returns the primary
    only); the practical loss is small since multi-address ifaces are
    rare on hosts that need hole-punching.  Returns
    [(iface, ip_str), ...]; empty on any failure."""
    SIOCGIFADDR = 0x8915
    addrs: list = []
    try:
        ifaces = socket.if_nameindex()
    except OSError:
        return []
    sock = None
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        for _idx, name in ifaces:
            try:
                ifr = struct.pack("256s", name.encode("utf-8")[:15])
                res = fcntl.ioctl(sock.fileno, SIOCGIFADDR, ifr)
            except OSError:
                # Many ifaces (notably IPv6-only and DOWN ones) refuse
                # SIOCGIFADDR with EADDRNOTAVAIL; that's expected.
                continue
            try:
                ip = socket.inet_ntoa(res[20:24])
            except OSError:
                continue
            addrs.append((name, ip))
    except OSError:
        pass
    finally:
        if sock is not None:
            try:
                sock.close()
            except OSError:
                pass
    return addrs


async def _enumerate_iface_addrs_v4() -> list:
    """Default provider: shell out to `ip -4 -o addr show` and parse,
    falling through to a SIOCGIFADDR-based stdlib enumeration when
    `ip` is missing OR returns no usable lines.  Returns
    [(iface_name, ip_str), ...].

    The dual approach is deliberate: prefer `ip` because it sees
    secondary aliases the SIOCGIFADDR ioctl doesn't, but inside hard
    systemd sandboxes the subprocess sometimes succeeds with empty
    output (no FileNotFoundError, no exception — just an empty stdout)
    and we want the daemon to keep producing LAN candidates regardless.
    Failure of both paths → empty list."""
    out_str = ""
    rc = -1
    err_str = ""
    try:
        proc = await asyncio.create_subprocess_exec(
            "ip", "-4", "-o", "addr", "show",
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE,
        )
        out_b, err_b = await proc.communicate()
        rc = proc.returncode
        out_str = out_b.decode("utf-8", errors="replace")
        err_str = err_b.decode("utf-8", errors="replace").strip()
    except (FileNotFoundError, OSError):
        _warn_iproute2_missing_once()
    addrs: list = []
    for line in out_str.splitlines():
        # Format: "<idx>: <iface> inet <ip>/<prefix> ... scope <scope> ..."
        toks = line.split()
        try:
            i_inet = toks.index("inet")
            iface = toks[1]
            ip_with_prefix = toks[i_inet + 1]
            ip_str = ip_with_prefix.split("/")[0]
        except (ValueError, IndexError):
            continue
        addrs.append((iface, ip_str))
    if addrs:
        return addrs
    # `ip` produced nothing parseable.  Fall through to the ioctl
    # enumeration so a sandboxed daemon still gets LAN candidates.
    fallback = _enumerate_iface_addrs_v4_ioctl
    LOG.event("candidates", "iface-enum-fallback",
              f"rc={rc},nfb={len(fallback)}",
              f"`ip -4 -o addr show` returned no usable lines "
              f"(rc={rc}, stderr={err_str!r}); falling back to "
              f"SIOCGIFADDR ioctl, found {len(fallback)} addrs")
    return fallback


def _default_route_iface_v4_proc() -> Optional[str]:
    """Pure-stdlib /proc-based default-route lookup.  Used as fallback
    when iproute2 is missing.  /proc/net/route is universal on Linux
    (containers, busybox, embedded) so this works where `ip` doesn't.

    Format: column 0 is iface, column 1 is destination (hex
    little-endian), column 7 is mask (hex le).  Default route =
    destination 00000000 + mask 00000000."""
    try:
        with open("/proc/net/route", "r") as f:
            for line in f:
                cols = line.split()
                if len(cols) < 8:
                    continue
                if cols[0] == "Iface":
                    continue
                if cols[1] == "00000000" and cols[7] == "00000000":
                    return cols[0]
    except (OSError, IOError):
        return None
    return None


async def _default_route_iface_v4() -> Optional[str]:
    """Default provider: which iface holds the v4 default route?
    Returns the iface name, or None if no default route is present.
    Tries `ip` first, falls back to /proc/net/route on missing
    iproute2 OR on empty `ip` output (the same sandbox-quirk path
    that affects `_enumerate_iface_addrs_v4`)."""
    try:
        proc = await asyncio.create_subprocess_exec(
            "ip", "-4", "route", "show", "default",
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.DEVNULL,
        )
        out, _ = await proc.communicate()
    except (FileNotFoundError, OSError):
        # Fall back to /proc/net/route — works in any Linux container,
        # iproute2 not required.
        _warn_iproute2_missing_once()
        return _default_route_iface_v4_proc()
    for line in out.decode("utf-8", errors="replace").splitlines():
        toks = line.split()
        try:
            return toks[toks.index("dev") + 1]
        except (ValueError, IndexError):
            continue
    # `ip` exited cleanly but produced nothing — fall through.
    return _default_route_iface_v4_proc


def _classify_iface_addr(
    iface: str, ip_str: str,
    default_iface: Optional[str],
    advertise_set: set,
    suppress_set: set,
    own_wg_ifaces: set,
) -> Optional[tuple]:
    """Decide (rank, kind) for a (iface, ip) pair, or None to drop.
    Pure function — easy to test in isolation."""
    if iface in own_wg_ifaces:
        return None
    if iface in suppress_set:
        return None
    if not _is_candidate_eligible_v4(ip_str):
        return None
    if _is_tunnel_iface_name(iface) and iface not in advertise_set:
        return None

    # AdvertiseInterfaces allowlist — rank 60, kind=mesh.  The user
    # explicitly opted this in; respect that even for "weird" addrs.
    if iface in advertise_set:
        return (60, "mesh")

    # Private (RFC1918 + CGNAT) — rank 50, kind=lan.
    if _is_private_v4(ip_str):
        if _is_bridge_iface_name(iface):
            return (40, "lan")
        return (50, "lan")

    # Globally-routable on a bridge — rank 40, kind=lan (bridges are
    # typically LAN-side; if it's somehow public it still works).
    if _is_bridge_iface_name(iface):
        return (40, "lan")

    # Globally-routable on a physical iface — depends on default route.
    if default_iface is not None and iface == default_iface:
        return (20, "stun")
    return (30, "stun")


CANDIDATE_LIST_CAP = 10


async def discover_local_candidates(
    global_config, listen_port: int,
    own_wg_ifaces=None,
    iface_addrs_provider=None,
    default_iface_provider=None,
    stun_provider=None,
) -> list:
    """Build the ranked candidate list this daemon advertises in
    OFFERs.  Returns a list of `{"ip", "port", "kind"}` dicts in
    rank order (lowest rank first).  Capped at
    `CANDIDATE_LIST_CAP`.  Deduplicated by IP — a STUN response
    that matches an admin-configured `PublicIp` only appears once.

    Step C of the candidate-negotiation v2 design.

    The provider arguments are dependency-injection seams for tests
    (see `tests/27_candidate_enumerate.py`).  In production they
    default to `_enumerate_iface_addrs_v4` /
    `_default_route_iface_v4` / `get_public_ipv4_all`.
    """
    iface_addrs_provider = iface_addrs_provider or _enumerate_iface_addrs_v4
    default_iface_provider = default_iface_provider or _default_route_iface_v4
    stun_provider = stun_provider or get_public_ipv4_all
    own_wg = set(own_wg_ifaces or [])
    advertise_set = set(global_config.advertise_interfaces)
    suppress_set = set(global_config.suppress_interfaces)

    # Run STUN + iface enumeration + default route in parallel.  STUN
    # is the slow leg (~2 s for unreachable servers); the others are
    # local subprocess calls.  CR-10: return_exceptions=True so a
    # raise from one provider degrades to an empty result for that
    # leg rather than killing the whole enumeration.
    raw = await asyncio.gather(
        stun_provider(global_config.stun_servers, global_config),
        iface_addrs_provider(),
        default_iface_provider(),
        return_exceptions=True,
    )
    def _unwrap(entry, default, label):
        if isinstance(entry, BaseException):
            LOG.event("candidates", f"{label}-error", repr(entry),
                      f"{label} provider raised {type(entry).__name__}: "
                      f"{entry}; degrading to empty",
                      level=logging.WARNING)
            return default
        return entry
    stun_ips      = _unwrap(raw[0], [],   "stun")
    iface_addrs   = _unwrap(raw[1], [],   "iface-enum")
    default_iface = _unwrap(raw[2], None, "default-route")

    candidates: list = []
    seen_ips: set = set()

    def _add(ip, kind, rank):
        if ip in seen_ips:
            return
        seen_ips.add(ip)
        candidates.append({
            "ip": ip, "port": int(listen_port),
            "kind": kind, "_rank": rank,
        })

    # Rank 0: PublicIp override.
    if getattr(global_config, "public_ip", None):
        if _is_candidate_eligible_v4(global_config.public_ip):
            _add(global_config.public_ip, "stun", 0)

    # Rank 10: STUN reflexive (deduped vs PublicIp).
    for ip in (stun_ips or []):
        if _is_candidate_eligible_v4(ip):
            _add(ip, "stun", 10)

    # Rank 20-60: local interface addresses.
    # Per-iface accept/reject diagnostics at DEBUG so they're available
    # when chasing a "why is candidate X missing" issue (the smoking
    # gun for the iproute2-SIGSYS finding earlier in the project) but
    # don't pollute INFO output during normal operation.
    if logging.getLogger().isEnabledFor(logging.DEBUG):
        raw_str = ",".join(f"{i}:{a}" for i, a in iface_addrs) or "<empty>"
        LOG.event("candidates", "iface-enum-raw", raw_str,
                  f"iface_addrs from provider: {raw_str}; "
                  f"default_iface={default_iface}; "
                  f"advertise={sorted(advertise_set)}; "
                  f"suppress={sorted(suppress_set)}; "
                  f"own_wg={sorted(own_wg)}",
                  level=logging.DEBUG)
    decisions: list = []
    for iface, ip_str in iface_addrs:
        if ip_str in seen_ips:
            decisions.append(f"{iface}:{ip_str}=dup")
            continue
        cls = _classify_iface_addr(
            iface, ip_str, default_iface,
            advertise_set, suppress_set, own_wg,
        )
        if cls is None:
            # Re-derive the reason for diagnostics (cheap).
            if iface in own_wg:
                why = "own-wg"
            elif iface in suppress_set:
                why = "suppress"
            elif not _is_candidate_eligible_v4(ip_str):
                why = "ineligible-ip"
            elif _is_tunnel_iface_name(iface) and iface not in advertise_set:
                why = "tunnel-not-advertised"
            else:
                why = "unknown"
            decisions.append(f"{iface}:{ip_str}=drop({why})")
            continue
        rank, kind = cls
        decisions.append(f"{iface}:{ip_str}=keep(rank={rank},kind={kind})")
        _add(ip_str, kind, rank)
    if logging.getLogger().isEnabledFor(logging.DEBUG):
        decisions_str = ",".join(decisions) or "<empty>"
        LOG.event("candidates", "iface-enum-decisions", decisions_str,
                  f"iface decisions: {decisions_str}",
                  level=logging.DEBUG)

    # Sort by rank, then by original insertion order (stable sort).
    candidates.sort(key=lambda c: c["_rank"])
    # Cap and strip _rank.
    candidates = candidates[:CANDIDATE_LIST_CAP]
    for c in candidates:
        c.pop("_rank", None)
    return candidates


# ---------------------------------------------------------------------------
# Crypto: domain-separated SecretBox
# ---------------------------------------------------------------------------


def derive_secretbox_key(my_priv_b64: str, peer_pub_b64: str) -> bytes:
    """X25519 ECDH then BLAKE2b-keyed → 32-byte SecretBox key.

    Domain separation: the resulting key is bound to PROTOCOL_LABEL; it can
    never collide with WireGuard's own session keys or any other use of the
    same Curve25519 keypair.
    """
    my_priv = base64.b64decode(my_priv_b64)
    peer_pub = base64.b64decode(peer_pub_b64)
    shared = crypto_scalarmult(my_priv, peer_pub)
    # generichash(in, key=label, digest_size=32) is a keyed BLAKE2b.
    return _nacl_blake2b(shared, digest_size=32, key=PROTOCOL_LABEL[:32], encoder=_NaclRawEncoder)


def encrypt_envelope(key: bytes,
                     candidates: list,
                     ts: Optional[int] = None) -> str:
    """Encrypt a signalling-OFFER blob carrying a list of candidate
    endpoints in preference order.  Sender empties the list for a
    `signal_wake` (it doesn't claim an endpoint).  See
    project_protocol_signal_wake_candidates memo for rationale."""
    payload = {
        "v": PROTOCOL_VERSION,
        "ts": int(ts if ts is not None else time.time()),
        "candidates": list(candidates or []),
    }
    box = SecretBox(key)
    ct = box.encrypt(json.dumps(payload).encode("utf-8"))
    return base64.b64encode(ct).decode("ascii")


def decrypt_envelope(key: bytes, blob_b64: str) -> Optional[dict]:
    """Decrypt + validate (version, freshness, structural shape).
    Returns the plaintext dict on success or None on any failure
    (silent — the receiver shouldn't leak per-step distinctions to
    a probing attacker)."""
    if not isinstance(blob_b64, str) or len(blob_b64) > MAX_SIGBOX_CIPHERTEXT_B64:
        return None
    try:
        ct = base64.b64decode(blob_b64)
        plain = SecretBox(key).decrypt(ct)
        if len(plain) > MAX_SIGBOX_PLAINTEXT:
            return None
        msg = json.loads(plain.decode("utf-8"))
    except Exception:
        return None
    if msg.get("v") != PROTOCOL_VERSION:
        return None
    ts = msg.get("ts")
    if not isinstance(ts, int):
        return None
    if abs(time.time() - ts) > PROTOCOL_FRESHNESS_WINDOW:
        return None
    # Normalise: every plaintext now carries `candidates` (list).
    # Reject anything else.
    cands = msg.get("candidates")
    if not isinstance(cands, list):
        return None
    return msg


def first_valid_candidate(msg: dict) -> Optional[tuple]:
    """Return the first `(ip, port)` candidate from a decrypted
    OFFER plaintext that passes [is_valid_public_endpoint], or None.
    Validation is per-candidate; bad entries are skipped silently
    (they're either typos or maliciously-injected garbage and the
    receiver mustn't dump kernel WG state into them).
    """
    for c in msg.get("candidates", []) or []:
        if not isinstance(c, dict):
            continue
        ip = c.get("ip")
        port = c.get("port")
        if not isinstance(ip, str) or not isinstance(port, int):
            continue
        if not is_valid_public_endpoint(ip, port):
            continue
        return ip, port
    return None


def is_valid_public_endpoint(ip: str, port: int) -> bool:
    """Reject loopback, link-local, multicast, unspecified, reserved, and
    weirdly-low ports. A malicious peer could otherwise redirect WG to dump
    handshakes onto a metadata service or local link."""
    try:
        addr = ipaddress.ip_address(ip)
    except ValueError:
        return False
    if (addr.is_loopback or addr.is_multicast or addr.is_link_local
            or addr.is_unspecified or addr.is_reserved):
        return False
    if isinstance(addr, ipaddress.IPv4Address) and addr.is_private:
        # Private addresses can be legitimate on LAN deployments. Allow for now;
        # an admin who wants strict global-only behavior can add a filter.
        pass
    if not (1 <= port <= 65535):
        return False
    return True


# ---------------------------------------------------------------------------
# Auto-enrollment crypto helpers
# ---------------------------------------------------------------------------


def derive_enroll_key(local_priv_b64: str, peer_pub_b64: str,
                      token: bytes) -> bytes:
    """Compute final_key = BLAKE2b(BLAKE2b(ECDH, key=LABEL_ENROLL), key=token).

    Domain separation:
      - LABEL_ENROLL guards against any cross-protocol key reuse
        (signalling uses LABEL_PROTOCOL = b"wg-peerjs/v1/sigbox").
      - Re-keying with `token` binds this key to a specific single-use
        enrollment voucher.  An attacker who lacks `token` cannot derive
        final_key even if they hold one of the long-term private keys.
    """
    local_priv = base64.b64decode(local_priv_b64)
    peer_pub = base64.b64decode(peer_pub_b64)
    shared = crypto_scalarmult(local_priv, peer_pub)
    enroll_key = _nacl_blake2b(shared, digest_size=32,
                               key=LABEL_ENROLL[:32],
                               encoder=_NaclRawEncoder)
    final_key = _nacl_blake2b(enroll_key, digest_size=32,
                              key=token,
                              encoder=_NaclRawEncoder)
    return final_key


def decrypt_enroll_blob(key: bytes, blob_b64: str) -> Optional[dict]:
    """Decrypt and JSON-parse an enrollment ciphertext.  Returns None on
    auth-tag failure, malformed JSON, or unknown protocol version.

    Enforces a ciphertext-length cap before decoding and a plaintext
    cap after decryption — defense-in-depth against memory exhaustion
    by an attacker who somehow ended up with a valid token (so they
    can produce real auth-tagged ciphertexts) and feeds us oversized
    JSON to parse."""
    if not isinstance(blob_b64, str) or len(blob_b64) > MAX_ENROLL_CIPHERTEXT_B64:
        return None
    try:
        ct = base64.b64decode(blob_b64)
        plain = SecretBox(key).decrypt(ct)
        if len(plain) > MAX_ENROLL_PLAINTEXT:
            return None
        msg = json.loads(plain.decode("utf-8"))
    except Exception:
        return None
    if msg.get("v") != PROTOCOL_VERSION:
        return None
    return msg


def encrypt_enroll_blob(key: bytes, plaintext: dict) -> str:
    box = SecretBox(key)
    ct = box.encrypt(json.dumps(plaintext).encode("utf-8"))
    return base64.b64encode(ct).decode("ascii")


def build_enroll_envelope(dst_routing_id: str, kind: str,
                          server_pub_b64: str,
                          ciphertext_b64: str) -> dict:
    """Wrap an enrollment response (ENROLL_OK / ENROLL_ERR) in the same
    WebRTC OFFER envelope used by signalling, so the public PeerJS broker
    forwards it.  Discriminator is `metadata.kind`."""
    conn_id = "dc_" + secrets.token_hex(6)
    return {
        "type": "OFFER",
        "dst": dst_routing_id,
        "payload": {
            "sdp": {"sdp": build_peerjs_sdp(), "type": "offer"},
            "type": "data",
            "connectionId": conn_id,
            "label": conn_id,
            "reliable": False,
            "serialization": "binary",
            "metadata": {
                "v": PROTOCOL_VERSION,
                "kind": kind,
                "server_pub": server_pub_b64,
                "blob": ciphertext_b64,
            },
        },
    }


PROVISION_PERMITS_DIR = "/var/lib/wireguardrtc-provision-broker/permits"


def remove_provision_permit(token: bytes) -> None:
    """Best-effort: remove a previously-written provisioning permit.

    Used when a token is superseded (re-mint of the same name) so a
    stale URL the admin might already have shipped cannot sneak through
    the broker.  Honors the same env-var override
    (``WIREGUARDRTC_PROVISION_PERMITS_DIR``) that
    write_provision_permit uses.
    """
    permits_dir = os.environ.get(
        "WIREGUARDRTC_PROVISION_PERMITS_DIR", PROVISION_PERMITS_DIR)
    safe_token = (
        base64.urlsafe_b64encode(token).rstrip(b"=").decode("ascii"))
    try:
        os.unlink(os.path.join(permits_dir, safe_token))
    except FileNotFoundError:
        pass
    except OSError:
        # Permission / IO error — broker permit may now be stale,
        # but we deliberately don't fail the new mint over it.
        pass


def write_provision_permit(token: bytes, name_hint: str,
                           expires_at: int) -> None:
    """Drop a permit file the broker uses to gate provisioning requests.

    Permits live in a directory the daemon process cannot write to (mode
    0700, root-owned; only writable from the admin-invoked
    `wireguardrtc --enroll-token` mint flow which runs under sudo).
    The broker checks for a matching permit before invoking the
    Provisioner, so a daemon RCE outside the mint→consumption window
    cannot synthesize a permit and therefore cannot provision peers.

    Best-effort.  On systems without the broker installed, the permits
    directory will not exist; in that case we skip silently and the
    legacy direct-ProvisionScript path remains usable.
    """
    permits_dir = os.environ.get(
        "WIREGUARDRTC_PROVISION_PERMITS_DIR", PROVISION_PERMITS_DIR)
    if not os.path.isdir(permits_dir):
        # Broker not deployed (or override pointing elsewhere) — direct
        # ProvisionScript users don't need permits.
        return
    safe_token = (
        base64.urlsafe_b64encode(token).rstrip(b"=").decode("ascii"))
    permit_path = os.path.join(permits_dir, safe_token)
    permit = {
        "name_hint": name_hint,
        "expires_at": int(expires_at),
        "created_at": int(time.time()),
    }
    try:
        fd = os.open(permit_path, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        with os.fdopen(fd, "w") as f:
            json.dump(permit, f)
    except PermissionError as e:
        # Most likely cause: the user ran `wireguardrtc --enroll-token`
        # without sudo, so the mint succeeded into pending-tokens.json
        # (which the wireguardrtc group can write) but the permits dir
        # is root-only.  The mint isn't actually broken — the daemon
        # will accept the ENROLL — but the broker will refuse to
        # provision.  Warn loudly on stderr so the admin notices and
        # rerun under sudo, but don't fail the mint.
        sys.stderr.write(
            f"[WARN] could not write provisioning permit "
            f"({e.__class__.__name__}: {e}).  The token is valid but "
            f"the privileged provisioning broker will refuse to "
            f"provision unless the permit exists.  Did you forget "
            f"`sudo`?\n")
    except Exception:
        # Any other write failure: clean up any partial file and
        # re-raise so the mint command fails clearly.
        try:
            os.unlink(permit_path)
        except FileNotFoundError:
            pass
        raise


def run_provision_script(script_path: str, iface: str, name: str,
                         client_pub_b64: str,
                         token: bytes = b"",
                         timeout: float = 15.0) -> tuple:
    """Invoke the user-supplied provisioning hook.

    Contract:
        script_path IFACE NAME PUBKEY_BASE64
        env: WIREGUARDRTC_PROVISION_TOKEN = url-safe-b64(token, no padding)
    The script must add the peer to the running WireGuard interface (via
    `wg set`, writing to a config file, calling other tooling, etc.) and
    exit with status 0 on success.  The daemon then reads back the
    allocation via `wg show`.

    The optional `token` parameter is the 32-byte token we just claimed
    for this enrollment, encoded into the env var so that the script
    (typically wireguardrtc-provision-client) can forward it to the
    privileged broker for permit lookup.  Backward-compatible with
    older provision scripts: if the env var is absent and the script
    doesn't read it, no harm done.

    Inputs are validated first to refuse anything that would expand
    unsafely as shell metacharacters or as path components.  The script
    is invoked with subprocess.run (no shell=True), arguments passed
    individually — the validation here is defensive.

    Returns (ok: bool, error_message: str).
    """
    # Defensive input validation — even though we never use shell=True,
    # we want to refuse anything weird up front so a bad provision script
    # can't be tricked into doing something unintended.
    if not script_path:
        return False, "ProvisionScript not configured"
    script = Path(script_path)
    if not script.is_file() or not os.access(script_path, os.X_OK):
        return False, f"ProvisionScript {script_path} is not an executable file"
    if not iface or any(c in iface for c in "\x00/"):
        return False, f"refusing bad iface name: {iface!r}"
    # WireGuard public keys are 32 raw bytes encoded as 44 chars of
    # standard base64 (alphabet A-Za-z0-9+/=).  base64.b64decode with
    # validate=True does the right thing — any other character or
    # length anomaly raises.
    try:
        raw = base64.b64decode(client_pub_b64, validate=True)
    except Exception:
        return False, f"client_pub is not valid base64: {client_pub_b64!r}"
    if len(raw) != 32:
        return False, (f"client_pub decodes to {len(raw)} bytes, "
                       f"expected 32: {client_pub_b64!r}")
    # Name hint is admin-supplied via the URI's name field; treat it as
    # untrusted (it could be tampered with).  Refuse control chars and
    # things that look like path injections.
    if (not name or len(name) > 64
            or any(c in name for c in "\x00\n\r\t/\\$`")):
        return False, f"refusing bad name hint: {name!r}"

    env = dict(os.environ)
    if token:
        # URL-safe base64, no padding — same encoding the URI uses, and
        # the form filenames in the broker's permits dir take.
        env["WIREGUARDRTC_PROVISION_TOKEN"] = (
            base64.urlsafe_b64encode(token).rstrip(b"=").decode("ascii"))
    try:
        res = subprocess.run(
            [str(script), iface, name, client_pub_b64],
            capture_output=True, text=True, timeout=timeout, env=env)
    except subprocess.TimeoutExpired:
        return False, f"ProvisionScript timed out after {timeout}s"
    except OSError as e:
        return False, f"failed to invoke ProvisionScript: {e}"
    if res.returncode != 0:
        # Truncate stderr defensively for log output.
        err = (res.stderr or res.stdout or "").strip()
        if len(err) > 200:
            err = err[:200] + "..."
        return False, (f"ProvisionScript exited {res.returncode}"
                       + (f": {err}" if err else ""))
    return True, ""


