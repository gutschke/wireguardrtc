# Wire-format constants for the enrollment protocol.
LABEL_ENROLL = b"wg-peerjs/v1/enroll"  # domain separator for enrollment keys
ENROLL_FRESHNESS_WINDOW = 90.0          # ±seconds for ENROLL ts validation
ENROLL_REPLAY_TTL = 300.0               # cached response retention (5 min)
TOKEN_BYTES = 32                        # 256-bit enrollment tokens
TOKEN_DEFAULT_EXPIRY = 600.0            # 10 minutes if not specified


class PendingTokensStore:
    """Persistent state for the auto-enrollment protocol.

    Holds two lists in a single JSON file (default
    /var/lib/wireguardrtc/pending-tokens.json, mode 0600):

      tokens[]              pending and used enrollment tokens
      recent_enrollments[]  cached ENROLL_OK responses for retry safety

    All mutating operations take an exclusive flock on the state file
    so concurrent racers (multiple ENROLL handlers, the
    --enroll-token CLI, etc.) serialize cleanly.  Atomic writes via
    write-temp + os.replace.
    """

    def __init__(self, state_dir: Path):
        self.state_dir = Path(state_dir)
        self.path = self.state_dir / "pending-tokens.json"

    # ------------ low-level IO ------------

    def _load_locked(self) -> dict:
        """Read the state file.  Returns the default schema if missing."""
        try:
            with open(self.path, "rb") as f:
                return json.loads(f.read().decode("utf-8") or "{}")
        except FileNotFoundError:
            return {"version": 1, "tokens": [], "recent_enrollments": []}
        except json.JSONDecodeError as e:
            raise RuntimeError(
                f"corrupt {self.path}: {e}; refusing to overwrite") from e

    def _chown_to_match_dir(self, target) -> None:
        """When running as root (CLI mints, package upgrades), make sure
        a freshly-created state file ends up with the same uid/gid as
        the state directory itself — otherwise the daemon (running as
        the unprivileged ``wireguardrtc`` user) can't open it.
        Best-effort; silently skipped when not root or on filesystems
        that don't support chown."""
        if os.geteuid != 0:
            return
        try:
            st = os.stat(self.state_dir)
        except OSError:
            return
        try:
            if isinstance(target, int):
                os.fchown(target, st.st_uid, st.st_gid)
            else:
                os.chown(str(target), st.st_uid, st.st_gid)
        except OSError:
            pass

    def _save_locked(self, state: dict) -> None:
        """Atomic write: temp + os.replace under the same dir."""
        self.state_dir.mkdir(parents=True, exist_ok=True)
        os.chmod(self.state_dir, 0o700)
        tmp = self.path.with_suffix(".tmp")
        # Open with O_NOFOLLOW + 0600 to refuse symlink attacks
        fd = os.open(str(tmp),
                     os.O_WRONLY | os.O_CREAT | os.O_TRUNC | os.O_NOFOLLOW,
                     0o600)
        try:
            self._chown_to_match_dir(fd)
            with os.fdopen(fd, "wb") as f:
                f.write(json.dumps(state, indent=2,
                                   sort_keys=True).encode("utf-8") + b"\n")
        except BaseException:
            # Best-effort cleanup before re-raising.
            try:
                os.unlink(tmp)
            except OSError:
                pass
            raise
        os.replace(tmp, self.path)

    def _open_locked(self):
        """Yield (fd, state).  Caller must save state via self._save_locked
        and then release the lock by closing fd.  Used as a CM via _txn
        """
        self.state_dir.mkdir(parents=True, exist_ok=True)
        os.chmod(self.state_dir, 0o700)
        # Lock file is the state file itself.  If it doesn't exist yet,
        # create it empty so flock has something to grab.
        if not self.path.exists():
            fd = os.open(str(self.path),
                         os.O_WRONLY | os.O_CREAT | os.O_NOFOLLOW, 0o600)
            self._chown_to_match_dir(fd)
            os.close(fd)
        # If a previous root-as-CLI mint left the file root-owned and the
        # daemon (unprivileged) is now opening it, repair ownership before
        # the O_RDWR open below would EACCES.  No-op when already correct.
        self._chown_to_match_dir(self.path)
        fd = os.open(str(self.path), os.O_RDWR | os.O_NOFOLLOW)
        fcntl.flock(fd, fcntl.LOCK_EX)
        return fd

    class _Txn:
        """Context manager that holds the file lock for read-modify-write."""

        def __init__(self, store: "PendingTokensStore"):
            self._store = store
            self._fd: Optional[int] = None
            self.state: Optional[dict] = None

        def __enter__(self):
            self._fd = self._store._open_locked()
            self.state = self._store._load_locked()
            return self

        def commit(self):
            assert self.state is not None
            self._store._save_locked(self.state)

        def __exit__(self, exc_type, exc, tb):
            if self._fd is not None:
                try:
                    fcntl.flock(self._fd, fcntl.LOCK_UN)
                finally:
                    os.close(self._fd)
            return False  # don't suppress

    def _txn(self):
        return PendingTokensStore._Txn(self)

    # ------------ public API ------------

    def mint(self, name_hint: str, expires_in: float = TOKEN_DEFAULT_EXPIRY,
             iface: Optional[str] = None,
             max_pending: int = 32) -> tuple:
        """Mint a fresh single-use enrollment token.

        Returns ``(token_bytes, superseded_meta)``: the raw token (caller
        serialises into the URI) and metadata for the previously-pending
        unexpired token with the same ``name_hint`` if one existed (None
        otherwise).  When superseded_meta is not None the previous token
        has been removed from the store; the caller should warn the admin
        that they have replaced an outstanding token (lost QR / refresh
        before expiry are the supported scenarios).

        Raises RuntimeError if the max-pending cap would be exceeded
        after purging expired entries and any same-name supersede.
        """
        token = secrets.token_bytes(TOKEN_BYTES)
        now = time.time()
        with self._txn() as txn:
            # Purge expired tokens and consumed-then-cached entries.
            txn.state.setdefault("tokens", [])
            txn.state.setdefault("recent_enrollments", [])
            txn.state["tokens"] = [
                t for t in txn.state["tokens"]
                if not t.get("used") and t.get("expires_at", 0) > now
            ]
            # Same-name supersede: at most one unexpired pending token per
            # name_hint at any time.  Re-minting the same name (lost QR,
            # refresh before expiry) replaces the previous token rather
            # than stacking another valid one alongside it.  See
            # docs/duplicate-label-policy notes / project memory.
            superseded_meta = None
            kept = []
            for t in txn.state["tokens"]:
                if t.get("name_hint") == name_hint and superseded_meta is None:
                    superseded_meta = t
                else:
                    kept.append(t)
            txn.state["tokens"] = kept
            active = len(txn.state["tokens"])
            if active >= max_pending:
                raise RuntimeError(
                    f"refusing to mint: {active} unconsumed tokens already "
                    f"pending (max {max_pending}).  Wait for them to be "
                    f"used or expire, or raise [Enrollment] MaxPendingTokens.")
            txn.state["tokens"].append({
                "token_b64":   base64.b64encode(token).decode(),
                "name_hint":   name_hint,
                "iface":       iface,
                "created_at":  int(now),
                "expires_at":  int(now + expires_in),
                "used":        False,
                "used_at":     None,
                "used_by":     None,
            })
            txn.commit()
        return token, superseded_meta

    def unmint(self, token: bytes) -> bool:
        """Roll back a [mint] that the caller couldn't follow up on
        (e.g., write_provision_permit raised after we already
        committed the token to disk).  Removes the token from the
        active-tokens list iff it's there and not yet consumed.
        Returns True if removed, False if not found / already used.
        CR-D1 of the candidate-negotiation v2 review."""
        token_b64 = base64.b64encode(token).decode()
        with self._txn() as txn:
            tokens = txn.state.setdefault("tokens", [])
            removed = False
            kept = []
            for t in tokens:
                if (t.get("token_b64") == token_b64 and not t.get("used")):
                    removed = True
                    continue
                kept.append(t)
            if removed:
                txn.state["tokens"] = kept
                txn.commit()
            return removed

    def try_claim(self, token: bytes,
                  client_pub_b64: str) -> Optional[dict]:
        """Atomically mark a token as consumed, returning its metadata
        dict on success or None if not found / expired / already used.

        The caller then runs ProvisionScript and, on success, calls
        cache_response() to persist the encrypted ENROLL_OK for retry
        safety.
        """
        token_b64 = base64.b64encode(token).decode()
        now = time.time()
        with self._txn() as txn:
            for entry in txn.state.get("tokens", []):
                if entry.get("token_b64") != token_b64:
                    continue
                if entry.get("used"):
                    return None
                if entry.get("expires_at", 0) <= now:
                    return None
                entry["used"] = True
                entry["used_at"] = int(now)
                entry["used_by"] = client_pub_b64
                txn.commit()
                return dict(entry)  # defensive copy
            return None

    def find_token(self, token: bytes) -> Optional[dict]:
        """Look up a token without claiming it.  Returns metadata dict
        for unused/unexpired tokens, dict with used=True for already-
        consumed ones, or None if unknown / expired-and-purged."""
        token_b64 = base64.b64encode(token).decode()
        now = time.time()
        with self._txn() as txn:
            for entry in txn.state.get("tokens", []):
                if entry.get("token_b64") != token_b64:
                    continue
                if not entry.get("used") and entry.get("expires_at", 0) <= now:
                    return None
                return dict(entry)
            return None

    def cache_response(self, client_pub_b64: str,
                       envelope: dict,
                       ttl: float = ENROLL_REPLAY_TTL) -> None:
        """Cache a built ENROLL_OK envelope keyed by the client's pubkey.
        Only the holder of the corresponding private key can decrypt it,
        so caching is safe.  Used to make legitimate retries (lost
        response over a flaky network) idempotent."""
        now = time.time()
        with self._txn() as txn:
            cache = txn.state.setdefault("recent_enrollments", [])
            # Remove any earlier entry for this client.
            cache[:] = [e for e in cache
                        if e.get("client_pub_b64") != client_pub_b64
                        and e.get("expires_at", 0) > now]
            cache.append({
                "client_pub_b64": client_pub_b64,
                "envelope":       envelope,
                "expires_at":     int(now + ttl),
            })
            txn.commit()

    def find_recent(self, client_pub_b64: str) -> Optional[dict]:
        """Return a previously cached envelope for this client_pub, or None."""
        now = time.time()
        with self._txn() as txn:
            for e in txn.state.get("recent_enrollments", []):
                if (e.get("client_pub_b64") == client_pub_b64
                        and e.get("expires_at", 0) > now):
                    return e["envelope"]
            return None

    def list_tokens(self) -> list:
        """Return a copy of all tokens for diagnostics (--show-config etc.)."""
        with self._txn() as txn:
            return [dict(t) for t in txn.state.get("tokens", [])]

    def purge_expired(self) -> int:
        """Drop expired tokens and stale cached responses.  Returns
        the number of removed entries (for logging)."""
        now = time.time()
        removed = 0
        with self._txn() as txn:
            tokens_before = len(txn.state.get("tokens", []))
            txn.state["tokens"] = [
                t for t in txn.state.get("tokens", [])
                if (not t.get("used") and t.get("expires_at", 0) > now)
                or (t.get("used") and t.get("used_at", 0) > now - 86400)
            ]
            cache_before = len(txn.state.get("recent_enrollments", []))
            txn.state["recent_enrollments"] = [
                e for e in txn.state.get("recent_enrollments", [])
                if e.get("expires_at", 0) > now
            ]
            removed = ((tokens_before - len(txn.state["tokens"]))
                       + (cache_before - len(txn.state["recent_enrollments"])))
            if removed > 0:
                txn.commit()
        return removed


