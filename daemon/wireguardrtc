# PeerJS client (single websocket, WebRTC-shaped wrapper)
# ---------------------------------------------------------------------------


def routing_id(pubkey_b64: str, salt: bytes) -> str:
    h = hashlib.sha256()
    h.update(pubkey_b64.encode("utf-8"))
    h.update(salt)
    return h.hexdigest()


def build_peerjs_sdp() -> str:
    """Generate the SDP body for a PeerJS datachannel OFFER. Fields are
    freshly randomised per-message as the standard PeerJS client does."""
    sid = secrets.randbits(63)
    ufrag = secrets.token_hex(2)
    pwd = secrets.token_hex(12)
    fp = ":".join(f"{b:02X}" for b in secrets.token_bytes(32))
    return (
        "v=0\r\n"
        f"o=- {sid} 2 IN IP4 127.0.0.1\r\n"
        "s=-\r\n"
        "t=0 0\r\n"
        "a=group:BUNDLE 0\r\n"
        "a=extmap-allow-mixed\r\n"
        "a=msid-semantic: WMS\r\n"
        "m=application 9 UDP/DTLS/SCTP webrtc-datachannel\r\n"
        "c=IN IP4 0.0.0.0\r\n"
        f"a=ice-ufrag:{ufrag}\r\n"
        f"a=ice-pwd:{pwd}\r\n"
        "a=ice-options:trickle\r\n"
        f"a=fingerprint:sha-256 {fp}\r\n"
        "a=setup:actpass\r\n"
        "a=mid:0\r\n"
        "a=sctp-port:5000\r\n"
        "a=max-message-size:262144\r\n"
    )


def build_offer_envelope(dst_routing_id: str, blob_b64: str) -> dict:
    conn_id = "dc_" + secrets.token_hex(6)
    return {
        "type": "OFFER",
        "dst": dst_routing_id,
        "payload": {
            "sdp": {"sdp": build_peerjs_sdp(), "type": "offer"},
            "type": "data",
            "connectionId": conn_id,
            "label": conn_id,
            "reliable": False,
            "serialization": "binary",
            "metadata": {"v": PROTOCOL_VERSION, "blob": blob_b64},
        },
    }


def extract_envelope(message: dict) -> Optional[tuple]:
    """Pull (src, metadata) out of a forwarded server message, or None.

    Both signalling OFFERs and enrollment messages ride inside the same
    WebRTC OFFER envelope — they're discriminated by the `kind` field
    inside `metadata`.  Absence of `kind` means a signalling OFFER.
    """
    if not isinstance(message, dict):
        return None
    if message.get("type") != "OFFER":
        return None
    src = message.get("src")
    payload = message.get("payload")
    if not isinstance(payload, dict):
        return None
    md = payload.get("metadata")
    if not isinstance(md, dict):
        return None
    if md.get("v") != PROTOCOL_VERSION:
        return None
    return src, md


class PeerJSClient:
    """Single long-lived websocket connection to the broker.

    Holds the daemon's routing-id slot, sends our outbound OFFERs, dispatches
    incoming OFFERs to a callback. Reconnects on disconnect with exponential
    backoff (capped at SIGNALING_BACKOFF). Sends HEARTBEAT every 5 s.
    """
    def __init__(self, server, key, our_routing_id, on_incoming, on_open=None):
        self.server = server
        self.key = key
        self.our_id = our_routing_id
        self.on_incoming = on_incoming
        self.on_open = on_open  # called with no args each time session opens
        self.ws = None
        self._send_lock = asyncio.Lock()
        self._stopped = asyncio.Event()
        self._connected = asyncio.Event()

    def _uri(self) -> str:
        sep = "&" if "?" in self.server else "?"
        token = secrets.token_hex(8)
        return (f"{self.server}{sep}key={self.key}&id={self.our_id}"
                f"&token={token}&version=1.5.2")

    async def stop(self):
        self._stopped.set()
        if self.ws is not None:
            try:
                await self.ws.close()
            except Exception:
                pass

    async def send(self, envelope: dict) -> bool:
        if self.ws is None or not self._connected.is_set():
            return False
        async with self._send_lock:
            try:
                await self.ws.send(json.dumps(envelope))
                return True
            except Exception as e:
                LOG.event("peerjs", "send", "fail",
                          f"send failed: {e!r}", level=logging.WARNING)
                return False

    async def run(self):
        backoff = 5.0
        while not self._stopped.is_set():
            session_start = None
            try:
                async with websockets.connect(self._uri()) as ws:
                    self.ws = ws
                    LOG.event("peerjs", "conn", "connecting",
                              f"connected to {self.server}")
                    # First server message should be OPEN.
                    raw = await asyncio.wait_for(ws.recv(), timeout=10.0)
                    msg = json.loads(raw)
                    if msg.get("type") != "OPEN":
                        LOG.event("peerjs", "conn", "no-open",
                                  f"unexpected first message: {msg}",
                                  level=logging.WARNING)
                        await asyncio.sleep(backoff)
                        backoff = min(backoff * 2, SIGNALING_BACKOFF)
                        continue
                    # CR-D9: only mark the session "started" once OPEN
                    # arrived.  Backoff resets at the END of the loop
                    # iff (now - session_start) >= STABLE_SESSION_S —
                    # mirrors the Android OfferListener fix.  Without
                    # this, a broker that quick-closes after sending
                    # OPEN keeps backoff pinned at 5s indefinitely,
                    # producing a tight reconnect storm.
                    session_start = time.monotonic()
                    self._connected.set()
                    LOG.event("peerjs", "conn", "open", "PeerJS session OPEN")
                    if self.on_open is not None:
                        asyncio.create_task(self.on_open())

                    hb_task = asyncio.create_task(self._heartbeat_loop())
                    try:
                        while not self._stopped.is_set():
                            raw = await ws.recv()
                            try:
                                msg = json.loads(raw)
                            except json.JSONDecodeError:
                                continue
                            extracted = extract_envelope(msg)
                            if extracted is not None:
                                src, metadata = extracted
                                try:
                                    await self.on_incoming(src, metadata)
                                except Exception as e:
                                    logging.exception(
                                        "on_incoming raised: %r", e)
                    finally:
                        hb_task.cancel()
                        try:
                            await hb_task
                        except (asyncio.CancelledError, Exception):
                            pass
            except websockets.exceptions.ConnectionClosed as e:
                LOG.event("peerjs", "conn", f"closed-{e.code}",
                          f"PeerJS connection closed (code={e.code})")
            except Exception as e:
                LOG.event("peerjs", "conn", f"err-{type(e).__name__}",
                          f"PeerJS error: {e!r}", level=logging.WARNING)
            finally:
                self.ws = None
                self._connected.clear()
            if self._stopped.is_set():
                return
            # CR-D9: reset backoff iff the session was alive long
            # enough to count as "stable".  A broker quick-close
            # leaves session_start either None (closed before OPEN)
            # or recent (< STABLE_SESSION_S ago) — both keep backoff
            # advancing exponentially, capped at SIGNALING_BACKOFF.
            if (session_start is not None and
                    time.monotonic() - session_start >= STABLE_SESSION_S):
                backoff = 5.0
            else:
                backoff = min(backoff * 2, SIGNALING_BACKOFF)
            await asyncio.sleep(backoff)
            backoff = min(backoff * 2, SIGNALING_BACKOFF)

    async def _heartbeat_loop(self):
        while not self._stopped.is_set():
            await asyncio.sleep(PEERJS_HEARTBEAT)
            if self.ws is None:
                return
            try:
                await self.ws.send(json.dumps({"type": "HEARTBEAT"}))
            except Exception:
                return


# ---------------------------------------------------------------------------
# Hole-punch raw-socket inject
# ---------------------------------------------------------------------------


def build_raw_udp_packet(src_port, dst_ip, dst_port, payload=b""):
    ip_hdr = struct.pack(
        "!BBHHHBBH4s4s",
        (4 << 4) | 5,                # version=4 IHL=5
        0,                            # DSCP/ECN
        20 + 8 + len(payload),        # total length
        0,                            # ID (kernel may overwrite)
        0,                            # flags + frag offset
        64,                           # TTL
        socket.IPPROTO_UDP,
        0,                            # IP checksum (kernel fills)
        b"\x00\x00\x00\x00",          # src IP (kernel fills from routing)
        socket.inet_aton(dst_ip),
    )
    udp_hdr = struct.pack(
        "!HHHH",
        src_port, dst_port,
        8 + len(payload),
        0,                            # UDP checksum=0 is legal for IPv4
    )
    return ip_hdr + udp_hdr + payload


def raw_inject(src_port, dst_ip, dst_port):
    """Send 3 empty UDP packets from a "stolen" source port. UDP is lossy and
    NAT mapping creation can race with the peer's incoming handshake; sending
    a small burst is cheap insurance."""
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_RAW, socket.IPPROTO_RAW)
        s.setsockopt(socket.SOL_IP, socket.IP_HDRINCL, 1)
    except PermissionError:
        LOG.event("hole-punch", "perm", "denied",
                  "cannot create raw socket — daemon needs CAP_NET_RAW",
                  level=logging.ERROR)
        return False
    try:
        packet = build_raw_udp_packet(src_port, dst_ip, dst_port)
        for i in range(RAW_INJECT_REPEATS):
            s.sendto(packet, (dst_ip, dst_port))
            if i + 1 < RAW_INJECT_REPEATS:
                time.sleep(RAW_INJECT_GAP)
    except Exception as e:
        logging.warning("raw-inject failed: %r", e)
        return False
    finally:
        s.close()
    return True


# ---------------------------------------------------------------------------
# Wake mechanism (force kernel WG to fire a handshake immediately)
# ---------------------------------------------------------------------------


def filter_candidates_for_peer(candidates: list, allowed_ips_str: str) -> list:
    """Sender-side per-peer trim: drop candidates whose IP falls inside
    any of the peer's `AllowedIPs` ranges.

    Using such an IP as Endpoint would make the peer's kernel route
    WG handshake packets back into the very tunnel needing the
    handshake to come up — a bootstrap deadlock.  Step B of the
    candidate-negotiation v2 design (memory:
    project_protocol_signal_wake_candidates.md): sender pre-trims so
    a misconfigured / pre-Step-A receiver still doesn't get served a
    deadlock candidate.  Step A's receiver-side check is
    defense-in-depth on top of this.

    [allowed_ips_str] is the raw `wg show <iface> allowed-ips` field
    for this peer (whitespace- or comma-separated CIDR list, possibly
    "(none)" or empty).  Returns a fresh list preserving the input
    order of survivors.
    """
    if not candidates:
        return []
    if not allowed_ips_str or allowed_ips_str.strip() == "(none)":
        return list(candidates)
    nets: list = []
    for token in allowed_ips_str.replace(",", " ").split():
        token = token.strip()
        if not token:
            continue
        try:
            nets.append(ipaddress.ip_network(token, strict=False))
        except ValueError:
            # Malformed entry — skip so a typo in one peers.d line
            # doesn't disable the filter for the whole list.
            continue
    if not nets:
        return list(candidates)
    out: list = []
    for c in candidates:
        ip = c.get("ip")
        try:
            addr = ipaddress.ip_address(ip)
        except (ValueError, TypeError):
            # Malformed candidate — drop, since we can't reason about it.
            continue
        if any(addr in net for net in nets):
            continue
        out.append(c)
    return out


def pick_wake_target(allowed_ips_str: str) -> Optional[str]:
    """Return an IPv4 host address that, when sent to via the WG iface,
    will route to the given peer (so kernel WG initiates a handshake to it).

    For /32 host routes: the host itself.
    For wider IPv4 networks: the first usable host inside.
    For /0 catchall: a TEST-NET-1 bogon — any IP works since /0 covers all,
                     and 192.0.2.1 won't be confused with real local hosts.
    For IPv6-only allowed-ips with no v4 entry: None (no v4 wake possible).
    """
    if not allowed_ips_str or allowed_ips_str.strip() == "(none)":
        return None
    has_catchall_v4 = False
    v4_host = None
    v4_net = None
    for token in allowed_ips_str.replace(",", " ").split():
        try:
            net = ipaddress.ip_network(token, strict=False)
        except ValueError:
            continue
        if not isinstance(net, ipaddress.IPv4Network):
            continue
        if net.prefixlen == 0:
            has_catchall_v4 = True
            continue
        if net.prefixlen == 32 and v4_host is None:
            v4_host = net.network_address
            continue
        if v4_net is None:
            v4_net = net
    if v4_host is not None:
        return str(v4_host)
    if v4_net is not None:
        hosts = list(v4_net.hosts())
        if hosts:
            return str(hosts[0])
        return str(v4_net.network_address)
    if has_catchall_v4:
        return WAKE_TARGET_BOGON
    return None


def wake_via_iface(iface: str, target_ip: str):
    """Send one byte through the WG interface. Kernel WG sees outbound traffic
    for the matching peer and initiates a handshake with the current endpoint.

    Uses SO_BINDTODEVICE so the packet is forced through `iface`, regardless
    of routing-table preference. Requires CAP_NET_RAW (already granted)."""
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        try:
            s.setsockopt(socket.SOL_SOCKET, socket.SO_BINDTODEVICE,
                         iface.encode("utf-8"))
        except OSError as e:
            if e.errno == errno.EPERM:
                LOG.event("wake", "perm", "denied",
                          "cannot SO_BINDTODEVICE — daemon needs CAP_NET_RAW",
                          level=logging.WARNING)
            return
        s.setblocking(False)
        try:
            s.sendto(b"\x00", (target_ip, 9))  # discard port
        except OSError:
            # Unreachable host or routing failure — kernel still saw the
            # outbound, which is enough to trigger WG handshake initiation.
            pass
    finally:
        s.close()


