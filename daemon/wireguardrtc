class PeerRuntime:
    config: PeerConfig
    iface: str
    last_signal_attempt: float = 0.0
    signal_backoff: float = SIGNALING_BACKOFF_INITIAL
    reinjector_task: Optional[asyncio.Task] = None
    last_dns_check: float = 0.0
    last_dns_resolved_ip: Optional[str] = None
    offer_exchange_count: int = 0       # OFFERs exchanged without tunnel-up
    offer_exchange_window_start: float = 0.0  # start of current exchange window
    offer_quarantine_until: float = 0.0  # suppress responses until this time


def parse_handshake_age(handshakes_table: dict, pubkey: str) -> float:
    raw = handshakes_table.get(pubkey, "0")
    try:
        ts = int(raw.strip())
    except ValueError:
        return float("inf")
    if ts == 0:
        return float("inf")
    return time.time() - ts


