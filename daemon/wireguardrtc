async def resolve_v4(host: str) -> Optional[str]:
    loop = asyncio.get_running_loop()
    try:
        infos = await loop.getaddrinfo(
            host, None, family=socket.AF_INET, type=socket.SOCK_DGRAM)
    except socket.gaierror:
        return None
    if not infos:
        return None
    return infos[0][4][0]


