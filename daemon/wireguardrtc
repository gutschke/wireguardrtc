class Daemon:
    def __init__(self, args):
        self.args = args
        self.global_config = load_global_config(args.config)
        self.peer_configs = load_peer_configs(
            args.peers_dir,
            auto_active_directory=auto_active_dir(self.global_config.state_dir)
            if self.global_config.auto_active_enrollment else None,
        )
        self.peerjs: Optional[PeerJSClient] = None
        self.shutdown_event = asyncio.Event()
        # Per-iface state.  Holds (pub_b64, listen_port) — NOT the
        # private key.  All operations that would need the priv go
        # through self.oracle (KeyOracleClient), which is the only
        # process in our trust boundary that holds raw key bytes.
        self._iface_keys = {}      # iface -> (pub_b64, listen_port)
        self._iface_peers = {}     # iface -> set of pubkey strings
        self._runtimes = {}        # (iface, pubkey) -> PeerRuntime
        self._chosen_iface = None  # which iface's pubkey is our PeerJS routing ID
        self.oracle: Optional[KeyOracleClient] = None
        self.raw: Optional[RawHelperClient] = None

    # --- self-test: verify configured peers exist somewhere in WG ---

    async def validate_peer_configs(self):
        live_peers = set()
        for iface in list_interfaces():
            allowed = await self.oracle.iface_table(iface, "allowed-ips")
            for pk in allowed.keys():
                live_peers.add(pk)
        ok = True
        for pk, cfg in self.peer_configs.items():
            if pk not in live_peers:
                logging.warning(
                    "%s: PublicKey %s not present on any WireGuard interface "
                    "(typo? wrong host?)", cfg.label, pk[:16] + "...")
                ok = False
            elif cfg.mode in (Mode.ACTIVE, Mode.PASSIVE):
                peer_broker_id = routing_id(pk, self.global_config.salt)
                logging.info("%s: broker id (peer) ...%s  [mode=%s]",
                             cfg.label, peer_broker_id[-8:], cfg.mode.value)
        return ok

    # --- iface state cache (refresh once per poll) ---

    async def refresh_iface_state(self):
        """Read pub/port and peer set for every WG iface via the oracle.

        Per-iface `wg show` queries require CAP_NET_ADMIN on this
        kernel (the daemon has no caps) so each field lookup is an
        RPC to the key-oracle.  Each RPC is a Unix-socket round-trip
        (microseconds) — sequential awaits are fine for the typical
        number of interfaces; switch to asyncio.gather if it ever
        matters.
        """
        new_keys = {}
        new_peers = {}
        for iface in list_interfaces():
            pub = await self.oracle.iface_field(iface, "public-key")
            port_s = await self.oracle.iface_field(iface, "listen-port")
            if not pub or pub == "(none)" or not port_s:
                # Diagnostic — log which field came back empty so the
                # admin can investigate.  StateLogger de-dupes so a
                # persistently-skipped iface logs once, not once per
                # poll.
                LOG.event("iface", "skipped", iface,
                          f"skipping {iface}: pub={pub!r} port={port_s!r}",
                          level=logging.WARNING)
                continue
            try:
                port = int(port_s)
            except ValueError:
                LOG.event("iface", "skipped", iface,
                          f"skipping {iface}: non-int listen-port {port_s!r}",
                          level=logging.WARNING)
                continue
            new_keys[iface] = (pub, port)
            # Use allowed-ips (not latest-handshakes) so peers with no
            # handshake yet are still discovered and signalled.
            allowed = await self.oracle.iface_table(iface, "allowed-ips")
            new_peers[iface] = set(allowed.keys())
        self._iface_keys = new_keys
        self._iface_peers = new_peers

    def select_listening_iface(self) -> Optional[str]:
        """Pick which interface's pubkey to use as our PeerJS routing ID.

        We hold ONE long-lived PeerJS connection — peers reach us at
        SHA-256(<pubkey> ‖ salt). Peers on different WG interfaces would
        normally use different pubkeys, so peers across multiple interfaces
        can't all reach a single routing ID.

        Picks the interface that hosts the most non-IGNORE configured peers.
        Warns if some configured peers will be unreachable as a result.
        Future versions should open one PeerJS connection per interface.
        """
        if not self._iface_keys:
            return None
        scoreboard = {iface: 0 for iface in self._iface_keys}
        for pk, cfg in self.peer_configs.items():
            if cfg.mode == Mode.IGNORE or cfg.mode == Mode.DNS_ROAM:
                continue
            for iface, peers in self._iface_peers.items():
                if pk in peers:
                    scoreboard[iface] += 1
                    break
        ranked = [iface for iface, n in
                  sorted(scoreboard.items(), key=lambda kv: (-kv[1], kv[0]))
                  if n > 0]
        if not ranked:
            # Fallback: enrollment-only mode has no configured peers yet.
            # If enrollment is enabled, pick the alphabetically-first
            # interface so we still open a PeerJS slot for incoming
            # ENROLL requests.
            if self.global_config.enrollment_enabled:
                return sorted(self._iface_keys.keys())[0]
            return None
        chosen = ranked[0]
        if len(ranked) > 1:
            unreachable = []
            for pk, cfg in self.peer_configs.items():
                if cfg.mode in (Mode.IGNORE, Mode.DNS_ROAM):
                    continue
                if pk not in self._iface_peers.get(chosen, set()):
                    unreachable.append(cfg.label)
            if unreachable:
                logging.warning(
                    "non-IGNORE peers configured on multiple interfaces; "
                    "PeerJS routing-id is keyed to %s, so peers on other "
                    "interfaces (%s) will not reach this daemon over PeerJS. "
                    "Workaround: split per-interface deployments, or wait for "
                    "multi-interface support",
                    chosen, ", ".join(unreachable))
        return chosen

    def our_routing_id(self) -> Optional[str]:
        if self._chosen_iface is None or self._chosen_iface not in self._iface_keys:
            return None
        pub, _ = self._iface_keys[self._chosen_iface]
        return routing_id(pub, self.global_config.salt)

    # --- incoming message dispatcher (called by PeerJSClient) ---

    async def on_incoming(self, src_id: str, metadata: dict):
        """Top-level handler for incoming PeerJS messages.

        Both signalling OFFERs and ENROLL requests ride inside the same
        WebRTC OFFER envelope; they're discriminated by `metadata.kind`.
        Absence of `kind` means a signalling OFFER (backward compatibility).
        """
        # Universal self-loop guard.
        our_id = self.our_routing_id()
        if our_id and src_id == our_id:
            LOG.event("peerjs", "self-loop", src_id,
                      "received message with our own routing ID — possible "
                      "misconfiguration (same salt+key on two hosts); ignoring",
                      level=logging.WARNING)
            return

        kind = metadata.get("kind")
        blob = metadata.get("blob")
        if not isinstance(blob, str):
            return

        if kind is None or kind == "offer":
            await self._handle_signaling(src_id, blob, is_wake=False)
        elif kind == "signal_wake":
            await self._handle_signaling(src_id, blob, is_wake=True)
        elif kind == "enroll":
            client_pub = metadata.get("client_pub")
            if not isinstance(client_pub, str):
                return
            await self._handle_enroll(src_id, client_pub, blob)
        # ENROLL_OK / ENROLL_ERR responses are not processed by the daemon
        # in its server role — those are handled by enrolling clients.
        # Silently ignore.

    async def _handle_signaling(self, src_id: str, blob_b64: str,
                                is_wake: bool = False):
        """Top-level dispatch for both ordinary signalling OFFERs and
        client-initiated `signal_wake` messages.

        is_wake = False:  legacy "I'm at <candidate>" — we apply the
            candidate to kernel WG and respond with our own endpoint
            unless the tunnel is already UP (anti-spam guard).
        is_wake = True:   "I want to reach you, please tell me where
            you are" — we DO NOT touch kernel WG state from the wake
            (the sender hasn't claimed an endpoint), but we DO send
            a responsive OFFER bypassing the tunnel-already-UP guard
            since the wake is an explicit user request.
        """
        # We listen on a single chosen iface's pubkey — only peers configured
        # on that iface (and not in IGNORE mode) can have legitimately sent us
        # an OFFER. Try each, decrypt fast on src_id mismatch.
        if self._chosen_iface is None:
            return
        iface = self._chosen_iface
        if iface not in self._iface_keys:
            return
        _pub, listen_port = self._iface_keys[iface]
        peers_on_iface = self._iface_peers.get(iface, set())
        for pk, cfg in self.peer_configs.items():
            if cfg.mode == Mode.IGNORE:
                continue
            if pk not in peers_on_iface:
                continue
            expected_src = routing_id(pk, self.global_config.salt)
            if src_id != expected_src:
                continue
            try:
                key = await self.oracle.derive_sigbox(iface, pk)
            except IOError as e:
                LOG.event(cfg.label, "oracle-derive", "fail",
                          f"OFFER from {cfg.label}: oracle derive_sigbox "
                          f"failed: {e}", level=logging.WARNING)
                return
            msg = decrypt_envelope(key, blob_b64)
            if msg is None:
                LOG.event(cfg.label, "decrypt", "fail",
                          f"OFFER from {cfg.label}: decryption/freshness failed",
                          level=logging.WARNING)
                return

            if not is_wake:
                # Ordinary signalling OFFER: apply the first valid
                # candidate (or skip the apply step entirely if none).
                # Kernel WG endpoint roaming will pick up the rest from
                # real handshake traffic — no point time-sharing.
                cand = first_valid_candidate(msg)
                if cand is None:
                    LOG.event(cfg.label, "rejected", "no-valid-candidate",
                              "OFFER from peer carried no usable candidate",
                              level=logging.WARNING)
                    # Fall through to the responsive-OFFER path so the
                    # peer at least learns where we are.
                else:
                    ip, port = cand
                    LOG.event(cfg.label, "incoming-endpoint", f"{ip}:{port}",
                              f"received endpoint {ip}:{port} via PeerJS "
                              f"(src broker id ...{src_id[-8:]})")
                    injected = await self.raw.inject(iface, listen_port, ip, port)
                    LOG.event(cfg.label, "hole-punch",
                              "ok" if injected else "fail",
                              f"raw UDP inject {listen_port} -> {ip}:{port}: "
                              f"{'ok' if injected else 'FAILED (raw-helper refused)'}")
                    if await self.oracle.set_endpoint(iface, pk, ip, port):
                        LOG.event(cfg.label, "wg-set", f"{ip}:{port}",
                                  f"wg set {iface} peer ...{pk[-8:]} endpoint {ip}:{port}")
                    ai = (await self.oracle.iface_table(iface, "allowed-ips")).get(pk, "")
                    target = pick_wake_target(ai)
                    if target is not None:
                        LOG.event(cfg.label, "wake", target,
                                  f"waking handshake via {iface} -> {target}")
                        await self.raw.wake(iface, target)
                    self._start_reinjector(pk, iface, cfg)
            else:
                # signal_wake: don't touch kernel WG state.  The sender
                # is asking "where are you" — we fall through to the
                # responsive-OFFER path which advertises our endpoint.
                LOG.event(cfg.label, "wake-received", str(int(time.time())),
                          f"signal_wake from {cfg.label} "
                          f"(src broker id ...{src_id[-8:]})")

            # Responsive OFFER: advertise our own endpoint so the peer can
            # punch their NAT toward us. Applies to all non-IGNORE modes.
            # Guards prevent OFFER loops and broker overuse.
            now = time.time()
            runtime = self._peer_runtime(pk, iface, cfg)

            # If the tunnel is already up, the peer's hole-punch worked
            # and there's nothing to bootstrap.  But a `signal_wake` is
            # an explicit user request to refresh the peer's stored
            # endpoint for us, so we always honor it (rate-limit still
            # applies — see the rolling-window counter below).
            if not is_wake:
                hs_age = parse_handshake_age(
                    await self.oracle.iface_table(iface, "latest-handshakes"), pk)
                if hs_age < HANDSHAKE_DEAD_THRESHOLD:
                    runtime.offer_exchange_count = 0
                    runtime.offer_exchange_window_start = 0.0
                    runtime.offer_quarantine_until = 0.0
                    return

            # Quarantine: too many exchanges without a working tunnel.
            if now < runtime.offer_quarantine_until:
                return

            # Rolling-window exchange counter.
            if now - runtime.offer_exchange_window_start > OFFER_EXCHANGE_WINDOW:
                runtime.offer_exchange_count = 0
                runtime.offer_exchange_window_start = now
            runtime.offer_exchange_count += 1

            if runtime.offer_exchange_count >= OFFER_EXCHANGE_QUARANTINE_THRESHOLD:
                logging.warning(
                    "[%s] %d OFFER exchanges in %.0fs without tunnel-up; "
                    "quarantining for %.0fs — verify NAT type and routing",
                    cfg.label, runtime.offer_exchange_count,
                    OFFER_EXCHANGE_WINDOW, OFFER_QUARANTINE_DURATION)
                runtime.offer_quarantine_until = now + OFFER_QUARANTINE_DURATION
                runtime.offer_exchange_count = 0
                runtime.offer_exchange_window_start = now
                return

            # Rate-limit: one outbound OFFER per OFFER_RESPONSE_MIN_INTERVAL.
            if now - runtime.last_signal_attempt < OFFER_RESPONSE_MIN_INTERVAL:
                return

            runtime.last_signal_attempt = now
            LOG.event(cfg.label, "offer-response", str(int(now)),
                      f"sending OFFER response to {cfg.label} "
                      f"(exchange {runtime.offer_exchange_count})")
            asyncio.create_task(self.signal_peer(iface, cfg, listen_port))
            return

    # --- enrollment handler (called from on_incoming for kind=="enroll") ---

    async def _handle_enroll(self, src_id: str, client_pub_b64: str,
                             ciphertext_b64: str):
        """Process an inbound ENROLL request.

        Security-critical sequence:
          1. fast rejects (enrollment off, missing iface, malformed pubkey)
          2. cached-response lookup (legitimate retry safety)
          3. try-decrypt over each pending unexpired token
          4. validate plaintext (token_check, freshness window)
          5. atomic token claim (single-use enforcement)
          6. ProvisionScript invocation
          7. read back allocated WG state
          8. build, encrypt, send ENROLL_OK; cache for retries
        Any failure short-circuits without leaking which step failed —
        attackers should not be able to distinguish "no such token" from
        "wrong key" from "expired token" via timing or response shape.
        """
        gcfg = self.global_config

        # Fast reject: enrollment disabled.
        if not gcfg.enrollment_enabled:
            LOG.event("enroll", "disabled", "1",
                      "received ENROLL but [Enrollment] Enabled = no; ignoring",
                      level=logging.DEBUG)
            return

        # Need an active WG interface to anchor the response.
        if self._chosen_iface is None or self._chosen_iface not in self._iface_keys:
            LOG.event("enroll", "no-iface", "1",
                      "received ENROLL but no usable WG interface yet; ignoring",
                      level=logging.WARNING)
            return
        iface = self._chosen_iface
        server_pub_b64, listen_port = self._iface_keys[iface]

        # Validate client pubkey shape (must decode to 32 bytes).
        try:
            client_pub_raw = base64.b64decode(client_pub_b64)
        except Exception:
            return
        if len(client_pub_raw) != 32:
            return

        # The src routing ID in the envelope must match what we'd compute
        # from client_pub.  Attackers couldn't forge this through the broker
        # (it's set by the broker based on the sender's registered ID), but
        # we check anyway as a sanity guard against malformed messages.
        expected_src = routing_id(client_pub_b64, gcfg.salt)
        if src_id != expected_src:
            LOG.event("enroll", "src-mismatch", expected_src[-8:],
                      f"ENROLL src_id {src_id[-8:]} doesn't match "
                      f"routing_id(client_pub); ignoring",
                      level=logging.WARNING)
            return

        store = PendingTokensStore(gcfg.state_dir)

        # Replay safety: legitimate retry from same client_pub returns the
        # cached envelope.  Only the holder of client_priv can decrypt it.
        cached = store.find_recent(client_pub_b64)
        if cached is not None:
            LOG.event(client_pub_b64[:12], "enroll-cached", "1",
                      f"retry from already-enrolled client "
                      f"(broker id ...{src_id[-8:]}); returning cached response",
                      level=logging.INFO)
            await self.peerjs.send(cached)
            return

        # Try-decrypt over each token (used + unused), checking expiry.
        # We DO try used tokens, because a client racing for an
        # already-consumed token deserves an authenticated TOKEN_USED
        # response — the user-noticing property
        tokens = store.list_tokens()
        now = time.time()
        matched_token: Optional[bytes] = None
        matched_key:   Optional[bytes] = None
        matched_plaintext: Optional[dict] = None
        matched_meta: Optional[dict] = None
        for entry in tokens:
            # Skip expired, including used-but-old purgeable entries.
            if entry.get("expires_at", 0) <= now and not entry.get("used"):
                continue
            try:
                token_bytes = base64.b64decode(entry["token_b64"])
            except Exception:
                continue
            try:
                key = await self.oracle.derive_enroll(
                    iface, client_pub_b64, token_bytes)
            except IOError as e:
                # Oracle unreachable; cannot proceed safely.
                LOG.event("enroll", "oracle-unreachable", "1",
                          f"oracle derive_enroll failed: {e}",
                          level=logging.WARNING)
                return
            decrypted = decrypt_enroll_blob(key, ciphertext_b64)
            if decrypted is None:
                continue
            # Belt-and-braces token_check inside the auth-tagged ciphertext.
            if decrypted.get("token_check") != entry["token_b64"]:
                continue
            # Freshness window.
            ts = decrypted.get("ts")
            if not isinstance(ts, int) or abs(now - ts) > ENROLL_FRESHNESS_WINDOW:
                continue
            matched_token = token_bytes
            matched_key = key  # reuse for the response encryption below
            matched_plaintext = decrypted
            matched_meta = entry
            break

        if matched_token is None:
            # Silent ignore (per threat model: don't leak which case failed).
            LOG.event("enroll", "unmatched", str(int(now / 5)),  # rate-limit
                      f"ENROLL from broker id ...{src_id[-8:]}: no matching "
                      f"token (or wrong key, or expired, or stale ts)",
                      level=logging.WARNING)
            return

        # Was the matched token already used by a *different* client?
        # That's a race-loss: respond with authenticated TOKEN_USED so the
        # losing client surfaces the failure to its user.
        if matched_meta.get("used"):
            err_blob = encrypt_enroll_blob(
                matched_key,
                {"v": PROTOCOL_VERSION, "ts": int(now),
                 "code": "TOKEN_USED", "retry_after": 0})
            envelope = build_enroll_envelope(
                src_id, "enroll_err", server_pub_b64, err_blob)
            await self.peerjs.send(envelope)
            LOG.event(client_pub_b64[:12], "enroll-token-used", "1",
                      f"ENROLL race lost: token for "
                      f"{matched_meta.get('name_hint','?')} already consumed "
                      f"by {matched_meta.get('used_by','?')[:12]}",
                      level=logging.WARNING)
            return

        # Atomic claim.  Returns None if someone else claimed the token
        # between list_tokens() and try_claim() (a different in-flight ENROLL
        # or a parallel CLI op).  In that race-loss case, fall through to the
        # same TOKEN_USED response.
        claim = store.try_claim(matched_token, client_pub_b64)
        if claim is None:
            err_blob = encrypt_enroll_blob(
                matched_key,
                {"v": PROTOCOL_VERSION, "ts": int(now),
                 "code": "TOKEN_USED", "retry_after": 0})
            envelope = build_enroll_envelope(
                src_id, "enroll_err", server_pub_b64, err_blob)
            await self.peerjs.send(envelope)
            LOG.event(client_pub_b64[:12], "enroll-token-used", "1",
                      f"ENROLL claim race lost between try-decrypt and "
                      f"atomic-claim",
                      level=logging.WARNING)
            return

        # We won the claim.  Run the provisioning hook.
        name_hint = matched_meta.get("name_hint", "unknown")
        ok, errmsg = run_provision_script(
            gcfg.provision_script, iface, name_hint, client_pub_b64,
            token=matched_token)
        if not ok:
            err_blob = encrypt_enroll_blob(
                matched_key,
                {"v": PROTOCOL_VERSION, "ts": int(now),
                 "code": "PROVISION_FAILED",
                 "note": errmsg or "provisioning script failed"})
            envelope = build_enroll_envelope(
                src_id, "enroll_err", server_pub_b64, err_blob)
            await self.peerjs.send(envelope)
            LOG.event(client_pub_b64[:12], "enroll-provision-fail", "1",
                      f"ENROLL provisioning failed for {name_hint}: {errmsg}",
                      level=logging.ERROR)
            return

        # Read back allocated WG state.
        await self.refresh_iface_state()
        allowed = (await self.oracle.iface_table(iface, "allowed-ips")
                   ).get(client_pub_b64, "")
        if not allowed:
            err_blob = encrypt_enroll_blob(
                matched_key,
                {"v": PROTOCOL_VERSION, "ts": int(now),
                 "code": "PROVISION_FAILED",
                 "note": "ProvisionScript returned ok but peer not visible "
                         "in `wg show`"})
            envelope = build_enroll_envelope(
                src_id, "enroll_err", server_pub_b64, err_blob)
            await self.peerjs.send(envelope)
            LOG.event(client_pub_b64[:12], "enroll-not-visible", "1",
                      f"ProvisionScript returned 0 but {client_pub_b64[:12]}... "
                      f"not in `wg show {iface} allowed-ips`",
                      level=logging.ERROR)
            return

        # Build ENROLL_OK plaintext.  The first /32 (or /128) entry in
        # allowed-ips is the address; if there are wider routes we list
        # them under "allowed_ips" for the client to add to its config.
        addr = ""
        for tok in allowed.replace(",", " ").split():
            try:
                net = ipaddress.ip_network(tok, strict=False)
            except ValueError:
                continue
            if isinstance(net, ipaddress.IPv4Network) and net.prefixlen == 32:
                addr = str(net)
                break
        # Endpoint hint: prefer the static [Global] PublicIp override, but
        # fall back to a fresh STUN lookup so the client gets a usable
        # endpoint even on hosts that don't pin a public IP.  Mirrors
        # signal_peer; STUN failure here is non-fatal — the client will
        # still hole-punch, just without a server endpoint pre-populated.
        endpoint_ip = gcfg.public_ip
        if not endpoint_ip:
            endpoint_ip = await get_public_ipv4(gcfg.stun_servers, gcfg)
        # Build the full ranked candidate list (Step C path) so the
        # client can race LAN/STUN/PublicIp from the very first connect
        # — without this, the embedded `server_endpoint_hint` (always
        # the public IP) gets used as the sole endpoint and a same-LAN
        # phone needlessly hairpins through the carrier.  Per-peer trim
        # uses the just-allocated /32 so the new peer never gets served
        # a candidate inside its own AllowedIPs (a deadlock case).
        own_wg = set(self._iface_keys.keys())
        try:
            cand_list = await discover_local_candidates(
                gcfg, listen_port, own_wg_ifaces=own_wg,
            )
            cand_list = filter_candidates_for_peer(cand_list, allowed)
        except Exception as e:
            LOG.event(client_pub_b64[:12], "enroll-candidates", "fail",
                      f"discover_local_candidates failed during enroll: {e!r}; "
                      f"client gets server_endpoint_hint only",
                      level=logging.WARNING)
            cand_list = []
        ok_plaintext = {
            "v":          PROTOCOL_VERSION,
            "ts":         int(now),
            "address":    addr or allowed.split(",")[0].strip(),
            "allowed_ips": "0.0.0.0/0, ::/0",  # client's view
            "keepalive":  25,
            "server_pubkey":         server_pub_b64,
            "server_endpoint_hint":  (f"{endpoint_ip}:{listen_port}"
                                      if endpoint_ip else None),
            # Full ranked list — clients that understand the field race
            # the entire list on first connect; older clients ignore it
            # and fall back to server_endpoint_hint.  Each entry:
            # {"ip": "<v4-addr>", "port": <int>, "kind": "stun|lan|mesh"}.
            "candidates": cand_list,
            "name":       name_hint,
        }
        ok_blob = encrypt_enroll_blob(matched_key, ok_plaintext)
        envelope = build_enroll_envelope(
            src_id, "enroll_ok", server_pub_b64, ok_blob)

        # Cache before sending.  Cache is the source of truth for retry safety;
        # if send() fails after this, the next retry returns the same envelope.
        store.cache_response(client_pub_b64, envelope)
        await self.peerjs.send(envelope)
        LOG.event(client_pub_b64[:12], "enroll-ok", addr,
                  f"enrolled {name_hint} (...{client_pub_b64[-8:]}) "
                  f"with address={addr or '?'}",
                  level=logging.INFO)

        # Auto-active: write a peers.d-style drop-in into the writable
        # state dir so the daemon will push OFFERs to this newly-
        # enrolled peer without requiring the admin to hand-author a
        # peers.d/<label>.conf entry.  The Phase-2 long-lived
        # OfferListener on the Android side relies on these OFFERs to
        # follow the daemon's roaming public IP.  An admin-authored
        # peers.d/ entry with the same pubkey overrides this drop-in
        # (the explicit /etc/wireguardrtc/peers.d wins).
        if gcfg.auto_active_enrollment:
            try:
                write_auto_active_peer(
                    state_dir=gcfg.state_dir,
                    pubkey_b64=client_pub_b64,
                    label=name_hint,
                    iface=iface,
                )
                # Refresh in-memory peer configs so the next poll
                # sends an OFFER without waiting for a daemon restart.
                self.peer_configs = load_peer_configs(
                    self.args.peers_dir,
                    auto_active_directory=auto_active_dir(gcfg.state_dir),
                )
            except Exception as e:
                LOG.event(client_pub_b64[:12], "auto-active", "fail",
                          f"could not write auto-active drop-in: {e!r}",
                          level=logging.WARNING)

    # --- conntrack keepalive: re-inject every REINJECT_INTERVAL while DOWN ---

    async def _reinjector_loop(self, pk: str, iface: str, cfg: PeerConfig):
        """Keep our NAT hole open after a hole-punch until the handshake lands.

        The raw-inject creates a conntrack entry (~30 s TTL). If the peer's NAT
        opens after our entry has expired we miss the handshake. Re-injecting
        every REINJECT_INTERVAL (20 s) keeps the entry perpetually fresh on our
        side, decoupling our NAT state from the peer's inject timing.
        """
        while True:
            await asyncio.sleep(REINJECT_INTERVAL)
            endpoints = await self.oracle.iface_table(iface, "endpoints")
            ep = endpoints.get(pk, "").strip()
            if not ep or ep == "(none)":
                continue
            handshakes = await self.oracle.iface_table(iface, "latest-handshakes")
            age = parse_handshake_age(handshakes, pk)
            if age < HANDSHAKE_DEAD_THRESHOLD:
                return  # tunnel is up, stop
            try:
                dst_ip, dst_port_s = ep.rsplit(":", 1)
                dst_port = int(dst_port_s)
            except (ValueError, AttributeError):
                continue
            listen_port_s = await self.oracle.iface_field(iface, "listen-port")
            try:
                listen_port = int(listen_port_s)
            except (ValueError, TypeError):
                continue
            aips = (await self.oracle.iface_table(iface, "allowed-ips")).get(pk, "")
            target = pick_wake_target(aips)
            logging.debug("[%s] re-inject %s -> %s:%s (conntrack refresh)",
                          cfg.label, listen_port, dst_ip, dst_port)
            await self.raw.inject(iface, listen_port, dst_ip, dst_port)
            if target is not None:
                await self.raw.wake(iface, target)

    def _start_reinjector(self, pk: str, iface: str, cfg: PeerConfig):
        runtime = self._peer_runtime(pk, iface, cfg)
        if runtime.reinjector_task is None or runtime.reinjector_task.done():
            runtime.reinjector_task = asyncio.create_task(
                self._reinjector_loop(pk, iface, cfg))

    # --- outbound: try to signal a peer that's currently dead ---

    async def signal_peer(self, iface: str, cfg: PeerConfig, listen_port: int):
        try:
            key = await self.oracle.derive_sigbox(iface, cfg.public_key)
        except IOError as e:
            LOG.event(cfg.label, "oracle-derive", "fail",
                      f"OFFER not sent to {cfg.label}: oracle derive_sigbox "
                      f"failed: {e}", level=logging.WARNING)
            return
        # Step C: build a ranked multi-candidate list (PublicIp +
        # parallel STUN + local interfaces).  Replaces the v1
        # single-candidate emission.  phone-host fills
        # [LAN, STUN] for free under this same path.
        own_wg = set(self._iface_keys.keys())
        candidates = await discover_local_candidates(
            self.global_config, listen_port,
            own_wg_ifaces=own_wg,
        )
        if not candidates:
            LOG.event(cfg.label, "offer-sent", "fail",
                      f"OFFER not sent to {cfg.label}: no candidates "
                      f"discovered (STUN failed AND no usable local "
                      f"interface address)",
                      level=logging.WARNING)
            return
        # Step B: trim candidates that would deadlock THIS peer's
        # kernel-WG bringup (IPs inside its own AllowedIPs).
        peer_aips = (await self.oracle.iface_table(iface, "allowed-ips")
                     ).get(cfg.public_key, "")
        candidates = filter_candidates_for_peer(candidates, peer_aips)
        if not candidates:
            LOG.event(cfg.label, "offer-sent", "fail",
                      f"OFFER not sent to {cfg.label}: every discovered "
                      f"candidate is inside that peer's AllowedIPs "
                      f"({peer_aips}) — would deadlock kernel-WG handshake",
                      level=logging.WARNING)
            return
        blob_b64 = encrypt_envelope(key, candidates)
        dst_id = routing_id(cfg.public_key, self.global_config.salt)
        envelope = build_offer_envelope(dst_id, blob_b64)
        if self.peerjs is None:
            return
        ok = await self.peerjs.send(envelope)
        if ok:
            advertised = ",".join(f"{c['ip']}:{c['port']}" for c in candidates)
            LOG.event(cfg.label, "offer-sent", str(int(time.time())),
                      f"sent OFFER to {cfg.label} (broker id ...{dst_id[-8:]})"
                      f" advertising {advertised}")
        else:
            LOG.event(cfg.label, "offer-sent", "fail",
                      f"OFFER not sent to {cfg.label}: PeerJS unavailable",
                      level=logging.WARNING)

    async def signal_all_active_peers(self):
        """Signal all ACTIVE peers that are currently DOWN. Called when the
        PeerJS session opens so we don't wait a full SIGNALING_BACKOFF cycle
        after a reconnect or startup race."""
        await self.refresh_iface_state()
        for iface, (pub, listen_port) in self._iface_keys.items():
            handshakes = await self.oracle.iface_table(iface, "latest-handshakes")
            peers_here = self._iface_peers.get(iface, set())
            for pk, cfg in self.peer_configs.items():
                if cfg.mode != Mode.ACTIVE:
                    continue
                if pk not in peers_here:
                    continue
                age = parse_handshake_age(handshakes, pk)
                if age < HANDSHAKE_DEAD_THRESHOLD:
                    continue
                runtime = self._peer_runtime(pk, iface, cfg)
                runtime.last_signal_attempt = time.time()
                asyncio.create_task(
                    self.signal_peer(iface, cfg, listen_port))

    # --- per-iface DNS roam check ---

    async def repair_dns(self, iface: str, listen_port: int):
        endpoints = await self.oracle.iface_table(iface, "endpoints")
        for pk, cfg in self.peer_configs.items():
            if cfg.mode != Mode.DNS_ROAM or not cfg.dns_host:
                continue
            host_port = cfg.dns_host
            if ":" not in host_port:
                continue
            host, p = host_port.rsplit(":", 1)
            try:
                target_port = int(p)
            except ValueError:
                continue
            ip = await resolve_v4(host)
            if ip is None:
                continue
            if not is_valid_public_endpoint(ip, target_port):
                continue
            new_ep = f"{ip}:{target_port}"
            current = endpoints.get(pk)
            if current == new_ep:
                continue
            LOG.event(cfg.label, "dns-roam", new_ep,
                      f"DNS {host} -> {ip}:{target_port}; updating endpoint")
            await self.oracle.set_endpoint(iface, pk, ip, target_port)
            ai = (await self.oracle.iface_table(iface, "allowed-ips")).get(pk, "")
            target = pick_wake_target(ai)
            if target is not None:
                await self.raw.wake(iface, target)

    # --- per-poll work ---

    async def poll_once(self):
        await self.refresh_iface_state()
        # Drop stale enrollment state on every poll cycle.  This is the
        # single mechanism that prevents pending-tokens.json from
        # growing unbounded across "admin minted N tokens that nobody
        # ever used" episodes.  purge_expired() is cheap (in-memory
        # filter + atomic write) and only writes when something
        # actually changed.
        if self.global_config.enrollment_enabled:
            removed = await asyncio.to_thread(
                PendingTokensStore(self.global_config.state_dir).purge_expired)
            if removed:
                LOG.event("enroll", "purged", str(removed),
                          f"purged {removed} expired token/cache entries")
        for iface, (pub, listen_port) in self._iface_keys.items():
            await self.repair_dns(iface, listen_port)
            handshakes = await self.oracle.iface_table(iface, "latest-handshakes")
            peers_here = self._iface_peers.get(iface, set())
            for pk, cfg in self.peer_configs.items():
                if cfg.mode != Mode.ACTIVE:
                    continue
                if pk not in peers_here:
                    continue  # not on this interface
                age = parse_handshake_age(handshakes, pk)
                up = age < HANDSHAKE_DEAD_THRESHOLD
                LOG.event(cfg.label, "status",
                          "UP" if up else "DOWN",
                          f"tunnel {'UP' if up else 'DOWN'} "
                          f"(last handshake age: "
                          f"{age:.0f}s)" if age != float('inf')
                          else "tunnel DOWN (no handshake yet)")
                runtime = self._peer_runtime(pk, iface, cfg)
                if up:
                    # Reset all transient state so the next outage starts fresh.
                    runtime.signal_backoff = SIGNALING_BACKOFF_INITIAL
                    runtime.offer_exchange_count = 0
                    runtime.offer_exchange_window_start = 0.0
                    runtime.offer_quarantine_until = 0.0
                    if (runtime.reinjector_task is not None
                            and not runtime.reinjector_task.done()):
                        runtime.reinjector_task.cancel()
                        runtime.reinjector_task = None
                    continue
                if (time.time() - runtime.last_signal_attempt
                        > runtime.signal_backoff):
                    runtime.last_signal_attempt = time.time()
                    runtime.signal_backoff = min(
                        runtime.signal_backoff * 2, SIGNALING_BACKOFF_MAX)
                    asyncio.create_task(
                        self.signal_peer(iface, cfg, listen_port))

    def _peer_runtime(self, pk: str, iface: str, cfg: PeerConfig) -> PeerRuntime:
        key = (iface, pk)
        if key not in self._runtimes:
            self._runtimes[key] = PeerRuntime(config=cfg, iface=iface)
        return self._runtimes[key]

    # --- main loop ---

    async def run(self):
        # Connect to the privileged key-oracle FIRST.  The daemon does
        # not hold any private keys itself; every derivation and every
        # `wg set` for an endpoint goes through the oracle.
        oracle_sock = os.environ.get(
            "WIREGUARDRTC_KEY_ORACLE_SOCKET", KEY_ORACLE_DEFAULT_SOCKET)
        self.oracle = KeyOracleClient(oracle_sock)
        for attempt in range(1, 31):
            if await self.oracle.connect():
                logging.info("connected to key oracle at %s", oracle_sock)
                break
            # The oracle is started by its own systemd unit; wait a bit
            # in case we got scheduled before it.
            await asyncio.sleep(min(attempt, 5))
        else:
            sys.stderr.write(
                "[FATAL] could not connect to wireguardrtc-key-oracle "
                f"at {oracle_sock} after 30 attempts.\n"
                "Is wireguardrtc-key-oracle.service running?\n")
            sys.exit(2)

        # And to the raw-socket helper.  CAP_NET_RAW lives there now,
        # not in our process; raw_inject() and wake_via_iface() go
        # through the helper RPC.
        raw_sock = os.environ.get(
            "WIREGUARDRTC_RAW_HELPER_SOCKET", RAW_HELPER_DEFAULT_SOCKET)
        self.raw = RawHelperClient(raw_sock)
        for attempt in range(1, 31):
            if await self.raw.connect():
                logging.info("connected to raw-socket helper at %s", raw_sock)
                break
            await asyncio.sleep(min(attempt, 5))
        else:
            sys.stderr.write(
                "[FATAL] could not connect to wireguardrtc-raw-helper "
                f"at {raw_sock} after 30 attempts.\n"
                "Is wireguardrtc-raw-helper.service running?\n")
            sys.exit(2)

        await self.refresh_iface_state()
        await self.validate_peer_configs()

        # Boot-time cleanup of any stale enrollment state from the
        # previous instance.  Tokens whose `expires_at` is in the past
        # are invalid by definition; keeping them in the file just
        # makes the daemon scan more entries on each ENROLL.  Same for
        # the recent-enrollments retry cache.
        if self.global_config.enrollment_enabled:
            removed = await asyncio.to_thread(
                PendingTokensStore(self.global_config.state_dir).purge_expired)
            if removed:
                logging.info(
                    "boot recovery: purged %d expired enrollment-state entries",
                    removed)

        if not self._iface_keys:
            sys.stderr.write(
                "[FATAL] no usable WireGuard interfaces found "
                "(missing pubkey/listen-port; check `wg show interfaces`)\n"
            )
            sys.exit(2)

        self._chosen_iface = self.select_listening_iface()
        our_id = self.our_routing_id()
        if not our_id:
            if self.global_config.enrollment_enabled:
                logging.warning(
                    "no active/passive peers configured but enrollment is "
                    "enabled; expected --enroll-token to mint vouchers but "
                    "found no WG interface to anchor the routing-id to")
            else:
                logging.warning(
                    "no active/passive peers configured; daemon will run for "
                    "DNS roaming only (no PeerJS connection will be opened)")

        peerjs_task = None
        if our_id:
            logging.info("PeerJS broker id (this peer): ...%s", our_id[-8:])
            self.peerjs = PeerJSClient(
                server=self.global_config.peerjs_server,
                key=self.global_config.peerjs_key,
                our_routing_id=our_id,
                on_incoming=self.on_incoming,
                on_open=self.signal_all_active_peers,
            )
            peerjs_task = asyncio.create_task(self.peerjs.run())

        logging.info("daemon started (%d active, %d passive, %d dns-roam, "
                     "%d ignore peers configured)",
                     sum(1 for c in self.peer_configs.values()
                         if c.mode == Mode.ACTIVE),
                     sum(1 for c in self.peer_configs.values()
                         if c.mode == Mode.PASSIVE),
                     sum(1 for c in self.peer_configs.values()
                         if c.mode == Mode.DNS_ROAM),
                     sum(1 for c in self.peer_configs.values()
                         if c.mode == Mode.IGNORE))

        try:
            while not self.shutdown_event.is_set():
                try:
                    await self.poll_once()
                except Exception as e:
                    logging.exception("poll error: %r", e)
                # PeerJS skipped at startup because WireGuard interfaces weren't
                # up yet (race with wg-quick).  Re-check on each poll so we open
                # the connection as soon as the interfaces appear.
                if self.peerjs is None:
                    self._chosen_iface = self.select_listening_iface()
                    late_id = self.our_routing_id()
                    if late_id:
                        logging.info(
                            "PeerJS broker id (this peer): ...%s  "
                            "[interfaces appeared after daemon start]",
                            late_id[-8:])
                        self.peerjs = PeerJSClient(
                            server=self.global_config.peerjs_server,
                            key=self.global_config.peerjs_key,
                            our_routing_id=late_id,
                            on_incoming=self.on_incoming,
                            on_open=self.signal_all_active_peers,
                        )
                        peerjs_task = asyncio.create_task(self.peerjs.run())
                try:
                    await asyncio.wait_for(self.shutdown_event.wait(),
                                           timeout=POLL_INTERVAL)
                except asyncio.TimeoutError:
                    pass
        finally:
            if self.peerjs is not None:
                await self.peerjs.stop()
            if peerjs_task is not None:
                peerjs_task.cancel()
                try:
                    await peerjs_task
                except (asyncio.CancelledError, Exception):
                    pass


