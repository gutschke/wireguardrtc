#!/bin/bash
# wireguardrtc-provision-default — minimal ProvisionScript hook for
# stock wg-quick deployments.
#
# Contract (called by wireguardrtc daemon):
#   wireguardrtc-provision-default IFACE NAME PUBKEY_BASE64
#   Exit 0 on success.  Daemon reads back the allocation via `wg show`.
#
# Behaviour:
#   1. Reads address pool from /etc/wireguardrtc/provisioning.conf:
#        Pool = 10.99.0.0/24       # CIDR; first usable host is reserved
#                                  # for the server, allocations start at the
#                                  # second usable host
#   2. Computes the next-available host address in that CIDR by scanning
#      already-allocated addresses in /etc/wireguard/IFACE.conf and the
#      live `wg show IFACE allowed-ips` table.
#   3. Appends a [Peer] block to /etc/wireguard/IFACE.conf for persistence.
#   4. Runs `wg syncconf IFACE <(wg-quick strip IFACE)` to apply without
#      disrupting existing peers.
#
# Limitations:
#   - IPv4 single-pool only.  Edit this script for IPv6 dual-stack or
#     multi-pool deployments, or replace it with your own ProvisionScript.
#   - Allocation is monotonic (starts where the highest-allocated address
#     ends + 1).  Does not reuse addresses freed by removed peers.
#   - Requires CAP_NET_ADMIN to invoke `wg syncconf` and `wg set`.
#
# Logging: anything written to stderr is captured by the daemon and
# included in a PROVISION_FAILED response if exit != 0.

set -euo pipefail

IFACE="${1:?usage: $0 IFACE NAME PUBKEY_BASE64}"
NAME="${2:?usage: $0 IFACE NAME PUBKEY_BASE64}"
PUBKEY="${3:?usage: $0 IFACE NAME PUBKEY_BASE64}"

CONF="/etc/wireguardrtc/provisioning.conf"
WG_CONF="/etc/wireguard/${IFACE}.conf"

[[ -r "$CONF" ]] || {
    echo "missing $CONF (need: 'Pool = X.X.X.X/Y')" >&2
    exit 1
}

# Trivial INI scan for `Pool = ...` (case-sensitive).
POOL=$(awk -F'=' '/^[[:space:]]*Pool[[:space:]]*=/ {gsub(/[[:space:]]/,"",$2); print $2; exit}' "$CONF")
[[ -n "$POOL" ]] || { echo "no Pool = ... line in $CONF" >&2; exit 1; }

[[ -w "$WG_CONF" ]] || {
    echo "$WG_CONF not writable (this script must run as root or as a user with edit access)" >&2
    exit 1
}

# Find next free address: collect all currently-used hosts inside POOL,
# pick the smallest that's not in use AND inside the pool's host range.
USED=$(
    {
        # Addresses currently in the conf file (peers + interface).
        awk '/^[[:space:]]*(Address|AllowedIPs)[[:space:]]*=/ {
                sub(/^[^=]*=/,"")
                gsub(/[[:space:]]/,"")
                n = split($0, parts, ",")
                for (i = 1; i <= n; i++) {
                    a = parts[i]
                    sub(/\/.*/, "", a)
                    print a
                }
        }' "$WG_CONF"
        # Plus anything live in the kernel.
        wg show "$IFACE" allowed-ips 2>/dev/null \
            | awk '{
                  for (i = 2; i <= NF; i++) {
                      a = $i
                      sub(/\/.*/, "", a)
                      print a
                  }
              }'
    } | sort -u
)

# Compute the next free /32 inside the pool.  We use Python for proper
# CIDR arithmetic (no need to take a dependency on ipcalc).
NEW_ADDR=$(python3 - "$POOL" <<EOF
import ipaddress, sys
pool = ipaddress.ip_network(sys.argv[1], strict=False)
used = set()
for line in sys.stdin.read().splitlines():
    line = line.strip()
    if not line:
        continue
    try:
        used.add(ipaddress.ip_address(line))
    except ValueError:
        pass
for host in pool.hosts():
    if host not in used:
        print(host)
        sys.exit(0)
sys.stderr.write("pool {} exhausted\n".format(pool))
sys.exit(1)
EOF
<<<"$USED"
)

[[ -n "$NEW_ADDR" ]] || { echo "could not allocate address from $POOL" >&2; exit 1; }

# Append [Peer] block to the conf (atomic-ish: write to .tmp + rename).
TMP=$(mktemp "${WG_CONF}.XXXX")
trap 'rm -f "$TMP"' EXIT
cp -p "$WG_CONF" "$TMP"
cat >> "$TMP" <<EOF

# auto-enrolled $(date -u +%Y-%m-%dT%H:%M:%SZ): $NAME
[Peer]
PublicKey  = $PUBKEY
AllowedIPs = ${NEW_ADDR}/32
EOF
mv "$TMP" "$WG_CONF"
trap - EXIT

# Apply to running interface without disrupting existing peers.
wg syncconf "$IFACE" <(wg-quick strip "$IFACE")

# Diagnostics on stderr (the daemon doesn't propagate these on success).
echo "provisioned $NAME ($PUBKEY) -> ${NEW_ADDR}/32 on $IFACE" >&2
exit 0
