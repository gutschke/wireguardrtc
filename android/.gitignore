# Build outputs
build/
.gradle/
.kotlin/
local.properties
*.iml
.idea/

# Keystore — never check in.  See app/keystore.properties.example
# and ../reference/PLAY_STORE_NOTES.md.
app/keystore.properties
*.keystore
*.jks

# wgbridge_native: the per-ABI libwgbridge_native.so files are
# regenerated by wgbridge_native/build.sh + consumed by
# :wgbridge-native-aar.  Don't check them in.  Also catch the host
# binary that a bare `go build .` produces (we never want it).
wgbridge_native/build/
wgbridge_native/wgbridge_native

# Sandbox-script runtime state.  Defaults to ${TMPDIR:-/tmp}/ so
# this rule is belt-and-suspenders for the legacy in-tree default.
tmp/

# Test reports + adhoc logs
*/build/reports/
*/build/test-results/
*.log
