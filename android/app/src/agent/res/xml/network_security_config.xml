<?xml version="1.0" encoding="utf-8"?>
<!--
  Network-security config for the `agent` buildType ONLY.

  Default Android policy (release + debug) denies cleartext HTTP/WS
  to every domain — correct production behavior, and exactly what
  blocked our first sandbox enrollment attempt against a plain `ws://`
  broker.  The agent buildType is an adb-driven instrumented test
  channel with applicationId `com.gutschke.wgrtc.agent`, never
  published to Play Store and never present in `release/` or `debug/`
  source sets, so a broadly permissive cleartext policy here has no
  blast radius beyond test rigs.

  The release variant does NOT pick this file up: `src/agent/` is
  absent from the release source set, and the `network_security_config`
  attribute is only declared in `src/agent/AndroidManifest.xml`.
  `:app:verifyAgentNotInRelease` (a Gradle task) scans the release
  APK's dex/resources for any `agent` traces and fails the build if
  one slips through.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
