<?xml version="1.0" encoding="utf-8"?>
<!--
  Network-security config for the `agent` buildType ONLY.

  Default Android policy (release + debug) denies cleartext HTTP/WS
  to every domain — correct production behaviour, and exactly what
  blocked our first sandbox enrollment attempt (`ws://10.10.50.0:9000/peerjs`).
  The agent buildType is an adb-driven instrumented test channel
  with applicationId `com.gutschke.wgrtc.agent`, never published.
  Allowing cleartext to RFC 1918 + TEST-NET-1 ranges only is the
  smallest blast-radius unblock for sandbox-broker tests.

  The release variant does NOT pick this file up: `src/agent/` is
  absent from the release source set, and the `network_security_config`
  attribute is only declared in `src/agent/AndroidManifest.xml`.
-->
<network-security-config>
    <!-- Test-rig brokers: 10.0.0.0/8 (LAN sandbox), 192.0.2.0/24
         (RFC 5737 TEST-NET-1), 198.51.100.0/24 (TEST-NET-2),
         203.0.113.0/24 (TEST-NET-3), and 127.0.0.0/8 (loopback).
         Cleartext WS to anything else still rejected. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.10.50.0</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
