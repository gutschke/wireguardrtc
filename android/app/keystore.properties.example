# Copy to keystore.properties (gitignored) and fill in the real
# values when you want assembleRelease / bundleRelease to produce
# a Play-Store-uploadable artefact.
#
# See ../reference/PLAY_STORE_NOTES.md for the keystore generation
# command + storage rationale.

# Absolute or repo-root-relative path to the upload keystore.
storeFile=/path/to/wgrtc-upload.keystore

# Keystore password (encrypts the keystore file at rest).
storePassword=CHANGEME

# Alias inside the keystore.
keyAlias=wgrtc-upload

# Per-key password (often same as storePassword for single-key
# stores).
keyPassword=CHANGEME
