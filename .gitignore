# ──────────────────────────────────────────────────────────────────
# Daemon (Python / Debian)
# ──────────────────────────────────────────────────────────────────
daemon/venv/
daemon/__pycache__/
daemon/**/*.pyc
daemon/**/*.pyo

# Debian package build artifacts
daemon/debian/wireguardrtc/
daemon/debian/files
daemon/debian/debhelper-build-stamp
daemon/debian/*.debhelper.log
daemon/debian/*.substvars
daemon/debian/.debhelper/
daemon/debian/*.debhelper

# Built packages (land in the repo root by default)
*.deb
*.buildinfo
*.changes

# Daemon doc build outputs (generated from .md source under docs/)
docs/wg-holepunch-guide.html
docs/wg-holepunch-guide.pdf

# Daemon test deps
daemon/tests/node_modules/

# ──────────────────────────────────────────────────────────────────
# Android
# ──────────────────────────────────────────────────────────────────
android/build/
android/.gradle/
android/.kotlin/
android/.idea/
android/local.properties
android/**/build/
android/**/*.iml

# Keystores — never commit
android/app/keystore.properties
android/**/*.keystore
android/**/*.jks

# Native (cgo) build outputs
android/wgbridge_native/build/
android/wgbridge_native/wgbridge_native
android/wgbridge-native-aar/build/

# Test reports + ad-hoc logs
android/**/build/reports/
android/**/build/test-results/
*.log

# Android packaging artifacts
android/**/*.aab
android/**/*.apk

# Release staging dir (`dist/` is built per release; contents are the
# .deb + .apk + SHA256SUMS attached to the GitHub Release).
dist/

# ──────────────────────────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────────────────────────
.DS_Store
