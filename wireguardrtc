KEY_ORACLE_DEFAULT_SOCKET = "/run/wireguardrtc/oracle.sock"
RAW_HELPER_DEFAULT_SOCKET = "/run/wireguardrtc/raw.sock"


class KeyOracleClient:
    """Client for the privileged key-oracle service.

    The oracle is a separate process that holds the WireGuard private
    keys in memory; the daemon talks to it over a Unix socket so that
    raw key bytes never enter the daemon's address space.  See
    SECURITY/Auto-enrollment privilege separation in wireguardrtc(8)
    for the threat model.

    All RPCs are async-await so the daemon can issue them from its
    asyncio coroutines without blocking; one oracle connection is
    held for the daemon's whole lifetime, with a lock serialising
    requests because the wire protocol is one request → one response.
    """
    def __init__(self, sock_path: str):
        self.sock_path = sock_path
        self.reader: Optional[asyncio.StreamReader] = None
        self.writer: Optional[asyncio.StreamWriter] = None
        self._lock = asyncio.Lock()

    async def connect(self) -> bool:
        try:
            self.reader, self.writer = await asyncio.open_unix_connection(
                self.sock_path)
            return True
        except (FileNotFoundError, ConnectionRefusedError, PermissionError,
                OSError) as e:
            logging.info("key oracle socket %s not reachable: %s",
                         self.sock_path, e)
            return False

    async def _rpc(self, req: dict) -> dict:
        if self.writer is None or self.reader is None:
            raise IOError("oracle not connected")
        async with self._lock:
            self.writer.write((json.dumps(req) + "\n").encode("utf-8"))
            await self.writer.drain()
            line = await self.reader.readline()
        if not line:
            raise IOError("oracle closed connection")
        try:
            return json.loads(line.decode("utf-8"))
        except json.JSONDecodeError as e:
            raise IOError(f"oracle returned non-JSON: {e}")

    async def derive_sigbox(self, iface: str, peer_pub_b64: str) -> bytes:
        resp = await self._rpc({
            "op": "derive_sigbox",
            "iface": iface, "peer_pub": peer_pub_b64,
        })
        if not resp.get("ok"):
            raise IOError(f"oracle derive_sigbox: {resp.get('error')}")
        return base64.b64decode(resp["key"])

    async def derive_enroll(self, iface: str, peer_pub_b64: str,
                            token: bytes) -> bytes:
        token_url = (base64.urlsafe_b64encode(token)
                     .rstrip(b"=").decode("ascii"))
        resp = await self._rpc({
            "op": "derive_enroll",
            "iface": iface, "peer_pub": peer_pub_b64,
            "token": token_url,
        })
        if not resp.get("ok"):
            raise IOError(f"oracle derive_enroll: {resp.get('error')}")
        return base64.b64decode(resp["key"])

    async def set_endpoint(self, iface: str, peer_pub_b64: str,
                           ip: str, port: int) -> bool:
        try:
            resp = await self._rpc({
                "op": "set_endpoint",
                "iface": iface, "peer_pub": peer_pub_b64,
                "ip": ip, "port": int(port),
            })
        except IOError as e:
            logging.warning("oracle set_endpoint IPC failed: %s", e)
            return False
        if not resp.get("ok"):
            logging.warning("oracle set_endpoint refused: %s",
                            resp.get("error"))
            return False
        return True

    async def list_interfaces(self) -> list:
        try:
            resp = await self._rpc({"op": "list_interfaces"})
        except IOError as e:
            logging.warning("oracle list_interfaces failed: %s", e)
            return []
        return resp.get("interfaces", []) if resp.get("ok") else []

    async def iface_field(self, iface: str, field: str) -> str:
        try:
            resp = await self._rpc({
                "op": "iface_field", "iface": iface, "field": field})
        except IOError as e:
            logging.warning("oracle iface_field(%s,%s) failed: %s",
                            iface, field, e)
            return ""
        return resp.get("value", "") if resp.get("ok") else ""

    async def iface_table(self, iface: str, field: str) -> dict:
        try:
            resp = await self._rpc({
                "op": "iface_table", "iface": iface, "field": field})
        except IOError as e:
            logging.warning("oracle iface_table(%s,%s) failed: %s",
                            iface, field, e)
            return {}
        return resp.get("table", {}) if resp.get("ok") else {}


class RawHelperClient:
    """Client for the privileged raw-socket helper service.

    Same single-connection-with-async-lock pattern as KeyOracleClient.
    The helper holds CAP_NET_RAW; this lets the daemon process drop
    *all* capabilities while still being able to do the spoofy
    hole-punch and SO_BINDTODEVICE-via-WG-iface wakeups.
    """
    def __init__(self, sock_path: str):
        self.sock_path = sock_path
        self.reader: Optional[asyncio.StreamReader] = None
        self.writer: Optional[asyncio.StreamWriter] = None
        self._lock = asyncio.Lock()

    async def connect(self) -> bool:
        try:
            self.reader, self.writer = await asyncio.open_unix_connection(
                self.sock_path)
            return True
        except (FileNotFoundError, ConnectionRefusedError, PermissionError,
                OSError) as e:
            logging.info("raw-helper socket %s not reachable: %s",
                         self.sock_path, e)
            return False

    async def _rpc(self, req: dict) -> dict:
        if self.writer is None or self.reader is None:
            raise IOError("raw-helper not connected")
        async with self._lock:
            self.writer.write((json.dumps(req) + "\n").encode("utf-8"))
            await self.writer.drain()
            line = await self.reader.readline()
        if not line:
            raise IOError("raw-helper closed connection")
        try:
            return json.loads(line.decode("utf-8"))
        except json.JSONDecodeError as e:
            raise IOError(f"raw-helper returned non-JSON: {e}")

    async def inject(self, iface: str, src_port: int,
                     dst_ip: str, dst_port: int) -> bool:
        try:
            resp = await self._rpc({
                "op": "inject",
