        except IOError as e:
            logging.warning("raw-helper inject IPC failed: %s", e)
            return False
        if not resp.get("ok"):
            logging.warning("raw-helper inject refused: %s",
                            resp.get("error"))
            return False
        return True

    async def wake(self, iface: str, target_ip: str) -> bool:
        try:
            resp = await self._rpc({
                "op": "wake",
                "iface": iface, "target_ip": target_ip,
            })
        except IOError as e:
            logging.warning("raw-helper wake IPC failed: %s", e)
            return False
        if not resp.get("ok"):
            logging.warning("raw-helper wake refused: %s",
                            resp.get("error"))
            return False
        return True


