    import websockets
    from nacl.bindings import crypto_scalarmult
    from nacl.hash import blake2b as _nacl_blake2b
    from nacl.encoding import RawEncoder as _NaclRawEncoder
    from nacl.secret import SecretBox
except ImportError as e:
    sys.stderr.write(
        f"[FATAL] missing dependency: {e}\n"
        "Install with: pip install websockets pynacl\n"
    )
    sys.exit(2)


# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

CONFIG_DIR = Path(os.environ.get("WIREGUARDRTC_CONFIG_DIR", "/etc/wireguardrtc"))
GLOBAL_CONFIG = CONFIG_DIR / "wireguardrtc.conf"
PEERS_DIR = CONFIG_DIR / "peers.d"
LOCK_FILE = Path(os.environ.get("WIREGUARDRTC_LOCK_FILE",
                                 "/run/wireguardrtc/lock"))

PROTOCOL_VERSION = 1
PROTOCOL_LABEL = b"wg-peerjs/v1/sigbox"  # wire format is locked; do not change
PROTOCOL_FRESHNESS_WINDOW = 90.0  # seconds; reject older or further-in-future

# Plaintext-size caps applied AFTER secretbox auth-tag verification.
# A peer with the right private key could otherwise hand us
# arbitrarily-large JSON to parse (memory exhaustion).  Real OFFER
# plaintexts are ~80 bytes; ENROLL plaintexts ~300; ENROLL_OK ~500.
# Caps are an order of magnitude over the largest legitimate case.
MAX_SIGBOX_PLAINTEXT = 1024
MAX_ENROLL_PLAINTEXT = 4096
# Same idea for the wire-format ciphertext (post-base64) before we
# even decrypt — attacker-controlled length, amortised over the
# decode and the secretbox call.
MAX_SIGBOX_CIPHERTEXT_B64 = 2048
MAX_ENROLL_CIPHERTEXT_B64 = 8192

POLL_INTERVAL = 30.0
HANDSHAKE_DEAD_THRESHOLD = 180.0  # >120 s rekey + 60 s grace
SIGNALING_BACKOFF_INITIAL = 30.0   # first retry after a failed hole-punch
SIGNALING_BACKOFF_MAX = 300.0      # cap; also used as the steady-state interval
SIGNALING_BACKOFF = SIGNALING_BACKOFF_MAX  # kept for log messages
REINJECT_INTERVAL = 20.0  # re-inject while DOWN to keep conntrack entry alive
PEERJS_HEARTBEAT = 5.0
STUN_TIMEOUT = 2.5
RAW_INJECT_REPEATS = 3
RAW_INJECT_GAP = 0.05  # seconds between repeats
WAKE_TARGET_BOGON = "192.0.2.1"  # TEST-NET-1, used for /0 catchall

OFFER_RESPONSE_MIN_INTERVAL = 25.0   # min gap between outbound OFFERs (incl. responses)
OFFER_EXCHANGE_QUARANTINE_THRESHOLD = 8   # exchanges without tunnel-up → quarantine
OFFER_EXCHANGE_WINDOW = 600.0        # rolling window for exchange count (10 min)
OFFER_QUARANTINE_DURATION = 300.0    # quarantine duration after threshold (5 min)

DEFAULT_STUN_SERVERS = [
    "stun.l.google.com:19302",
    "stun.cloudflare.com:3478",
    "stun.nextcloud.com:3478",
]
DEFAULT_PEERJS_SERVER = "wss://0.peerjs.com/peerjs"
DEFAULT_PEERJS_KEY = "peerjs"

STUN_MAGIC_COOKIE = 0x2112A442


# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------


class Mode(enum.Enum):
    ACTIVE = "active"
    PASSIVE = "passive"
    DNS_ROAM = "dns-roam"
    IGNORE = "ignore"


@dataclasses.dataclass
class PeerConfig:
    public_key: str
    mode: Mode
    label: str  # filename stem, for logs
    dns_host: Optional[str] = None  # only meaningful for DNS_ROAM


@dataclasses.dataclass
class GlobalConfig:
    salt: bytes
    peerjs_server: str
    peerjs_key: str
    stun_servers: list
    public_ip: Optional[str] = None  # IPv4 override; bypasses STUN if set
    stun_strict: bool = False  # if true, reject private/non-global STUN responses
    enrollment_enabled: bool = False
    provision_script: Optional[str] = None
    state_dir: Path = Path("/var/lib/wireguardrtc")
    max_pending_tokens: int = 32
    # When the daemon successfully enrols a peer, write a peers.d-style
    # drop-in to <state_dir>/auto-enrolled.d/ so the daemon pushes
    # signalling OFFERs to it (Mode=active) without requiring the admin
    # to hand-author a peers.d/<label>.conf.  An explicit drop-in in
    # /etc/wireguardrtc/peers.d/ always wins over the auto-enrolled
    # entry.  See [Enrollment] AutoActive in wireguardrtc(5).
    auto_active_enrollment: bool = True


def load_global_config(path: Path) -> GlobalConfig:
    cp = configparser.ConfigParser()
    cp.optionxform = str  # preserve case for base64 values
    if not cp.read(path):
        sys.stderr.write(f"[FATAL] config file not found: {path}\n")
        sys.exit(2)

    salt_str = cp.get("Global", "Salt", fallback="").strip()
    if not salt_str or salt_str == "CHANGE_ME_TO_A_SECURE_RANDOM_STRING":
        sys.stderr.write(
            f"[FATAL] {path}: [Global] Salt must be set to a unique random value.\n"
            "Generate one with: head -c 32 /dev/urandom | base64\n"
        )
        sys.exit(2)
    salt = salt_str.encode("utf-8")

    peerjs_server = cp.get("Global", "PeerJsServer", fallback=DEFAULT_PEERJS_SERVER).strip()
    peerjs_key = cp.get("Global", "PeerJsKey", fallback=DEFAULT_PEERJS_KEY).strip()

    public_ip_str = cp.get("Global", "PublicIp", fallback="").strip()
    public_ip = None
    if public_ip_str:
        try:
            addr = ipaddress.ip_address(public_ip_str)
        except ValueError:
            sys.stderr.write(
                f"[FATAL] {path}: [Global] PublicIp = {public_ip_str!r} "
                "is not a valid IP address.\n"
            )
            sys.exit(2)
        if not isinstance(addr, ipaddress.IPv4Address):
            sys.stderr.write(
                f"[FATAL] {path}: [Global] PublicIp must be IPv4. "
                "IPv6 endpoint publication is not yet implemented; "
                "see wg-holepunch-guide.md §8 (Limitations).\n"
            )
            sys.exit(2)
        if (addr.is_loopback or addr.is_multicast or addr.is_link_local
                or addr.is_unspecified or addr.is_reserved):
            sys.stderr.write(
                f"[FATAL] {path}: [Global] PublicIp = {public_ip_str} "
                "is not routable on the public internet.\n"
            )
            sys.exit(2)
        public_ip = str(addr)

    stun_raw = cp.get("Stun", "Servers", fallback=", ".join(DEFAULT_STUN_SERVERS))
    stun = [s.strip() for s in stun_raw.split(",") if s.strip()]

    # When `Strict = yes`, get_public_ipv4() rejects STUN responses
    # that report a non-globally-routable address (private RFC 1918,
    # CGN, loopback, link-local, multicast, unspecified, reserved).
    # Catches a hijacked or misconfigured STUN server feeding us an
    # internal IP that we'd otherwise advertise as the host's
    # publicly-reachable endpoint.  Default off because LAN-only
    # deployments legitimately need to advertise private addresses.
    stun_strict = cp.getboolean("Stun", "Strict", fallback=False)

    enrollment_enabled = cp.getboolean(
        "Enrollment", "Enabled", fallback=False)
    provision_script = cp.get(
        "Enrollment", "ProvisionScript", fallback="").strip() or None
    state_dir_str = cp.get(
        "Enrollment", "StateDir", fallback="/var/lib/wireguardrtc").strip()
    try:
        max_pending = cp.getint("Enrollment", "MaxPendingTokens", fallback=32)
    except ValueError:
        sys.stderr.write(
            f"[FATAL] {path}: [Enrollment] MaxPendingTokens must be an integer.\n")
        sys.exit(2)
    if max_pending < 1 or max_pending > 1000:
        sys.stderr.write(
            f"[FATAL] {path}: [Enrollment] MaxPendingTokens out of range "
            f"(got {max_pending}, allowed 1..1000).\n")
        sys.exit(2)
    if enrollment_enabled and not provision_script:
        sys.stderr.write(
            f"[FATAL] {path}: [Enrollment] Enabled requires "
            f"ProvisionScript to be set.\n")
        sys.exit(2)
    auto_active = cp.getboolean(
        "Enrollment", "AutoActive", fallback=True)

    return GlobalConfig(
        salt=salt,
        peerjs_server=peerjs_server,
        peerjs_key=peerjs_key,
        stun_servers=stun,
        public_ip=public_ip,
        stun_strict=stun_strict,
        enrollment_enabled=enrollment_enabled,
        provision_script=provision_script,
        state_dir=Path(state_dir_str),
        max_pending_tokens=max_pending,
        auto_active_enrollment=auto_active,
    )


AUTO_ACTIVE_SUBDIR = "auto-enrolled.d"


def auto_active_dir(state_dir: Path) -> Path:
    """Path to the runtime drop-in directory the daemon writes to
    when [Enrollment] AutoActive = yes.  Lives under state_dir
    (writable by the daemon), separate from the read-only admin
    dir at /etc/wireguardrtc/peers.d.  Per-pubkey filenames; the
    daemon scans this in addition to the admin dir."""
    return state_dir / AUTO_ACTIVE_SUBDIR


def write_auto_active_peer(state_dir: Path, pubkey_b64: str,
                           label: str, iface: str) -> None:
    """Write a peers.d-style drop-in for a freshly-enrolled peer with
    Mode=active.  Filename is the SHA-256 fingerprint of the pubkey
    (truncated, hex) so admin and auto-enrolled drop-ins can never
    collide on filename, and re-enrolment of the same pubkey
    overwrites idempotently."""
    aa_dir = auto_active_dir(state_dir)
    aa_dir.mkdir(parents=True, exist_ok=True)
    os.chmod(aa_dir, 0o700)
    fp = hashlib.sha256(pubkey_b64.encode("utf-8")).hexdigest()[:16]
    # Sanitise label for use as a filename hint — admin-supplied
    # via the URI's name field, but already validated by
    # cmd_enroll_token to be free of path-injecting characters.
    safe_label = "".join(c for c in label
                         if c.isalnum() or c in "-_.") or "peer"
    path = aa_dir / f"{safe_label}-{fp}.conf"
    body = (f"# auto-generated by wireguardrtc on enrolment.\n"
            f"# An admin-authored entry in /etc/wireguardrtc/peers.d/\n"
            f"# with the same PublicKey overrides this drop-in.\n"
            f"# Manage / delete via the same flow as peers.d: this\n"
            f"# file is a regular wireguardrtc peer drop-in.\n"
            f"[Peer]\n"
            f"PublicKey = {pubkey_b64}\n"
            f"Mode = active\n"
            f"# Iface = {iface}\n")
    tmp = path.with_suffix(".tmp")
    fd = os.open(str(tmp), os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    try:
        with os.fdopen(fd, "w") as f:
            f.write(body)
    except BaseException:
        try: os.unlink(tmp)
        except OSError: pass
        raise
    os.replace(tmp, path)


def load_peer_configs(directory: Path,
                      auto_active_directory: Optional[Path] = None) -> dict:
    """Load every drop-in. Returns {public_key: PeerConfig}.

    Two source directories:
      - `directory` — the admin-authored, read-only
        /etc/wireguardrtc/peers.d.  Authoritative.
      - `auto_active_directory` — the runtime drop-in dir under
        state_dir, populated by write_auto_active_peer() when
        [Enrollment] AutoActive = yes.

    Admin entries win on pubkey collision so an explicit override
    never fires.  Pass None for auto_active_directory to skip the
    auto-loaded set entirely (CLI tools that don't care about
    runtime peers, e.g. --show-config).
    """
    out: dict = {}
    # Auto-active first; admin overrides next so admin wins on
    # collision.  Both dirs use the same drop-in format.
    for d in [auto_active_directory, directory]:
        if d is None or not d.is_dir():
            continue
        out = _merge_peer_dir(out, d, override=(d == directory))
    return out


def _merge_peer_dir(into: dict, directory: Path, override: bool) -> dict:
    for path in sorted(directory.glob("*.conf")):
        cp = configparser.ConfigParser()
        cp.optionxform = str
        if not cp.read(path):
            logging.warning("could not read %s", path)
            continue
        if "Peer" not in cp:
            logging.warning("%s: no [Peer] section, skipping", path)
            continue
        sec = cp["Peer"]
        pubkey = sec.get("PublicKey", "").strip()
        if not pubkey:
            logging.warning("%s: no PublicKey in [Peer], skipping", path)
            continue
        mode_str = sec.get("Mode", "passive").strip().lower()
        try:
            mode = Mode(mode_str)
        except ValueError:
            logging.warning("%s: unknown Mode=%r, defaulting to passive",
                            path, mode_str)
            mode = Mode.PASSIVE
        dns_host = sec.get("DnsHost", "").strip() or None
        if mode == Mode.DNS_ROAM and not dns_host:
            logging.warning("%s: dns-roam requires DnsHost, ignoring peer", path)
            continue
        if pubkey in into and not override:
            # Auto-active dir runs first (override=False).  If admin
            # later loads the same pubkey, that's the override path
            # below — no warning.
            logging.debug("%s: duplicate PublicKey already loaded from %s",
                          path, into[pubkey].label)
            continue
        if pubkey in into and override:
            # Admin override — silently replace the auto-active entry.
            pass
        into[pubkey] = PeerConfig(
            public_key=pubkey,
            mode=mode,
            label=path.stem,
            dns_host=dns_host,
        )
    return into


# ---------------------------------------------------------------------------
# Anti-spam logging
# ---------------------------------------------------------------------------


class StateLogger:
    """Emit a line only when the (scope, key) value changes."""
    def __init__(self):
        self._state = {}

    def event(self, scope, key, value, message, level=logging.INFO):
        cell = (scope, key)
        if self._state.get(cell) == value:
            return
        self._state[cell] = value
        logging.log(level, "[%s] %s", scope, message)


LOG = StateLogger()


# ---------------------------------------------------------------------------
# WireGuard kernel state (via `wg`)
# ---------------------------------------------------------------------------


def wg_show(*args) -> str:
    res = subprocess.run(
        ["wg", "show", *args],
        capture_output=True, text=True, timeout=5,
    )
    if res.returncode != 0:
        # caller decides what to do; don't spam
        return ""
    return res.stdout


def wg_set(*args) -> bool:
    res = subprocess.run(
        ["wg", "set", *args],
        capture_output=True, text=True, timeout=5,
    )
    if res.returncode != 0:
        logging.warning("wg set %s failed: %s",
                        " ".join(args), res.stderr.strip())
        return False
    return True


def list_interfaces() -> list:
    return wg_show("interfaces").split()


def get_iface_field(iface, field) -> str:
    return wg_show(iface, field).strip()


def get_iface_table(iface, field) -> dict:
    """For per-peer fields like endpoints/allowed-ips/latest-handshakes:
    returns {pubkey: rest_of_line_with_whitespace_separated_values}."""
    out = {}
    for line in wg_show(iface, field).splitlines():
        parts = line.split(None, 1)
        if len(parts) == 2:
            out[parts[0]] = parts[1]
        elif len(parts) == 1:
            out[parts[0]] = ""
    return out


# ---------------------------------------------------------------------------
# STUN client (async, validates txid)
# ---------------------------------------------------------------------------


async def stun_query(server, timeout=STUN_TIMEOUT) -> Optional[tuple]:
    """Returns (external_ip, external_port) on success, or None."""
    if ":" not in server:
        return None
    host, port_s = server.rsplit(":", 1)
    try:
        port = int(port_s)
    except ValueError:
        return None
    loop = asyncio.get_running_loop()
    try:
        infos = await loop.getaddrinfo(host, None, family=socket.AF_INET,
                                       type=socket.SOCK_DGRAM)
    except socket.gaierror:
        return None
    if not infos:
        return None
    server_ip = infos[0][4][0]

    txid = os.urandom(12)
    request = struct.pack("!HHL12s", 0x0001, 0, STUN_MAGIC_COOKIE, txid)

    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.setblocking(False)
    sock.bind(("0.0.0.0", 0))
    try:
        sock.sendto(request, (server_ip, port))
        deadline = loop.time() + timeout
        while loop.time() < deadline:
            remaining = deadline - loop.time()
            try:
                data = await asyncio.wait_for(loop.sock_recv(sock, 2048),
                                              timeout=remaining)
            except asyncio.TimeoutError:
                return None
            if len(data) < 20:
                continue
            msg_type, msg_len, magic, resp_txid = struct.unpack("!HHL12s",
                                                                data[:20])
            if (msg_type != 0x0101 or magic != STUN_MAGIC_COOKIE
                    or resp_txid != txid):
                continue
            offset = 20
            end = 20 + msg_len
            while offset + 4 <= end:
                atype, alen = struct.unpack("!HH", data[offset:offset + 4])
                offset += 4
                if atype == 0x0020 and alen >= 8:
                    family = data[offset + 1]
                    if family == 0x01:
                        xport = struct.unpack("!H",
                                              data[offset + 2:offset + 4])[0]
                        xip = struct.unpack("!L",
                                            data[offset + 4:offset + 8])[0]
                        ext_port = xport ^ (STUN_MAGIC_COOKIE >> 16)
                        ext_ip = socket.inet_ntoa(
                            struct.pack("!L", xip ^ STUN_MAGIC_COOKIE))
                        return ext_ip, ext_port
                offset += alen + ((4 - (alen % 4)) % 4)
        return None
    finally:
        sock.close()


async def get_public_ipv4(stun_servers, state) -> Optional[str]:
    """Return the host's public IPv4 address.

    If the GlobalConfig has a `public_ip` override set, return it immediately
    and skip STUN entirely.  Otherwise query each STUN server in order and
    return the first answer.  Used by deployments where the host has a known
    static public IPv4 address (typical for VPS or anycast setups), or where
    no public STUN server is reachable from the host's network namespace.

    With `[Stun] Strict = yes`, STUN responses whose XOR-MAPPED-ADDRESS
    is non-globally-routable (RFC 1918 private, CGN, loopback, etc.)
    are skipped — guards against a hijacked or misconfigured STUN
    server feeding us an internal IP.  We try the next server in the
    list.  Default is off because LAN-only deployments legitimately
    advertise private addresses.
    """
    if getattr(state, "public_ip", None):
        LOG.event("stun", "public_ip", state.public_ip,
                  f"public IPv4 = {state.public_ip} (configured override; "
                  f"STUN skipped)")
        return state.public_ip
    strict = getattr(state, "stun_strict", False)
    for server in stun_servers:
        result = await stun_query(server)
        if result is None:
            continue
        ext_ip, _ = result
        if strict:
            try:
                addr = ipaddress.ip_address(ext_ip)
            except ValueError:
                LOG.event("stun", "rejected", f"{server}:{ext_ip}",
                          f"STUN strict: {server} returned malformed "
                          f"address {ext_ip!r}; trying next",
                          level=logging.WARNING)
                continue
            if not addr.is_global:
                LOG.event("stun", "rejected", f"{server}:{ext_ip}",
                          f"STUN strict: {server} returned "
                          f"non-routable {ext_ip}; trying next",
                          level=logging.WARNING)
                continue
        LOG.event("stun", "public_ip", ext_ip,
                  f"public IPv4 mapped as {ext_ip} via {server}")
        return ext_ip
    LOG.event("stun", "public_ip", None, "STUN: no server responded")
    return None


# ---------------------------------------------------------------------------
# Crypto: domain-separated SecretBox
# ---------------------------------------------------------------------------


def derive_secretbox_key(my_priv_b64: str, peer_pub_b64: str) -> bytes:
    """X25519 ECDH then BLAKE2b-keyed → 32-byte SecretBox key.

    Domain separation: the resulting key is bound to PROTOCOL_LABEL; it can
    never collide with WireGuard's own session keys or any other use of the
    same Curve25519 keypair.
    """
    my_priv = base64.b64decode(my_priv_b64)
    peer_pub = base64.b64decode(peer_pub_b64)
    shared = crypto_scalarmult(my_priv, peer_pub)
    # generichash(in, key=label, digest_size=32) is a keyed BLAKE2b.
    return _nacl_blake2b(shared, digest_size=32, key=PROTOCOL_LABEL[:32], encoder=_NaclRawEncoder)


def encrypt_envelope(key: bytes,
                     candidates: list,
                     ts: Optional[int] = None) -> str:
    """Encrypt a signalling-OFFER blob carrying a list of candidate
    endpoints in preference order.  Sender empties the list for a
    `signal_wake` (it doesn't claim an endpoint).  See
    project_protocol_signal_wake_candidates memo for rationale."""
    payload = {
        "v": PROTOCOL_VERSION,
        "ts": int(ts if ts is not None else time.time()),
        "candidates": list(candidates or []),
    }
    box = SecretBox(key)
    ct = box.encrypt(json.dumps(payload).encode("utf-8"))
    return base64.b64encode(ct).decode("ascii")


def decrypt_envelope(key: bytes, blob_b64: str) -> Optional[dict]:
    """Decrypt + validate (version, freshness, structural shape).
    Returns the plaintext dict on success or None on any failure
    (silent — the receiver shouldn't leak per-step distinctions to
    a probing attacker)."""
    if not isinstance(blob_b64, str) or len(blob_b64) > MAX_SIGBOX_CIPHERTEXT_B64:
        return None
    try:
        ct = base64.b64decode(blob_b64)
        plain = SecretBox(key).decrypt(ct)
        if len(plain) > MAX_SIGBOX_PLAINTEXT:
            return None
        msg = json.loads(plain.decode("utf-8"))
    except Exception:
        return None
    if msg.get("v") != PROTOCOL_VERSION:
        return None
    ts = msg.get("ts")
    if not isinstance(ts, int):
        return None
    if abs(time.time() - ts) > PROTOCOL_FRESHNESS_WINDOW:
        return None
    # Normalise: every plaintext now carries `candidates` (list).
    # Reject anything else.
    cands = msg.get("candidates")
    if not isinstance(cands, list):
        return None
    return msg


def first_valid_candidate(msg: dict) -> Optional[tuple]:
    """Return the first `(ip, port)` candidate from a decrypted
    OFFER plaintext that passes [is_valid_public_endpoint], or None.
    Validation is per-candidate; bad entries are skipped silently
    (they're either typos or maliciously-injected garbage and the
    receiver mustn't dump kernel WG state into them).
    """
    for c in msg.get("candidates", []) or []:
        if not isinstance(c, dict):
            continue
        ip = c.get("ip")
        port = c.get("port")
        if not isinstance(ip, str) or not isinstance(port, int):
            continue
        if not is_valid_public_endpoint(ip, port):
            continue
        return ip, port
    return None


def is_valid_public_endpoint(ip: str, port: int) -> bool:
    """Reject loopback, link-local, multicast, unspecified, reserved, and
    weirdly-low ports. A malicious peer could otherwise redirect WG to dump
    handshakes onto a metadata service or local link."""
    try:
        addr = ipaddress.ip_address(ip)
    except ValueError:
        return False
    if (addr.is_loopback or addr.is_multicast or addr.is_link_local
            or addr.is_unspecified or addr.is_reserved):
        return False
    if isinstance(addr, ipaddress.IPv4Address) and addr.is_private:
        # Private addresses can be legitimate on LAN deployments. Allow for now;
        # an admin who wants strict global-only behaviour can add a filter.
        pass
    if not (1 <= port <= 65535):
        return False
    return True


# ---------------------------------------------------------------------------
# Auto-enrollment crypto helpers (cf. PLAN.md §4.4.2)
# ---------------------------------------------------------------------------


def derive_enroll_key(local_priv_b64: str, peer_pub_b64: str,
                      token: bytes) -> bytes:
    """Compute final_key = BLAKE2b(BLAKE2b(ECDH, key=LABEL_ENROLL), key=token).

    Domain separation:
      - LABEL_ENROLL guards against any cross-protocol key reuse
        (signalling uses LABEL_PROTOCOL = b"wg-peerjs/v1/sigbox").
      - Re-keying with `token` binds this key to a specific single-use
        enrollment voucher.  An attacker who lacks `token` cannot derive
        final_key even if they hold one of the long-term private keys.
    """
    local_priv = base64.b64decode(local_priv_b64)
    peer_pub = base64.b64decode(peer_pub_b64)
    shared = crypto_scalarmult(local_priv, peer_pub)
    enroll_key = _nacl_blake2b(shared, digest_size=32,
                               key=LABEL_ENROLL[:32],
                               encoder=_NaclRawEncoder)
    final_key = _nacl_blake2b(enroll_key, digest_size=32,
                              key=token,
                              encoder=_NaclRawEncoder)
    return final_key


def decrypt_enroll_blob(key: bytes, blob_b64: str) -> Optional[dict]:
    """Decrypt and JSON-parse an enrollment ciphertext.  Returns None on
    auth-tag failure, malformed JSON, or unknown protocol version.

    Enforces a ciphertext-length cap before decoding and a plaintext
    cap after decryption — defense-in-depth against memory exhaustion
    by an attacker who somehow ended up with a valid token (so they
    can produce real auth-tagged ciphertexts) and feeds us oversized
    JSON to parse."""
    if not isinstance(blob_b64, str) or len(blob_b64) > MAX_ENROLL_CIPHERTEXT_B64:
        return None
    try:
        ct = base64.b64decode(blob_b64)
        plain = SecretBox(key).decrypt(ct)
        if len(plain) > MAX_ENROLL_PLAINTEXT:
            return None
        msg = json.loads(plain.decode("utf-8"))
    except Exception:
        return None
    if msg.get("v") != PROTOCOL_VERSION:
        return None
    return msg


def encrypt_enroll_blob(key: bytes, plaintext: dict) -> str:
    box = SecretBox(key)
    ct = box.encrypt(json.dumps(plaintext).encode("utf-8"))
    return base64.b64encode(ct).decode("ascii")


def build_enroll_envelope(dst_routing_id: str, kind: str,
                          server_pub_b64: str,
                          ciphertext_b64: str) -> dict:
    """Wrap an enrollment response (ENROLL_OK / ENROLL_ERR) in the same
    WebRTC OFFER envelope used by signalling, so the public PeerJS broker
    forwards it.  Discriminator is `metadata.kind`."""
    conn_id = "dc_" + secrets.token_hex(6)
    return {
        "type": "OFFER",
        "dst": dst_routing_id,
        "payload": {
            "sdp": {"sdp": build_peerjs_sdp(), "type": "offer"},
            "type": "data",
            "connectionId": conn_id,
            "label": conn_id,
            "reliable": False,
            "serialization": "binary",
            "metadata": {
                "v": PROTOCOL_VERSION,
                "kind": kind,
                "server_pub": server_pub_b64,
                "blob": ciphertext_b64,
            },
        },
    }


PROVISION_PERMITS_DIR = "/var/lib/wireguardrtc-provision-broker/permits"


def remove_provision_permit(token: bytes) -> None:
    """Best-effort: remove a previously-written provisioning permit.

    Used when a token is superseded (re-mint of the same name) so a
    stale URL the admin might already have shipped cannot sneak through
    the broker.  Honours the same env-var override
    (``WIREGUARDRTC_PROVISION_PERMITS_DIR``) that
    write_provision_permit() uses.
    """
    permits_dir = os.environ.get(
        "WIREGUARDRTC_PROVISION_PERMITS_DIR", PROVISION_PERMITS_DIR)
    safe_token = (
        base64.urlsafe_b64encode(token).rstrip(b"=").decode("ascii"))
    try:
        os.unlink(os.path.join(permits_dir, safe_token))
    except FileNotFoundError:
        pass
    except OSError:
        # Permission / IO error — broker permit may now be stale,
        # but we deliberately don't fail the new mint over it.
        pass


def write_provision_permit(token: bytes, name_hint: str,
                           expires_at: int) -> None:
    """Drop a permit file the broker uses to gate provisioning requests.

    Permits live in a directory the daemon process cannot write to (mode
    0700, root-owned; only writable from the admin-invoked
    `wireguardrtc --enroll-token` mint flow which runs under sudo).
    The broker checks for a matching permit before invoking the
    Provisioner, so a daemon RCE outside the mint→consumption window
    cannot synthesize a permit and therefore cannot provision peers.

    Best-effort.  On systems without the broker installed, the permits
    directory will not exist; in that case we skip silently and the
    legacy direct-ProvisionScript path remains usable.
    """
    permits_dir = os.environ.get(
        "WIREGUARDRTC_PROVISION_PERMITS_DIR", PROVISION_PERMITS_DIR)
    if not os.path.isdir(permits_dir):
        # Broker not deployed (or override pointing elsewhere) — direct
        # ProvisionScript users don't need permits.
        return
    safe_token = (
        base64.urlsafe_b64encode(token).rstrip(b"=").decode("ascii"))
    permit_path = os.path.join(permits_dir, safe_token)
    permit = {
        "name_hint": name_hint,
        "expires_at": int(expires_at),
        "created_at": int(time.time()),
    }
    try:
        fd = os.open(permit_path, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        with os.fdopen(fd, "w") as f:
            json.dump(permit, f)
    except PermissionError as e:
        # Most likely cause: the user ran `wireguardrtc --enroll-token`
        # without sudo, so the mint succeeded into pending-tokens.json
        # (which the wireguardrtc group can write) but the permits dir
        # is root-only.  The mint isn't actually broken — the daemon
        # will accept the ENROLL — but the broker will refuse to
        # provision.  Warn loudly on stderr so the admin notices and
        # rerun under sudo, but don't fail the mint.
        sys.stderr.write(
            f"[WARN] could not write provisioning permit "
            f"({e.__class__.__name__}: {e}).  The token is valid but "
            f"the privileged provisioning broker will refuse to "
            f"provision unless the permit exists.  Did you forget "
            f"`sudo`?\n")
    except Exception:
        # Any other write failure: clean up any partial file and
        # re-raise so the mint command fails clearly.
        try:
            os.unlink(permit_path)
        except FileNotFoundError:
            pass
        raise


def run_provision_script(script_path: str, iface: str, name: str,
                         client_pub_b64: str,
                         token: bytes = b"",
                         timeout: float = 15.0) -> tuple:
    """Invoke the user-supplied provisioning hook.

    Contract:
        script_path IFACE NAME PUBKEY_BASE64
        env: WIREGUARDRTC_PROVISION_TOKEN = url-safe-b64(token, no padding)
    The script must add the peer to the running WireGuard interface (via
    `wg set`, writing to a config file, calling other tooling, etc.) and
    exit with status 0 on success.  The daemon then reads back the
    allocation via `wg show`.

    The optional `token` parameter is the 32-byte token we just claimed
    for this enrollment, encoded into the env var so that the script
    (typically wireguardrtc-provision-client) can forward it to the
    privileged broker for permit lookup.  Backward-compatible with
    older provision scripts: if the env var is absent and the script
    doesn't read it, no harm done.

    Inputs are validated first to refuse anything that would expand
    unsafely as shell metacharacters or as path components.  The script
    is invoked with subprocess.run (no shell=True), arguments passed
    individually — the validation here is defensive.

    Returns (ok: bool, error_message: str).
    """
    # Defensive input validation — even though we never use shell=True,
    # we want to refuse anything weird up front so a bad provision script
    # can't be tricked into doing something unintended.
    if not script_path:
        return False, "ProvisionScript not configured"
    script = Path(script_path)
    if not script.is_file() or not os.access(script_path, os.X_OK):
        return False, f"ProvisionScript {script_path} is not an executable file"
    if not iface or any(c in iface for c in "\x00/"):
        return False, f"refusing bad iface name: {iface!r}"
    # WireGuard public keys are 32 raw bytes encoded as 44 chars of
    # standard base64 (alphabet A-Za-z0-9+/=).  base64.b64decode with
    # validate=True does the right thing — any other character or
    # length anomaly raises.
    try:
        raw = base64.b64decode(client_pub_b64, validate=True)
    except Exception:
        return False, f"client_pub is not valid base64: {client_pub_b64!r}"
    if len(raw) != 32:
        return False, (f"client_pub decodes to {len(raw)} bytes, "
                       f"expected 32: {client_pub_b64!r}")
    # Name hint is admin-supplied via the URI's name field; treat it as
    # untrusted (it could be tampered with).  Refuse control chars and
    # things that look like path injections.
    if (not name or len(name) > 64
            or any(c in name for c in "\x00\n\r\t/\\$`")):
        return False, f"refusing bad name hint: {name!r}"

    env = dict(os.environ)
    if token:
        # URL-safe base64, no padding — same encoding the URI uses, and
        # the form filenames in the broker's permits dir take.
        env["WIREGUARDRTC_PROVISION_TOKEN"] = (
            base64.urlsafe_b64encode(token).rstrip(b"=").decode("ascii"))
    try:
        res = subprocess.run(
            [str(script), iface, name, client_pub_b64],
            capture_output=True, text=True, timeout=timeout, env=env)
    except subprocess.TimeoutExpired:
        return False, f"ProvisionScript timed out after {timeout}s"
    except OSError as e:
        return False, f"failed to invoke ProvisionScript: {e}"
    if res.returncode != 0:
        # Truncate stderr defensively for log output.
        err = (res.stderr or res.stdout or "").strip()
        if len(err) > 200:
            err = err[:200] + "..."
        return False, (f"ProvisionScript exited {res.returncode}"
                       + (f": {err}" if err else ""))
    return True, ""


